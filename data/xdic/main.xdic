                <Поле Имя="ДОКУМЕНТ.РАСЧМЕСЯЦ" Тип="Дата" />
                <Поле Имя="ДОКУМЕНТ.ЗАМЕСЯЦ" Тип="Дата" />
                <Поле Имя="ДОКУМЕНТ.ТИП" Тип="Строка" />
                <Поле Имя="ДОКУМЕНТ.ВИД" Тип="Строка" />
                <Поле Имя="ДОКУМЕНТ.АНАЛИТИКА" Тип="Строка" />
            </Поля>
