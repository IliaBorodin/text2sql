        <Table Имя="ЭДО Состояние" Описание="Состояния электронных документов">
            <Поля>
                <Поле Имя="Дата" Тип="Дата" Размер="2" Описание="Дата сосостояния электронного документа"/>
                <Поле Имя="Время" Тип="Время" Размер="2" Описание="Время сосостояния электронного документа"/>
                <Поле Имя="ЭДО Состояние-ЭДО Документ" Тип="Внешний ключ" Таблица="ЭДО Документ" При_удалении="CASCADE" Описание="Привязка к электронному документу. Указатель на таблицу ~ЭДО Документ~"/>
                <Поле Имя="Состояние" Тип="Целое" Размер="4" Описание="Состояние электронного документа, см. функцию ВидыСостоянийЭДО_Массив"/>
                <Поле Имя="Состояние оператора" Тип="Целое" Размер="4" Описание="Код состояния электронного документа, определяемый оператором ЭДО"/>
                <Поле Имя="Примечание" Тип="Строка" Описание="Описание состояния электронного документа, определяемое оператором ЭДО"/>
                <Поле Имя="Пользователь" Тип="Строка" Длина="50" Описание="Сведения о пользователе, получившем состояние электронного документа"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="ЭДО Состояние-ЭДО Документ" Поля="ЭДО Состояние-ЭДО Документ, Дата, Время"/>
            </Индексы_базы>
        </Table>
        <Table Имя="ЭДО Журнал" Описание="Журнал (протокол) операций электронного документооборота">
            <Поля>
                <Поле Имя="Дата" Тип="Дата" Размер="2" Описание="Дата события"/>
                <Поле Имя="Время" Тип="Время" Размер="2" Описание="Время события"/>
                <Поле Имя="Папки" Тип="Иерархия" Опции="NoDelete "/>
                <Поле Имя="Сеанс" Тип="Целое" Описание="Принадлежность события к сеансу ЭДО. Ссылка на запись в этой же таблице (первая запись выполняемой операции)"/>
                <Поле Имя="Функция" Тип="Целое" Размер="1" Описание="Выполняемая операция (функция), см. функцию ФункцииЭДО_Массив"/>
                <Поле Имя="Тип" Тип="Целое" Размер="1" Описание="Тип события: 0 - отладочное, 1 - пользовательское"/>
                <Поле Имя="Оператор" Тип="Строка" Длина="50" Описание="Код оператора ЭДО"/>
                <Поле Имя="Статус" Тип="Целое" Размер="1" Описание="Статус события: 0 - информация, 1 - ошибка, 2 - предупреждение"/>
                <Поле Имя="Запрос" Тип="Строка" Длина="50" Описание="Запрос оператору ЭДО (заголовок события)"/>
                <Поле Имя="Ответ" Тип="Строка" Длина="1000" Описание="Ответ оператора ЭДО (описание события)"/>
                <Поле Имя="ИдСессии" Тип="Строка" Длина="100" Описание="Идентификатор сессии"/>
                <Поле Имя="Пользователь" Тип="Строка" Длина="50" Описание="Сведения о пользователе, под которым выполнялась операция"/>
                <Поле Имя="Отправитель" Тип="Целое" Описание="Организация - отправитель электронного документа. Указатель на таблицу ~Организации~"/>
                <Поле Имя="Отправитель_ИД" Тип="Строка" Длина="50" Описание="Идентификатор организации-отправителя электронного документа"/>
                <Поле Имя="Получатель" Тип="Целое" Описание="Организация - получатель электронного документа. Указатель на таблицу ~Организации~"/>
                <Поле Имя="Получатель_ИД" Тип="Строка" Длина="50" Описание="Идентификатор организации-получателя электронного документа"/>
                <Поле Имя="Договор" Тип="Целое" Описание="Привязка события к договору. Указатель на таблицу ~Договор~"/>
                <Поле Имя="Документ" Тип="Целое" Описание="Привязка события к документу. Указатель на таблицу ~Документ~"/>
                <Поле Имя="ДокументЭДО" Тип="Целое" Описание="Привязка события к электронному документу. Указатель на таблицу ~ЭДО Документ~"/>
                <Поле Имя="ИмяФайла" Тип="Строка" Длина="256" Описание="Имя файла с дополнительной информацией по событию"/>
                <Поле Имя="КодФайла" Тип="Двоичные данные" Описание="Код файла с дополнительной информацией по событию"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="Папки" Поля="Папки desc, Время desc, row_id desc"/>
                <Индекс Имя="ДатаВремя" Поля="Дата, Время"/>
                <Индекс Имя="Сеанс" Поля="Сеанс, row_id, Дата, Время"/>
                <Индекс Имя="Договор" Поля="Договор, Дата, Время"/>
            </Индексы_базы>
        </Table>
        <Table Имя="ЭДО Идентификатор" Описание="Идентификаторы участников электронного документооборота">
            <Поля>
                <Поле Имя="ЭДО Идентификатор-Организация" Тип="Внешний ключ" Таблица="Организации" При_удалении="CASCADE" Описание="Организация - получатель электронного документа. Указатель на таблицу ~Организации~"/>
                <Поле Имя="Идентификатор" Тип="Строка" Длина="50" Описание="Идентификатор контрагента" />
                <Поле Имя="Оператор" Тип="Строка" Длина="50" Описание="Название оператора которому принадлежит идентификатор"/>
                <Поле Имя="Комментарий" Тип="Строка" />
                <Поле Имя="Основной" Тип="Целое" Размер="1" Длина="1" Описание="1 - основной, 0 - нет"/>
                <Поле Имя="Состояние" Тип="Строка" Описание="Текстовое описание состояния идентификатора"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="ОрганизацияИдентификатор" Поля="ЭДО Идентификатор-Организация, Идентификатор" Опции="UNIQUE"/>
            </Индексы_базы>
        </Table>
        <Table Имя="Пломбы" Описание="Пломбы, установленные на приборе учета">
            <Поля>
                <Поле Имя="Номер" Тип="Строка" Длина="20" Описание="Номер пломбы"/>
                <Поле Имя="Вид пломбы" Тип="Целое" Описание="Вид пломбы (Наклейка, Антимагнитная). Перечень в функции ПломбыБланки_Виды()"/>
                <Поле Имя="Место установки" Тип="Строка" Описание="Место установки пломбы строкой. Перечень в функции ПломбыБланки_МестаУстановки()"/>
                <Поле Имя="Состояние" Тип="Целое" Описание="Состояние пломбы. Перечень в функции ПломбыБланки_Состояния()"/>
                <Поле Имя="Дата установки" Тип="Дата" Размер="2"/>
                <Поле Имя="Дата проверки" Тип="Дата" Размер="2"/>
                <Поле Имя="Дата снятия" Тип="Дата" Размер="2"/>
                <Поле Имя="Дата состояния" Тип="Дата" Размер="2" Описание="Дата смены состояния пломбы"/>
                <Поле Имя="Дата выдачи" Тип="Дата" Размер="2"/>
                <Поле Имя="Пломба-Объект" Тип="Внешний ключ" Таблица="Список объектов" При_удалении="SET NULL" Описание="Указатель на прибор учета"/>
                <Поле Имя="Пломба-Сотрудник" Тип="Внешний ключ" Таблица="Сотрудники" При_удалении="SET NULL" Описание="Сотрудник (контролер), установивший пломбу"/>
                <Поле Имя="Пломба-Организация" Тип="Внешний ключ" Таблица="Организации" При_удалении="SET NULL"/>
                <Поле Имя="Папки" Тип="Иерархия" Опции="NoDelete "/>
                <Поле Имя="Примечание" Тип="Строка" />
                <Поле Имя="Тип" Тип="Целое" Размер="1" Длина="3" Значение_по_умолчанию="0"/>
                <Поле Имя="Пломба-Распределитель" Тип="Внешний ключ" Таблица="Распределители список" При_удалении="SET NULL"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="Счетчик" Поля="Пломба-Объект"/>
                <Индекс Имя="Организация" Поля="Пломба-Организация" Выражение="&quot;Пломба-Организация&quot; is not null"/>
                <Индекс Имя="Сотрудник" Поля="Пломба-Сотрудник" Выражение="&quot;Пломба-Сотрудник&quot; is not null"/>
                <Индекс Имя="ПломбаПапки" Поля="Папки, Папки_add"/>
                <Индекс Имя="Распределитель" Поля="Пломба-Распределитель" Выражение="&quot;Пломба-Распределитель&quot; is not null"/>
                <Индекс Имя="Тип" Поля="Тип"/>
                <Индекс Имя="Вид пломбы" Поля="Вид пломбы"/>
                <Индекс Имя="Примечание" Тип="gin" Поля="&quot;Примечание&quot; gin_trgm_ops"/>
            </Индексы_базы>
            <Триггеры>
                <Триггер Имя="Пломбы" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql" Сущность1="Пломба-Объект" />
            </Триггеры>
        </Table>
        <Table Имя="Шаблоны примечаний">
