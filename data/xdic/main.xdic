        <Table Имя="Основания владения">
            <Поля>
                <Поле Имя="Название" Тип="Строка"/>
                <Поле Имя="ЧастнаяСобственность" Тип="Флаги" Поля="Да"/>
            </Поля>
        </Table>
        <Table Имя="Документы владения" Описание="Подтверждающие документы владения лицевым счетом">
            <Поля>
                <Поле Имя="Счет-Владение" Тип="Внешний ключ" Таблица="Лицевые счета" При_удалении="CASCADE" Описание="Указатель на ЛС"/>
                <Поле Имя="Человек-Владение" Тип="Внешний ключ" Таблица="Частные лица" При_удалении="NO ACTION" Описание="Кто является владельцем"/>
                <Поле Имя="Номер" Тип="Строка" Описание="Номер документа"/>
                <Поле Имя="ДатНач" Тип="Дата" Размер="4" Описание="Действие документа с"/>
                <Поле Имя="ДатКнц" Тип="Дата" Размер="4" Описание="Действие документа по"/>
                <Поле Имя="Основание" Тип="Внешний ключ" Таблица="Основания владения" При_удалении="NO ACTION" Описание="Основание владения"/>
                <Поле Имя="Доля владения" Тип="Строка"/>
                <Поле Имя="Примечание" Тип="Строка" Описание="Дополнительная информация"/>
                <Поле Имя="РегНомер" Тип="Строка" Описание="Регистрационный номер"/>
                <Поле Имя="ДатаРег" Тип="Дата" Размер="4" Описание="Дата регистрации права"/>
                <Поле Имя="СерияБланк" Тип="Строка" Описание="Серия документа"/>
                <Поле Имя="БланкНомер" Тип="Строка" Описание="Номер документа"/>
                <Поле Имя="КемРегистр" Тип="Строка" Описание="Кто выдал документ"/>
                <Поле Имя="Доля_Числитель" Тип="Целое" Опции="CtrlC " Описание="Числитель дроби доли владения"/>
                <Поле Имя="Доля_Знаменатель" Тип="Целое" Опции="CtrlC " Описание="Знаменатель дроби доли владения"/>
                <Поле Имя="Совместная" Тип="Флаги" Поля="Общая совместная" Описание="Является ли право владения совместным"/>
                <Поле Имя="ДатаДок" Тип="Дата" Размер="4"/>
                <Поле Имя="ВладениеДок" Тип="Перечисляемое" Поля="\nСвидетельство о регистрации права\nВыписка из ЕГРП"/>
                <Поле Имя="Титульный" Тип="Флаги" Поля="Выводить в квитанцию"/>
                <Поле Имя="ДатаДокумента" Тип="Дата" Размер="4"/>
                <Поле Имя="Флаги" Тип="Флаги" Поля="Удерживать начисления ЖКУ из зарплаты"/>
                <Поле Имя="ДовЛицо" Тип="Целое" Размер="1" Длина="1" MSSQL="bit" Описание="Доверенное лицо при голосовании"/>
                <Поле Имя="Главный" Тип="Целое" Описание="При совместном праве 0 - не является главным, 1 - является главным"/>
                <Поле Имя="Совместный" Тип="Внешний ключ" Таблица="Документы владения" При_удалении="SET NULL" Описание="Ссылка на связанный докумнет на владения"/>
                <Поле Имя="ЧеловекСовмест" Тип="Внешний ключ" Таблица="Частные лица" При_удалении="SET NULL" Описание="Ссылка на частное лицо, которое является совместителем"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="Счет-Владение" Поля="Счет-Владение,ДатНач,ДатКнц,Титульный desc" ДопПоля="Человек-Владение"/>
                <Индекс Имя="Человек-Владение" Поля="Человек-Владение,Счет-Владение,ДатНач,ДатКнц"/>
                <Индекс Имя="Основание" Поля="Основание,ДатНач,ДатКнц"/>
                <Индекс Имя="Совместный" Поля="Совместный"/>
                <Индекс Имя="ЧеловекСовмест" Поля="ЧеловекСовмест"/>
            </Индексы_базы>
            <Триггеры>
                <Триггер Имя="Док_владения" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql" Сущность1="Счет-Владение" Сущность2="Человек-Владение"/>
                <Триггер Имя="Док_владения_ВП_UPDTRIG" Версия="3" Файл="Документы владения_ВП_UPDATE.sql"/>
            </Триггеры>
        </Table>
