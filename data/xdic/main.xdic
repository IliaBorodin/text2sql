        <Table Имя="ДО задания" Описание="Работы по заявкам">
            <Поля>
                <Поле Имя="Номер" Тип="Строка" Описание="Порядковый номер работы внутри заявки"/>
                <Поле Имя="Папки" Тип="Иерархия" Опции="BreakDelete " Описание="Папки или указатель на сводную ведомость работ"/>
                <Поле Имя="Подзадания" Тип="Иерархия" Опции="BreakDelete " Описание="Ссылка на работу, с которой создано подзадание"/>
                <Поле Имя="ТипИсполнителя" Тип="Целое" Размер="1" Длина="3" Описание="0-сотрудник, 1-представитель организации"/>
                <Поле Имя="Задание-Исполнитель" Тип="Внешний ключ" Таблица="Сотрудники" При_удалении="NO ACTION" Описание="Указатель на сотрудника-исполнителя"/>
                <Поле Имя="Задание-Представитель" Тип="Внешний ключ" Таблица="Частные лица" При_удалении="NO ACTION" Описание="Указатель на представителя-исполнителя"/>
                <Поле Имя="Задание-Ответственный" Тип="Внешний ключ" Таблица="Сотрудники" При_удалении="NO ACTION" Описание="Указатель на сотрудника, ответственного за исполнение."/>
                <Поле Имя="Задание-Редактор" Тип="Внешний ключ" Таблица="Сотрудники" При_удалении="NO ACTION" Описание="Указатель на сотрудника, последним редактировавшего работу"/>
                <Поле Имя="Задание-Карточка" Тип="Внешний ключ" Таблица="ДО карточки" При_удалении="CASCADE" Описание="Указатель на заявку"/>
                <Поле Имя="Задание-Фаза" Тип="Внешний ключ" Таблица="ДО фазы" При_удалении="NO ACTION" Описание="Указатель на фазу заявки"/>
                <Поле Имя="Статус завершения" Тип="Целое" Размер="1" Длина="3" Описание="Признак активности работы. 0-не завершена, активна"/>
                <Поле Имя="Свой номер" Тип="Целое" Описание="Номер работы"/>
                <Поле Имя="Предыдущий номер" Тип="Целое" Описание="Свой номер предыдущей работы"/>
                <Поле Имя="Время выдачи" Тип="Время" Размер="4" Описание="Время создания работы"/>
                <Поле Имя="Время принятия" Тип="Время" Размер="4" Описание="Время начала работы (принятия исполнителем)"/>
                <Поле Имя="Время завершения" Тип="Время" Размер="4" Описание="Время завершения"/>
                <Поле Имя="Дата выдачи" Тип="Дата" Размер="2" Описание="Дата создания работы"/>
                <Поле Имя="Дата завершения" Тип="Дата" Размер="2" Описание="Дата завершения"/>
                <Поле Имя="Дата принятия" Тип="Дата" Размер="2" Описание="Дата начала работы (принятия исполнителем)"/>
                <Поле Имя="Срок исполнения" Тип="Вещественное" Точность="9" Опции="CtrlC " Описание="Плановое количество часов исполнения работы"/>
                <Поле Имя="Отметки" Тип="Строка" Длина="8001" Описание="Комментарий по факту выполнения работы"/>
                <Поле Имя="Завершить до" Тип="Дата" Размер="2" Описание="Плановый срок завершения работы. Устаревшее."/>
                <Поле Имя="Примечание" Тип="Строка"/>
                <Поле Имя="Задание-Наряд" Тип="Внешний ключ" Таблица="Наряд заказы" При_удалении="CASCADE" Описание="Указатель на наряд-заказ"/>
                <Поле Имя="Задание-Организация" Тип="Внешний ключ" Таблица="Организации" При_удалении="SET NULL" Описание="Указатель на организацию-исполнителя"/>
                <Поле Имя="ВремяИсполнения" Тип="Строка" Описание="Суммарное время исполнения работы ЧЧЧ:ММ"/>
                <Поле Имя="Дата редактирования" Тип="Дата" Размер="2"/>
                <Поле Имя="Время редактирования" Тип="Время" Размер="4"/>
                <Поле Имя="Дата автозавершения" Тип="Дата" Размер="2"/>
                <Поле Имя="ЗавершитьДо" Тип="ДатаВремя" Описание="Плановый срок завершения работы."/>
                <Поле Имя="ВыходС" Тип="ДатаВремя" Описание="Время выхода на объект"/>
                <Поле Имя="ВыходПо" Тип="ДатаВремя" Описание="Время выхода на объект"/>
                <Поле Имя="ДопПримечание" Тип="Строка" Описание="Внутренний комментарий исполнителя"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="Подзадания_Статус" Поля="Подзадания, Статус завершения"/>
                <Индекс Имя="Карточка" Поля="Задание-Карточка, Задание-Исполнитель"/>
                <Индекс Имя="Папки" Поля="Папки, Папки_add"/>
                <Индекс Имя="Исполнитель" Поля="Задание-Исполнитель,Папки, Папки_add" ДопПоля="Статус завершения, Задание-Карточка, Дата выдачи, Время выдачи"/>
                <Индекс Имя="IX_Ведомости" Поля="Папки_add,Папки,Статус завершения,Дата завершения" Выражение="Папки_add=0"/>
            </Индексы_базы>
            <Триггеры>
                <Триггер Имя="ДО_задания" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql" Сущность1="Задание-Карточка" Сущность2="Задание-Наряд"/>
            </Триггеры>
        </Table>
