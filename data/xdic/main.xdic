                <Поле Имя="ПороговоеЗначение" Тип="Целое" Описание="Пороговое значение (верхняя граница) по диапазону"/>
                <Поле Имя="Объем" Тип="Вещественное" Точность="9" Описание="Объем потребления"/>
                <Поле Имя="Сумма" Тип="Деньги" Описание="Сумма с НДС"/>
                <Поле Имя="КолВоЛС" Тип="Целое" Описание="Количество лицевых"/>
                <Поле Имя="КодСтроки" Тип="Строка" Описание="Код строки в отчете с разделителем '.'"/>
