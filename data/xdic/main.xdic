                <Поле Имя="Код файла" Тип="Двоичные данные" Описание="Код файла"/>
                <Поле Имя="Комментарий" Тип="Строка" Длина="1000" Описание="Описание файла"/>
                <Поле Имя="Автор" Тип="Внешний ключ" Таблица="Сотрудники" При_удалении="NO ACTION" Описание="ИД сотрудника"/>
                <Поле Имя="Типы документов-Файл" Тип="Внешний ключ" Таблица="Типы документов"/>
                <Поле Имя="Файл-Связка" Тип="Внешний ключ" Таблица="Файлы" При_удалении="CASCADE"/>
                <Поле Имя="Транспорт" Тип="Внешний ключ" Таблица="ЦентрУведомленийТранспорт" При_удалении="CASCADE"/>
