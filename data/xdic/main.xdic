                <Поле Имя="ПлатежС" Тип="Дата" Размер="2" Описание="Назначение платежа юридических лиц - начальный месяц периода оплаты"/>
                <Поле Имя="ПлатежПо" Тип="Дата" Размер="2" Описание="Назначение платежа юридических лиц - конечный месяц периода оплаты"/>
                <Поле Имя="Чек-Ордер" Тип="Внешний ключ" Таблица="Сторонние платежи - список" При_удалении="NO ACTION" Описание="Используется в программе Касса"/>
                <Поле Имя="Тип операции" Тип="Внешний ключ" Таблица="Банковские документы" При_удалении="NO ACTION" Описание="не используется"/>
                <Поле Имя="Вид операции" Тип="Внешний ключ" Таблица="Банковские документы" При_удалении="NO ACTION" Описание="Виды операций для документов из программ Касса, Расчеты с поставщиками"/>
                <Поле Имя="Причина-Платежи" Тип="Внешний ключ" Таблица="Аналитики" При_удалении="NO ACTION" Описание="Указание причины формирования платежной ведомости"/>
                <Поле Имя="Документы-Потребитель" Тип="Внешний ключ" Таблица="Потребители договора" При_удалении="NO ACTION" Описание="Связь с потребителем"/>
