                <Поле Имя="Цвет" Тип="Строка" Описание="Цветовое обозначение категории БП"/>
            </Поля>
        </Table>
        <Table Имя="БудущиеРаботы" Вид="Служебная" Описание="Будущие фазы и работы. Заполняется при создании БП, записи удаляются, когда наступает нужная фаза">
            <Поля>
                <Поле Имя="идБизнесПроцесс" Тип="Внешний ключ" Таблица="Бизнес процессы" При_удалении="CASCADE" Описание="БП на котором будет работа" />
                <Поле Имя="Название" Тип="Строка" Описание="Название фазы/работы"/>
                <Поле Имя="идФаза" Тип="Внешний ключ" Таблица="ДО фазы" При_удалении="CASCADE" Описание="Ссылка на фазу"/>
                <Поле Имя="идРабота" Тип="Внешний ключ" Таблица="ОперацииФаз" При_удалении="NO ACTION" Описание="Ссылка на работу, null если это фаза"/>
                <Поле Имя="ЗонаОтветственностиТип" Тип="Строка" Описание="Тип зоны ответственности (Должность/Группа/Исполнитель-менеджер)"/>
                <Поле Имя="ЗонаОтветственностиЗначение" Тип="Целое" Описание="Зона ответственности из которой берётся сотрудник-исполнитель/ответственный"/>
                <Поле Имя="идОтветственный" Тип="Внешний ключ" Таблица="Сотрудники" При_удалении="NO ACTION" Описание="Ответственный на будущей фазе/работе, null если не указан или если массовая работа "/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="Ключ" Поля="идБизнесПроцесс, идФаза, идРабота"/>
                <Индекс Имя="идОтветственный" Поля="идОтветственный"/>
                <Индекс Имя="ЗонаОтветственности" Поля="ЗонаОтветственностиТип, ЗонаОтветственностиЗначение"/>
            </Индексы_базы>
        </Table>
        <Table Имя="ДО группы" Описание="Справочник групп">
