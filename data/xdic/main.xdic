                <Поле Имя="Объем" Тип="Вещественное" Точность="9" Опции="CtrlC " Описание="Объем акта"/>
                <Поле Имя="Сумма" Тип="Деньги" Опции="CtrlC " Описание="Сумма акта"/>
                <Поле Имя="Информация" Тип="Строка" Длина="4000" Описание="дополнительная информация"/>
