                <Поле Имя="Пост-Оплата" Тип="Внешний ключ" Таблица="Организации" При_удалении="NO ACTION"/>
                <Поле Имя="УК-Оплата" Тип="Внешний ключ" Таблица="Организации" При_удалении="NO ACTION"/>
