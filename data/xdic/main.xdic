        <Table Имя="Соглашение рассрочки" Описание="Соглашение о рассрочке">
            <Поля>
                <Поле Имя="Папки" Тип="Иерархия" Опции="BreakDelete " Описание="Иерархия для организации папок"/>
                <Поле Имя="Номер" Тип="Строка" Описание="Номер документа"/>
                <Поле Имя="Дата" Тип="Дата" Размер="4" Описание="Дата документа"/>
                <Поле Имя="РасчетныйМесяц" Тип="Дата" Размер="4" Описание="Расчетный месяц"/>
                <Поле Имя="Тема" Тип="Строка" Длина="250" Описание="расширение номера"/>
                <Поле Имя="Лицевой" Тип="Внешний ключ" Таблица="Лицевые счета" При_удалении="CASCADE" Описание="row_id таблицы [Лицевые счета]"/>
