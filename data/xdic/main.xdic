                <Поле Имя="Y" Тип="Строка" Описание="Координаты фазы по оси Y для отображения на блок-схеме" />
                <Поле Имя="Настройки" Тип="Строка" PostgreSQL="jsonb"/>
                <Поле Имя="Отчеты" Тип="Строка" PostgreSQL="jsonb"/>
                <Поле Имя="ШаблонРаботы" Тип="Целое" Размер="1" Описание="Указатель на шаблон. Перечислены в классе ШаблоныРабот" />
                <Поле Имя="ЛюбойПереход" Тип="Целое" Размер="1" Длина="1" />
                <Поле Имя="ОчередностьНаМаршруте" Тип="Целое" Описание="Какая по счёту эта фаза от стартовой точки маршрута. Для сортировки по очерёдности" />
            </Поля>
            <Индексы_базы>
                <Индекс Имя="Фаза-Категория" Поля="Фаза-Категория"/>
            </Индексы_базы>
            <Триггеры>
                <Триггер Имя="ДО_фазы" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql" />
