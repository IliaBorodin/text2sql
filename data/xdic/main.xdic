         <Триггеры>
            <Триггер Имя="ПП_права_по_статусам" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql" />
         </Триггеры>
      </Table>
        <Table Имя="Участники бизнес процесса" Описание="Перечень сотрудников, имеющих доступ в бп">
