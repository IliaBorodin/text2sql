        <Table Имя="Подсудность">
            <Поля>
                <Поле Имя="Договор" Тип="Внешний ключ" Таблица="Договор" При_удалении="SET NULL"/>
                <Поле Имя="Задача" Тип="Целое"/>
                <Поле Имя="Лицевой" Тип="Внешний ключ" Таблица="Лицевые счета" При_удалении="SET NULL"/>
                <Поле Имя="Название" Тип="Строка"/>
                <Поле Имя="Папки" Тип="Иерархия" Опции="BreakDelete "/>
