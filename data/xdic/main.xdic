                <Поле Имя="ВидРасчета" Тип="Целое" Значение_по_умолчанию="0" Описание="Вид расчета, флаги, подробности в функции ufnULTypeOfService"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="МесяцДоговор" Поля="Месяц,Договор" Опции="CLUSTERED"/>
            </Индексы_базы>
        </Table>
        <Table Имя="Ведомость расчета ВС" Вид="Служебная" Категория="Начислительные" Описание="Расшифровка расчета за месяц с максимальной детализацией по водоснабжению и водоотведению">
            <Поля>
                <Поле Имя="Договор" Тип="Целое" Описание="row_id из таблицы договор"/>
                <Поле Имя="Объект" Тип="Целое" Значение_по_умолчанию_MSSQL="-1" Значение_по_умолчанию_PostgreSQL="&apos;-1&apos;::integer" Описание="row_id из таблицы объекты договор"/>
