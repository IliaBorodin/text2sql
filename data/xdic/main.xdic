                <Поле Имя="Виды-Состояние" Тип="Внешний ключ" Таблица="Классификаторы" При_удалении="NO ACTION" Описание="ссылка на справочник состояний"/>
                <Поле Имя="Сообщение-Состояние" Тип="Внешний ключ"  Таблица="ЦентрУведомленийСообщения" При_удалении="SET NULL" Описание="Связь состояний с сообщениями"/>
                <Поле Имя="Договор-Состояние" Тип="Внешний ключ" Таблица="Договор" При_удалении="CASCADE" Описание="ссылка на договор"/>
                <Поле Имя="Документ-Состояние" Тип="Внешний ключ" Таблица="Документ" При_удалении="CASCADE" Описание="ссылка на документ"/>
                <Поле Имя="Лицевой-Состояние" Тип="Внешний ключ"  Таблица="Лицевые счета" При_удалении="CASCADE" Описание="ссылка на лицевой"/>
                <Поле Имя="Месяц" Тип="Дата" Размер="2" Описание="Месяц учета состояния"/>
                <Поле Имя="Дата" Тип="ДатаВремя" Размер="2" Описание="дата установки состояния"/>
                <Поле Имя="Комментарий" Тип="Строка" Описание="комментарий"/>
                <Поле Имя="Автор" Тип="Строка" Описание="Имя пользователя"/>
            </Поля>
        </Table>
        <Table Имя="Ставки" Описание="Хранение справочника ключевой и расчетной ставок">
