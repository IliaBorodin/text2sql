                <Поле Имя="ВидРасчета" Тип="Целое" Значение_по_умолчанию="0" Описание="Вид расчета, флаги, подробности в функции ufnULTypeOfService"/>
                <Поле Имя="Интервал" Тип="Целое" Размер="1" Описание="количество дней, за который произведен расчет"/>
