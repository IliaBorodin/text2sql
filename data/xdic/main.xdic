            <Индексы_базы>
                <Индекс Имя="РН-Список" Поля="РН-Список"/>
                <Индекс Имя="Месяц расчета" Поля="Месяц расчета"/>
                <Индекс Имя="Счет" Поля="Счет"/>
            </Индексы_базы>
        </Table>
        <Table Имя="Сальдо договора" Вид="Служебная" Категория="Начислительные" Раздел="RANGE (Месяц)" Описание="Сальдо договора в разрезе документов и видов деятельности">
            <Поля>
                <Поле Имя="Сальдо-Договор" Тип="Внешний ключ" Таблица="Договор" При_удалении="NO ACTION" Описание="Ссылка на договор"/>
                <Поле Имя="Счет-Сальдо" Тип="Внешний ключ" Таблица="Документ" При_удалении="CASCADE" Описание="Ссылка на счет-фактуру для дебета"/>
                <Поле Имя="Платеж-Сальдо" Тип="Внешний ключ" Таблица="Документ" При_удалении="CASCADE" Описание="Ссылка на платеж для кредита"/>
                <Поле Имя="Виды-Задолженности" Тип="Внешний ключ" Таблица="Виды задолженности" При_удалении="SET NULL" Описание="Ссылка на справочник видов задолженности"/>
                <Поле Имя="Сумма" Тип="Деньги" Опции="CtrlC " Описание="Сумма с ндс"/>
                <Поле Имя="Сумма2" Тип="Деньги" Опции="CtrlC " Описание="Сумма без ндс"/>
                <Поле Имя="Месяц" Тип="Дата" Размер="2" Описание="Месяц, в котором произведен расчет (сальдо считаем на конец периода, т.е. если месяц=01.01.2021, то сальдо по факту на 31.01.2021)"/>
                <Поле Имя="ДатаДокумента" Тип="Дата" Размер="2" Описание="Дата документа с остатками"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="Платеж-Сальдо" Поля="Платеж-Сальдо"/>
                <Индекс Имя="Счет-Сальдо" Поля="Счет-Сальдо"/>
                <Индекс Имя="Договор" Поля="Сальдо-Договор" ДопПоля="Месяц, Сумма"/>
                <Индекс Имя="Договор_Счет" Поля="Сальдо-Договор, Месяц, Платеж-Сальдо" ДопПоля="Сумма" Выражение="&quot;Платеж-Сальдо&quot; is not null"/>
                <Индекс Имя="Договор_Платеж" Поля="Сальдо-Договор, Месяц, Счет-Сальдо" ДопПоля="Сумма" Выражение="&quot;Счет-Сальдо&quot; is not null"/>
                <Индекс Имя="Месяц" Поля="Месяц, Сальдо-Договор"/>
            </Индексы_базы>
            <Триггеры/>
        </Table>
        <Table Имя="Свойства" Описание="Параметры и их характеристики, установленных на соответствующие объекты (лицевы счета, дома и т.п.)">
            <Поля>
                <Поле Имя="Виды-Параметры" Тип="Внешний ключ" Таблица="Виды параметров" При_удалении="NO ACTION" Описание="Связь со справочником видов параметров"/>
                <Поле Имя="ДатКнц" Тип="Дата" Размер="2" Описание="Дата окончания действия параметра"/>
                <Поле Имя="ДатНач" Тип="Дата" Размер="2" Описание="Дата начала действия параметра"/>
                <Поле Имя="Документ-Параметры" Тип="Внешний ключ" Таблица="Документ" При_удалении="CASCADE" Описание="Связь с документом, на котором установлен параметр"/>
                <Поле Имя="Знач2" Тип="Вещественное" Точность="15" Опции="CtrlC " Описание="Дополнительное значение (доступно в правиле расчета по конструкции Имя.2). Используется, если параметр имеет несколько составляющих значения (к таким параметрам относится, например, ЛИЦЕВЫЕ – диапазоны допустимых номеров лицевых счетов – у этого параметра в поле [Значение] хранится нижняя граница, в поле Знач2 – верхняя)."/>
                <Поле Имя="Знач3" Тип="Вещественное" Точность="15" Опции="CtrlC " Описание="Дополнительное значение (доступно в правиле расчета по конструкции Имя.3)"/>
                <Поле Имя="Значение" Тип="Вещественное" Точность="15" Опции="CtrlC " Описание="Значение параметра (доступно в правиле расчета по имени параметра или конструкции Имя.1). Используется для хранения числовых или перечисляемых значений параметров."/>
                <Поле Имя="Объекты-Параметры" Тип="Внешний ключ" Таблица="Список объектов" При_удалении="CASCADE" Описание="Связь с объектом, на котором установлен параметр"/>
                <Поле Имя="Организация-Параметры" Тип="Внешний ключ" Таблица="Организации" При_удалении="SET NULL" Описание="Связь с организацией, на которой установлен параметр"/>
                <Поле Имя="Параметры-Договор" Тип="Внешний ключ" Таблица="Договор" При_удалении="CASCADE" Описание="Связь с договором ЮЛ, на котором установлен параметр"/>
                <Поле Имя="Параметры-УКДоговор" Тип="Внешний ключ" Таблица="УК Договоры" При_удалении="CASCADE" Описание="Связь с договором УК, на котором установлен параметр"/>
                <Поле Имя="Примечание" Тип="Строка" Описание="Используется для хранения текстового значения параметра или как пользовательское примечание"/>
                <Поле Имя="Счет-Параметры" Тип="Внешний ключ" Таблица="Лицевые счета" При_удалении="CASCADE" Описание="Связь с лицевым счетом, на котором установлен параметр"/>
                <Поле Имя="Объект-Параметры" Тип="Внешний ключ" Таблица="Объекты договора" При_удалении="CASCADE" Описание="Связь с объектом договора ЮЛ, на которой установлен параметр"/>
                <Поле Имя="СетьЭлемент-Параметры" Тип="Внешний ключ" Таблица="Сеть элементы" При_удалении="CASCADE" Описание="Связь с объектом сети, на котором установлен параметр"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="Счет" Поля="Счет-Параметры, ДатНач, ДатКнц, Виды-Параметры" Выражение="&quot;Счет-Параметры&quot; is not null"/>
                <Индекс Имя="Вид" Поля="Виды-Параметры, Счет-Параметры, ДатНач, ДатКнц" ДопПоля="Значение, Знач2, Знач3, Примечание" Выражение="&quot;Счет-Параметры&quot; is not null and Значение is not null"/>
                <Индекс Имя="Объект" Поля="Объекты-Параметры, ДатНач, ДатКнц" Выражение="&quot;Объекты-Параметры&quot; is not null"/>
                <Индекс Имя="УКДоговор" Поля="Параметры-УКДоговор, Виды-Параметры" Выражение="&quot;Параметры-УКДоговор&quot; is not null"/>
                <Индекс Имя="Документ-Параметры" Поля="Документ-Параметры" Выражение="&quot;Документ-Параметры&quot; is not null"/>
                <Индекс Имя="Договор" Поля="Параметры-Договор, Виды-Параметры, ДатНач, ДатКнц"  Выражение="&quot;Параметры-Договор&quot; is not null"/>
                <Индекс Имя="Объект-Параметры" Поля="Объект-Параметры, ДатНач, ДатКнц, Виды-Параметры" Выражение="&quot;Объект-Параметры&quot; is not null"/>
                <Индекс Имя="СетьЭлемент-Параметры" Поля="СетьЭлемент-Параметры, ДатНач, ДатКнц" Выражение="&quot;СетьЭлемент-Параметры&quot; is not null"/>
                <Индекс Имя="Организация-Параметры" Поля="Организация-Параметры" Выражение="&quot;Организация-Параметры&quot; is not null"/>
            </Индексы_базы>
            <Триггеры>
                <Триггер Имя="Свойства" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql" Сущности1="Счет-Параметры,Объекты-Параметры,Организация-Параметры,Объект-Параметры,Документ-Параметры" Сущности2="Параметры-Договор,Параметры-УКДоговор,СетьЭлемент-Параметры"/>
                <Триггер Имя="Свойства_BF_DELTRIG" Версия="2" Файл="Свойства_BF_DELTRIG.sql"/>
                <Триггер Имя="Свойства_BF_INSTRIG" Версия="2" Файл="Свойства_BF_INSTRIG.sql"/>
                <Триггер Имя="Свойства_BF_UPDTRIG" Версия="2" Файл="Свойства_BF_UPDTRIG.sql"/>
                <Триггер Имя="Свойства_LSVP_DELTRIG" Версия="1" Файл="Свойства_LSVP_DELTRIG.sql"/>
                <Триггер Имя="Свойства_LSVP_INSTRIG" Версия="1" Файл="Свойства_LSVP_INSTRIG.sql"/>
                <Триггер Имя="Свойства_LSVP_UPDTRIG" Версия="1" Файл="Свойства_LSVP_UPDTRIG.sql"/>
            </Триггеры>
        </Table>
        <Table Имя="Связи документов" Описание="Таблица связей, отображающая все операции с документами (погашение счетов, сторнировки, возвраты, формирование счетов-фактур на авансы и т.д.)">
            <Поля>
                <Поле Имя="N п/п" Тип="Целое" Описание="Не используется"/>
                <Поле Имя="Вид связи" Тип="Перечисляемое" Поля="\nРегистрация\nВнешние документы\nСписок рассылки\nСвязи проектов\nМестонахождение ОС\nПлан сборки\nЖурнал лиц"/>
                <Поле Имя="ДатКнц" Тип="Дата" Размер="2" Описание="Не используется"/>
                <Поле Имя="ДатНач" Тип="Дата" Размер="2" Описание="Не используется"/>
                <Поле Имя="Дата" Тип="Дата" Размер="2" Описание="Дата операции"/>
                <Поле Имя="Комментарий" Тип="Строка" Описание="Не используется"/>
                <Поле Имя="Номер" Тип="Целое" Описание="Не используется"/>
                <Поле Имя="Связи" Тип="Иерархия" Опции="BreakDelete " Описание="Не используется"/>
                <Поле Имя="Связка1" Тип="Внешний ключ" Таблица="Документ" При_удалении="CASCADE" Описание="Документ основания (для сальдо это счет-фактура)"/>
                <Поле Имя="Связка2" Тип="Внешний ключ" Таблица="Документ" При_удалении="CASCADE" Описание="Документ следствие (исключение - для сальдо это платеж)"/>
                <Поле Имя="Сумма" Тип="Деньги" Опции="CtrlC " Описание="Сумма операции (например погашения счета-фактуры платежом)"/>
                <Поле Имя="Флаги" Тип="Флаги" Поля="Оплата\nОтгрузка\nРегистрация\nПереуступка долга\nВключать в сделку\nПоставка\nСторно" Описание="0 - указатель на документ основания, 64 - сторно, 128 - коррекция (перерасчет), 256 - расчет сальдо 1024 - исправление документа"/>
                <Поле Имя="Сторонние платежи" Тип="Внешний ключ" Таблица="Сторонние платежи - ведомости" При_удалении="CASCADE"/>
                <Поле Имя="Связи-Договор" Тип="Внешний ключ" Таблица="Договор" При_удалении="CASCADE" Описание="Ссылка на договор при расчете сальдо"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="Связка2" Поля="Связка2, Флаги"/>
                <Индекс Имя="Связка1" Поля="Связка1, Флаги"/>
                <Индекс Имя="Договор" Поля="Связи-Договор, Флаги, Дата"/>
                <Индекс Имя="Флаги" Поля="Флаги" Выражение='&quot;Флаги&quot; = ANY ( ARRAY~[1,64,128]~ )'/>
            </Индексы_базы>
            <Триггеры>
                <Триггер Имя="Связи документовУ_TRIG" Версия="2" Файл="связи_документов_deltrig.sql"/>
                <Триггер Имя="Связи_документов_BF_DELTRIG" Версия="2" Файл="Связи документов_BF_DELTRIG.sql"/>
                <Триггер Имя="Связи_документов_BF_INSTRIG" Версия="2" Файл="Связи документов_BF_INSTRIG.sql"/>
                <Триггер Имя="Связи_документов_BF_UPDTRIG" Версия="2" Файл="Связи документов_BF_UPDTRIG.sql"/>
            </Триггеры>
        </Table>
        <Table Имя="Связи классификаторов">
            <Поля>
                <Поле Имя="Дата" Тип="Дата" Размер="2"/>
