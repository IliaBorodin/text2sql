                <Поле Имя="Акт-Платежи" Тип="Внешний ключ" Таблица="Акты нарушений" При_удалении="NO ACTION"/>
                <Поле Имя="Карточка-Платежи" Тип="Внешний ключ" Таблица="ДО карточки" При_удалении="CASCADE"/>
                <Поле Имя="ФЛДоговор-Платежи" Тип="Внешний ключ" Таблица="ФЛДоговор" При_удалении="CASCADE"/>
                <Поле Имя="ФЛДокумент-Платежи" Тип="Внешний ключ" Таблица="ФЛДокумент" При_удалении="CASCADE"/>
                <Поле Имя="Аналитика-Платежи" Тип="Внешний ключ" Таблица="Аналитики" При_удалении="NO ACTION"/>
                <Поле Имя="Подразделение-Платежи" Тип="Внешний ключ" Таблица="Организации" При_удалении="NO ACTION"/>
                <Поле Имя="Флаги" Тип="Флаги"/>
                <Поле Имя="Дата" Тип="Дата" Размер="2"/>
                <Поле Имя="Месяц" Тип="Дата" Размер="2"/>
