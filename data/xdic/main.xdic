                <Поле Имя="N п/п" Тип="Целое" Опции="CtrlC " Описание="ном по порядку в реестре акта"/>
                <Поле Имя="ДопЧасы" Тип="Вещественное" Точность="9" Опции="CtrlC "/>
                <Поле Имя="ЧасНач" Тип="Время" Размер="4"/>
                <Поле Имя="ЧасКнц" Тип="Время" Размер="4"/>
                <Поле Имя="ДнЧасы" Тип="Вещественное" Точность="9" Опции="CtrlC "/>
                <Поле Имя="НочнЧасы" Тип="Вещественное" Точность="9" Опции="CtrlC "/>
                <Поле Имя="Дни" Тип="Вещественное" Точность="9" Опции="CtrlC "/>
                <Поле Имя="Тип" Тип="Целое" Опции="CtrlC "/>
