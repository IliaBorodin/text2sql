                <Поле Имя="Тип" Тип="Целое" Описание="0 - отчеты, 1 - производства фазы, 2 - список массовых операций, 3 - список единичных операций для возможности искл." />
                <Поле Имя="Флаги" Тип="Флаги" Поля="\nЗарезервирован\nНе копировать" Описание="0 - Свободное редактирование, 1 - Запрет на редактирование и удаление, 2 - Запрет на копирование"/>
                <Поле Имя="Формат" Тип="Перечисляемое" Поля="pdf\nhtml\nxlsx\ndocx\ntxt" Описание="Формат формы"/>
                <Поле Имя="Шаблон" Тип="Внешний ключ" Таблица="Файлы" При_удалении="SET NULL"/>
                <Поле Имя="ДанныеОтчетныхФорм" Тип="Строка" PostgreSQL="jsonb" Описание="Хранит дополнительную информацию по фазам ( 'phaz', '{ [фаза]:[список подфаз]}'::jsonb, 'icons', 'имя картинки' )"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="Расширение" Поля="Расширение,Тип" />
            </Индексы_базы>
            <Триггеры>
