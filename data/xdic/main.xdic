                <Поле Имя="Правила-Документы" Тип="Строка" Описание="Класс выполнения расчета документа (например, распределение ОДПУ)"/>
                <Поле Имя="Приложение" Тип="Строка" Описание="Служебное поле. Используется в программе Касса"/>
