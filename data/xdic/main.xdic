                <Поле Имя="ВыгрузкаСтрока" Тип="Строка" Длина="8001" Описание="Строка выгрузки (содержит сформированную строку для файла выгрузки)"/>
                <Поле Имя="Чек-Документ" Тип="Внешний ключ" Таблица="Документ" При_удалении="CASCADE" Описание="row_id [Документ], связь с платежом ЮЛ"/>
                <Поле Имя="СуммаПР" Тип="Деньги" Опции="CtrlC " Описание="Сумма полного расчета (фискализация)"/>
                <Поле Имя="СуммаОК" Тип="Деньги" Опции="CtrlC " Описание="Сумма оплаты кредита (фискализация)"/>
                <Поле Имя="СуммаАв" Тип="Деньги" Опции="CtrlC " Описание="Сумма аванса (фискализация)"/>
                <Поле Имя="Месяц" Тип="Дата" Описание="Месяц для сохранения чеков передачи в кредит и схлопнутых чеков зачета авансов"/>
                <Поле Имя="ТипЧека" Тип="Целое" Размер="1" Значение_по_умолчанию="0" Описание="Тип чека (0 - чек на оплату, 1 - чек передачи в кредит, 2 - чек зачета аванса, 3 - общий чек зачета аванса и передачи в кредит, 4 - чек коррекции возврат, 5 - чек коррекции приход )"/>
                <Поле Имя="ОплатыБезнал" Тип="Строка"/>
                <Поле Имя="РасчетИнтернет" Тип="Целое"/>
                <Поле Имя="МестоРасчета" Тип="Строка"/>
                <Поле Имя="Чек-Коррекция" Тип="Внешний ключ" Таблица="Документ" При_удалении="CASCADE" Описание="Связь с документом коррекции"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="ГУИД" Поля="ГУИД"/>
                <Индекс Имя="Чек-Платеж" Поля="Чек-Платеж"/>
                <Индекс Имя="СчетМесяц" Поля="Чек-Счет, Месяц"/>
                <Индекс Имя="Чек-СтороннийПлатеж" Поля="Чек-СтороннийПлатеж" Выражение="&quot;Чек-СтороннийПлатеж&quot; is not null"/>
                <Индекс Имя="Чек-Документ" Поля="Чек-Документ"/>
                <Индекс Имя="Месяц" Поля="Месяц"/>
            </Индексы_базы>
            <Триггеры>
                <Триггер Имя="Чеки_BF_DELTRIG" Версия="2" Файл="Чеки_BF_DELTRIG.sql"/>
                <Триггер Имя="Чеки" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql" Сущность1="Чек-Счет" Сущность2="Чек-Платеж" ВТекстПоля="ВидОплаты,Детализация,Налоги,ФискальныеДанные"/>
            </Триггеры>
        </Table>
        <Table Имя="Ведомость расчета" Вид="Служебная" Категория="Начислительные" Описание="Расшифровка расчета за месяц с максимальной детализацией. Используется в основном для электроэнергии">
            <Поля>
                <Поле Имя="Договор" Тип="Целое" Описание="row_id из таблицы договор"/>
                <Поле Имя="Объект" Тип="Целое" Значение_по_умолчанию_MSSQL="-1" Значение_по_умолчанию_PostgreSQL="&apos;-1&apos;::integer" Описание="row_id из таблицы объекты договор"/>
                <Поле Имя="Лицевой" Тип="Целое" Описание="row_id из таблицы лицевые счета"/>
                <Поле Имя="Месяц" Тип="Дата" Описание="месяц, в котором произведен расчет"/>
                <Поле Имя="ЗаМесяц" Тип="Дата" Описание="месяц, за который произведен расчет"/>
                <Поле Имя="ЗаводскойНомер" Тип="Строка" Описание="заводской номер прибора учета"/>
                <Поле Имя="Интервал" Тип="Целое" Размер="1" Описание="количество дней, за который произведен расчет"/>
                <Поле Имя="Максмощ" Тип="Вещественное" Описание="значение параметра максимальная мощность (электроэнергия)"/>
                <Поле Имя="ЧИспМощ" Тип="Вещественное" Описание="значение параметра число часов использования мощности (электроэнергия)"/>
                <Поле Имя="ВидНачислений" Тип="Строка" Описание="код вида расчета: по счетчику, замещающий, по норме и т.д. "/>
                <Поле Имя="Суб" Тип="Строка" Описание="признак субабонента: С - вычитаемый счетчик из другого договора, П - вычитаемый из текущего договора, В% - в процентах подчиненный"/>
                <Поле Имя="Процент" Тип="Вещественное" Описание="процент вычитания для субабонента"/>
                <Поле Имя="ПокНач" Тип="Вещественное" Описание="предыдущее показание"/>
                <Поле Имя="ПокКнц" Тип="Вещественное" Описание="текущиее показание"/>
                <Поле Имя="Расход" Тип="Вещественное" Описание="разница показания"/>
