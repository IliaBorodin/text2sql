                <Поле Имя="ПланПериодНач" Тип="Строка" Описание="Начало планового периода в формате ДД.ММ"/>
                <Поле Имя="ПланПериодКнц" Тип="Строка" Описание="Окончание планового периода в формате ДД.ММ"/>
