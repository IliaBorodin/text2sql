                <Поле Имя="ДлитГВ" Тип="Вещественное" Описание="длительность действия системы водоснабжения"/>
                <Поле Имя="ОтПериод" Тип="Целое" Описание="признак отопительного периода"/>
                <Поле Имя="Сеть" Тип="Целое" Опции="CtrlC " Описание="ссылка на структуру сети тыблица [сеть элементы]"/>
                <Поле Имя="ОтрОбъем_вх" Тип="Вещественное" Описание="объем отрицательной дельты входящий - принят к расчету"/>
                <Поле Имя="ОтрОбъем_исх" Тип="Вещественное" Описание="объем отрицательной дельты исходящий"/>
