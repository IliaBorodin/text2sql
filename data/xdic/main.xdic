                <Поле Имя="Параметр-Значения" Тип="Внешний ключ" Таблица="Параметры" При_удалении="CASCADE" Описание="row_id [Параметры], идентификатор параметра"/>
                <Поле Имя="Тип владельца" Тип="Строка" Описание="Архив, данное поле не используется"/>
