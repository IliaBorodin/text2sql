                <Поле Имя="Сумма" Тип="Деньги" Опции="CtrlC "/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="Карточка-Платежи" Поля="Карточка-Платежи" Выражение="&quot;Карточка-Платежи&quot; is not null"/>
                <Индекс Имя="Связь-Документ" Поля="Связь-Документ" Выражение="&quot;Связь-Документ&quot; is not null"/>
                <Индекс Имя="Связь-Лицевой" Поля="Связь-Лицевой" Выражение="&quot;Связь-Лицевой&quot; is not null"/>
                <Индекс Имя="Связь-Платежи" Поля="Связь-Платежи" Выражение="&quot;Связь-Платежи&quot; is not null"/>
