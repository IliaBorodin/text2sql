        <Table Имя="Типы услуг" Описание="Справочник жилищно-коммунальных услуг для биллинга">
            <Поля>
                <Поле Имя="Внешний код 1" Тип="Строка" Описание="Код для интеграции со сторонними системами"/>
                <Поле Имя="Внешний код 2" Тип="Строка" Описание="Код для интеграции со сторонними системами"/>
                <Поле Имя="Группа" Тип="Целое" Размер="2" Длина="5" Описание="Число, определяющее оптимизацию льгот. Когда один человек имеет несколько льгот, считается их сумма в пределах всех услуг каждой группы (услуг, имеющих одинаковое число в данном поле), определяется максимум, выбирается только одна льгота, дающая этот максимум (или все льготы «на одного»)"/>
                <Поле Имя="Единица измерения" Тип="Строка" Описание="Физическая единица измерения объема услуги"/>
                <Поле Имя="Название" Тип="Строка" Описание="Краткое название услуги"/>
                <Поле Имя="Наименование" Тип="Строка" Описание="Полное наименование услуги"/>
                <Поле Имя="Налог1" Тип="Вещественное" Точность="2" Описание="Процент НДС"/>
                <Поле Имя="Налог2" Тип="Вещественное" Точность="2" Описание="не используется"/>
                <Поле Имя="НеБлокировать" Тип="Целое" Описание="не используется"/>
                <Поле Имя="Номер услуги" Тип="Целое" Описание="Цифровой код услуги, используется внутри системы"/>
                <Поле Имя="Параметры услуги" Тип="Флаги" Поля="Указание поставщика не обязательно\nВыводится при отсутствии детализации\nИсключается из счета-фактуры\nХранит долги или переплату\nПоказания счетчика\nНачисление по счетчику\nДоначисление по счетчику\nУслуга сверх норм\nСоставляющая объема группы\nНачисление по норме\nДоначисление по норме\nНачисляется по оплате\nСоставляющая тарифа группы" Описание="1 - Указание поставщика не обязательно, если установлен, изменения на лицевой счет по данной услуге можно вносить, даже если данной услуги на лицевом нет, 2 - не используется, 3 - суммы по данной услуге не передаются при формировании счета-фактуры, 4 - обязательно нужна при использовании деления поступающих сумм по платежным группам. В каждой из платежных групп должна быть одна (и только одна!) такая услуга. Сумма переплаты по данной платежной группе помещается на такую услугу, 5 - данная услуга хранит показания счетчика, 6 - на данную услугу помещается сумма начислений при наличии показаний счетчика, 7 - на данную услугу помещается сумма начислений при отсутствии показаний счетчика, 8 - на данную услугу помещаются суммы начислений за потребление услуги сверх социальной нормы, 9 - объем этой услуги следует учитывать при вычислении объема потребления по группе в целом (применяется в случаях, когда вычисляется калькуляция услуги и один и тот же объем присутствует на нескольких услугах, а для получения объема группы услуг нужно взять только одну)"/>
                <Поле Имя="Тип отображения" Тип="Флаги" Поля="Не может быть установлена на лицевой" Описание="Признак, что услуга не может быть установлена на лицевой (в соответствии с логикой системы начисления, не все услуги подлежат установке на лицевые счета)"/>
                <Поле Имя="Платежная группа" Тип="Целое" Размер="1" Длина="3" Описание="Число, определяющее алгоритм деления поступившей оплаты. Применяется только при методике приема и распределения оплаты в соответствии с платежными группами"/>
                <Поле Имя="Поле с лицевым счетом" Тип="Строка" Описание="не используется"/>
                <Поле Имя="Поставщик по умолчанию" Тип="Внешний ключ" Таблица="Организации" При_удалении="NO ACTION" Описание="Если для услуги не установлен поставщик на адресном объекте (дом, квартира), то в качестве поставщика в начисления запишется значение из этого поля"/>
                <Поле Имя="Признаки" Тип="Флаги" Поля="Облагается налогом 1\nОблагается налогом 2\nВходит в фактическое начисление для субсидии\nОплачивается отдельно\nСторонняя услуга\nНа данную услугу делится субсидия\nНДС сверху тарифа" Описание="1 - Облагается налогом 1 – есть НДС, 2 - Облагается налогом 2 – не используется, 3 - Входит в фактическое начисление для субсидий – если установлен, при расчете субсидий включаются суммы по данным услугам, 4 - Оплачивается отдельно – если установлен, поступающая общей суммой оплата не делится по данным услугам, оплата данных услуг должна задаваться явно, 5 - Сторонняя услуга – не используется, 6 - На данную услугу делится субсидия – если установлен, сумма субсидии будет делиться на данную услугу, 7 - НДС сверху тарифа – для начислений для юр.лиц – если расчет на лицевых счетах идет по тарифу без НДС, флаг должен быть установлен"/>
                <Поле Имя="Приоритет при печати" Тип="Целое" Размер="1" Длина="3" Описание="не используется"/>
                <Поле Имя="Склад-Услуги" Тип="Внешний ключ" Таблица="Номенклатура" При_удалении="NO ACTION" Описание="Используется для группировки биллинговых услуг в услуги, отражаемые в документах юридических лиц"/>
                <Поле Имя="Субсчет" Тип="Строка" Описание="не используется"/>
                <Поле Имя="Счет1" Тип="Строка" Описание="поле для интеграции со сторонними системами"/>
                <Поле Имя="Счет2" Тип="Строка" Описание="поле для интеграции со сторонними системами"/>
                <Поле Имя="Типы услуг" Тип="Иерархия" Опции="BreakDelete " Описание="Для организации пользовательских группировок услуг"/>
                <Поле Имя="Управление" Тип="Целое" Опции="CtrlC " Описание="Поле хранит в себе информацию о том, в каких функциональных модулях комплекса данную запись нужно отображать в справочнике"/>
                <Поле Имя="Характеристика услуги" Тип="Флаги" Поля="Оплачивается отдельно" Описание="Используется для начисления по оплате"/>
                <Поле Имя="Группа счетчика" Тип="Целое"/>
                <Поле Имя="ФЛДоговор-Услуги" Тип="Внешний ключ" Таблица="ФЛДоговор" При_удалении="NO ACTION" Описание="Ссылка на абонентский договор, который будет использоваться по умолчанию"/>
                <Поле Имя="Вариант НДС" Тип="Перечисляемое" Поля="\nВ тарифе\nНе облагается" Описание="Вариант НДС для ФЛ ('',В тарифе,Не облагается)"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="Номер услуги" Поля="Номер услуги" ДопПоля="row_id, Единица измерения"/>
            </Индексы_базы>
            <Триггеры>
                <Триггер Имя="Типы услуг_SPR_TRIG" Версия="1" Файл="Типы услуг_SPR_TRIG.sql"/>
                <Триггер Имя="Типы_услуг" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql" />
            </Триггеры>
            <Политики>
                <Политика Имя="AP_Usl" Файл="Типы услуг_Select_AP_Usl.sql"/>
            </Политики>
        </Table>
        <Table Имя="Типы услуг ПДУ">
            <Поля>
                <Поле Имя="Услуга-Подомовой" Тип="Внешний ключ" Таблица="Типы услуг" При_удалении="NO ACTION"/>
            </Поля>
            <Индексы_базы/>
            <Триггеры/>
        </Table>
        <Table Имя="Транзакции Платежей">
