                <Индекс Имя="Задача" Поля="Задача,Тип"/>
                <Индекс Имя="Лицевой" Поля="Лицевой,Флаги" ДопПоля="Суд" Выражение="&quot;Лицевой&quot; is not null"/>
                <Индекс Имя="Папки" Поля="Папки, Папки_add" ДопПоля="Лицевой,Договор"/>
                <Индекс Имя="Суд" Поля="Суд" ДопПоля="Лицевой,Договор" Выражение="&quot;Суд&quot; is not null"/>
                <Индекс Имя="Флаги" Поля="Флаги"/>
            </Индексы_базы>
            <Триггеры/>
        </Table>
        <Table Имя="Показания для контроля" Категория="Показания" Описание="Промежуточная таблица служит для приема показаний из сторонних систем (как есть без изменений) с дальнейшим анализом и передачей в табл. [Показания счетчиков] используемой в расчете ">
            <Поля>
                <Поле Имя="N п/п" Тип="Целое"/>
                <Поле Имя="Акт" Тип="Целое" Размер="1" Длина="3"/>
                <Поле Имя="Дата" Тип="Дата" Размер="2"/>
                <Поле Имя="Дополнительный расход" Тип="Вещественное" Точность="9" Опции="CtrlC "/>
                <Поле Имя="Итоговый расход" Тип="Вещественное" Точность="9" Опции="CtrlC "/>
                <Поле Имя="Контроль-Документ" Тип="Внешний ключ" Таблица="Документ" При_удалении="CASCADE"/>
                <Поле Имя="Контроль-Счет" Тип="Внешний ключ" Таблица="Лицевые счета" При_удалении="CASCADE" Описание="row_id [Лицевые счета] проставляется в процессе переноса"/>
                <Поле Имя="Контроль-Услуга" Тип="Внешний ключ" Таблица="Типы услуг" При_удалении="CASCADE" Описание="row_id [Типы услуг] проставляется в процессе переноса"/>
                <Поле Имя="Объект-Контроль" Тип="Внешний ключ" Таблица="Список объектов" При_удалении="CASCADE" Описание="row_id [Список объектов] проставляется в процессе переноса"/>
                <Поле Имя="ДокументГрупповой-Контроль" Тип="Внешний ключ" Таблица="Документ" При_удалении="CASCADE"/>
                <Поле Имя="Показание" Тип="Вещественное" Точность="9" Опции="CtrlC " Описание="Принятое показание"/>
                <Поле Имя="Расход" Тип="Вещественное" Точность="9" Опции="CtrlC " Описание="Расход для контроля"/>
                <Поле Имя="Расчетный месяц" Тип="Дата" Размер="2" Описание="Расчетный месяц в котором показание должно быть учтено"/>
                <Поле Имя="Сумма" Тип="Вещественное" Точность="9" Опции="CtrlC "/>
                <Поле Имя="СчМесяцев" Тип="Целое" Размер="1" Опции="CtrlC "/>
                <Поле Имя="Тариф" Тип="Целое" Размер="1" Опции="CtrlC " Описание="Вид используемого тарифа для многотарифных счетчиков"/>
                <Поле Имя="Тип" Тип="Целое" Размер="1"/>
                <Поле Имя="ТипВвода" Тип="Целое" Размер="2" Опции="CtrlC "/>
                <Поле Имя="Контроль-Показание" Тип="Внешний ключ" Таблица="Показания счетчиков" При_удалении="SET NULL" Описание="row_id [Показания счетчиков] проставляется в процессе переноса"/>
                <Поле Имя="ФлагОшибок" Тип="Целое" Размер="4" Описание="флаги взводятся при проблемах в процессе переноса"/>
                <Поле Имя="НомерЛС файл" Тип="Текст" Размер="255" Описание="Номер ЛС из внешнего источника"/>
                <Поле Имя="СтороннийЛС файл" Тип="Текст" Размер="255" Описание="Номер ЛС в сторонней системе"/>
                <Поле Имя="АдресЛС файл" Тип="Текст" Размер="255" Описание="Адрес из внешнего источника - справочно для сверки проблемных"/>
                <Поле Имя="ФИО файл" Тип="Текст" Размер="255" Описание="ФИО из внешнего источника - справочно для сверки проблемных"/>
                <Поле Имя="Услуга файл" Тип="Текст" Размер="255" Описание="Услуга - справочно для сверки проблемных"/>
                <Поле Имя="ЗаводскойНомер файл" Тип="Текст" Размер="255" Описание="Заводской номер из внешнего источника"/>
                <Поле Имя="ТипСчетчика файл" Тип="Текст" Размер="255" Описание="Тип счетчика для сверки проблемных"/>
                <Поле Имя="Тарифность файл" Тип="Целое" Размер="1" Опции="CtrlC " Описание="Тарифность для сверки"/>
                <Поле Имя="ТипПоказаний" Тип="Перечисляемое" Поля="Ипу\Окпу\nОДПУ" Значение_по_умолчанию="0"/>
                <Поле Имя="ФотографияПоказания" Тип="Строка" Длина="256" />
                <Поле Имя="ФотографияАкт" Тип="Строка" Длина="256" />
                <Поле Имя="УникГуид" Тип="Гуид" Описание="guid уникальный из Стек-коннекта который приходит"/>
                <Поле Имя="УникГуидОперации" Тип="Гуид" Описание="Уникальный guid операции для Стек-Коннекта"/>
                <Поле Имя="Показания-Источник" Тип="Внешний ключ" Таблица="Источники показаний" При_удалении="NO ACTION" Описание="Источник показаний"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="Счет" Поля="Контроль-Счет, Тариф, Дата" ДопПоля="Показание, Объект-Контроль"/>
