                <Индекс Имя="_ИД" Поля="_ИД"/>
                <Индекс Имя="Название" Тип="gin" Поля="&quot;Название&quot; gin_trgm_ops"/>
            </Индексы_базы>
            <Триггеры>
                <Триггер Имя="Организации" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql"/>
                <Триггер Имя="Организации_LS_UPDTRIG" Версия="1" Файл="Организации_LS_UPDTRIG.sql"/>
            </Триггеры>
