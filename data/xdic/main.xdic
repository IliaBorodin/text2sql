                <Индекс Имя="СО-Параметры" Поля="СО-Параметры" Выражение="&quot;СО-Параметры&quot; is not null"/>
                <Индекс Имя="Карточка-Параметры" Поля="Карточка-Параметры" Выражение="&quot;Карточка-Параметры&quot; is not null"/>
