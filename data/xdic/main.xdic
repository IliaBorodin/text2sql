                <Поле Имя="ГруппаУслуг" Тип="Внешний ключ" Таблица="Типы услуг" При_удалении="NO ACTION" Описание="row_id из справочника [Типы услуг]"/>
                <Поле Имя="Услуга-ПениПериоды" Тип="Внешний ключ" Таблица="Типы услуг" При_удалении="NO ACTION" Описание="row_id из справочника [Типы услуг]"/>
                <Поле Имя="Поставщик" Тип="Внешний ключ" Таблица="Организации" При_удалении="NO ACTION" Описание="row_id поставщика услуги из таблицы [Организации]"/>
                <Поле Имя="ДоговорУК" Тип="Внешний ключ" Таблица="УК Договоры" При_удалении="NO ACTION" Описание="row_id договора (с УК или прямого) из таблицы [УК Договоры]"/>
