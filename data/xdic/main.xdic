                <Индекс Имя="Документ" Поля="Платеж-Список" ДопПоля="Счет-Оплата"/>
                <Индекс Имя="Дата_РасчМесяц" Поля="Дата, РасчМесяц" ДопПоля="Счет-Оплата, Платеж-Список, Сумма"/>
                <Индекс Имя="РасчМесяц" Поля="РасчМесяц, Счет-Оплата" ДопПоля="Платеж-Список, Сумма"/>
