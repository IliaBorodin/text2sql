                <Поле Имя="UL_ANALIT" Тип="Целое" Опции="CtrlC "/>
                <Поле Имя="UL_COMMENT" Тип="Строка" Описание="Описание вида обмена"/>
                <Поле Имя="FL_ROW_ID" Тип="Целое" Опции="CtrlC " Описание="Идентификатор сущности в базе данных физических лиц"/>
                <Поле Имя="FL_ANALIT" Тип="Целое" Опции="CtrlC "/>
