                <Поле Имя="ПозицияВыход" Тип="Строка" Описание="Позиция стрелки на фазе выхода для отображения на блок-схеме"/>
                <Поле Имя="УсловиеПерехода" Тип="Целое" Описание="Условие по которому происходит переход необходимо для шлюза. 0-false, 1-true"/>
                <Поле Имя="ТипПерехода" Тип="Целое" Значение_по_умолчанию_PostgreSQL="0" Описание="Тип перехода на блок-схеме для шлюза. 0-переход, 1-переход с шлюза"/>
