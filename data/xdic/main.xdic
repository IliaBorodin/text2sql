        <Table Имя="Временное движение" Описание="Временная регистрация или временное убытие зарегистрированных жильцов на лицевом счёте. Может влиять на расчёт, если расчёт идёт от количества проживающих">
            <Поля>
                <Поле Имя="Счет-Движения" Тип="Внешний ключ" Таблица="Лицевые счета" При_удалении="CASCADE" Описание="Указатель на лицевой счёт"/>
                <Поле Имя="Человек-Движения" Тип="Внешний ключ" Таблица="Карточки регистрации" При_удалении="CASCADE" Описание="Проживающий на ЛС, по которому происходит движение "/>
                <Поле Имя="Тип" Тип="Перечисляемое" Поля="Временное отсутствие\nВременная регистрация" Описание="0 - временное отсутствие, 1 - временная регистрация"/>
                <Поле Имя="Флаги" Тип="Флаги" Поля="Влияет на льготы\nВлияет на нормативное начисление для субсидии\nВлияет на фактическое начисление для субсидии\nВлияет на прожиточный минимум семьи\nКвартирант\nУчастник СВО"/>
                <Поле Имя="Причина" Тип="Перечисляемое" Поля="Причина указана текстом\n------------------------------\nБолезнь\nПроживание на садовом участке\nОтпуск\nВременная регистрация по другому адресу\nРабота вахтовым методом\nНахождение в плавании\nКомандировка\n------------------------------\nСлужба в ВС\nОбучение\nНахождение в МЛС\nНе проживание по адресу постоянной регистрации\nРозыск\n------------------------------\nВременная регистрация гражданина РФ\nВременная регистрация иностранного гражданина\n------------------------------\nПребывание в детском доме\nПребывание в интернате\nПребывание в доме-интернате"/>
                <Поле Имя="ДатНач" Тип="Дата" Размер="2"/>
                <Поле Имя="ДатКнц" Тип="Дата" Размер="2"/>
                <Поле Имя="Примечание" Тип="Строка" Описание="Необязательная дополнительная информация"/>
                <Поле Имя="Оставлять" Тип="Вещественное" Точность="9" Опции="CtrlC " Описание="Какой процент начислений оставлять при расчёте."/>
                <Поле Имя="НомерЗаявления" Тип="Целое" Опции="CtrlC "/>
                <Поле Имя="ДатРег" Тип="Дата" Размер="2"/>
                <Поле Имя="Дата подтверждения" Тип="Дата" Размер="2" Описание="Последняя дата подтверждения действия данной записи"/>
                <Поле Имя="Документ" Тип="Строка" Описание="Документ подтверждающий данные регистрационные действия"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="Счет" Поля="Счет-Движения, ДатНач, ДатКнц" ДопПоля="Тип, Оставлять"/>
                <Индекс Имя="Человек" Поля="Человек-Движения, ДатНач, ДатКнц"/>
            </Индексы_базы>
            <Триггеры>
                <Триггер Имя="Врем_движ" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql" Сущность1="Счет-Движения"/>
            </Триггеры>
