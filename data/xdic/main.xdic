                <Поле Имя="ВозвратПричина" Тип="Целое" Опции="CtrlC " Описание="Указание кода причины возврата суд. документа"/>
                <Поле Имя="ГосПошлина" Тип="Деньги" Опции="CtrlC " Описание="Сумма Госпошлины"/>
                <Поле Имя="ДатаСостояния" Тип="Дата" Размер="2" Описание="Дата контроля для ограничений ЮЛ в работе с параллельными фазами"/>
                <Поле Имя="Дата пени" Тип="Дата" Описание="Дата расчета пени"/>
                <Поле Имя="Дата уведомления" Тип="Дата" Описание="Дата вручения документа"/>
                <Поле Имя="ДатКнц" Тип="Дата" Размер="2" Описание="Дата окончания действия фазы"/>
                <Поле Имя="ДатКнцДолга" Тип="Дата" Размер="2" Описание="Последний месяц долга"/>
                <Поле Имя="ДатКнцПени" Тип="Дата" Размер="2" Описание="Последний месяц, за который считаем пени в деле"/>
                <Поле Имя="ДатНач" Тип="Дата" Размер="2" Описание="Дата начала действия фазы"/>
                <Поле Имя="ДатНачДолга" Тип="Дата" Размер="2" Описание="Первый месяц долга"/>
                <Поле Имя="ДатНачПени" Тип="Дата" Размер="2" Описание="Первый месяц, за который считаем пени в деле"/>
                <Поле Имя="ДанныеПоРассылке" Тип="Строка" PostgreSQL="jsonb" Описание="Хранит данные по рассылкам, созданным с состояния (актуально для ММО=2), для суда дополнительные данные по выпискам"/>
                <Поле Имя="Договор-Состояние" Тип="Целое" Описание="Не используется"/>
                <Поле Имя="Документ-Состояние" Тип="Внешний ключ" Таблица="Взыскание задолженности" При_удалении="CASCADE" Описание="Ссылка на документ взыскания"/>
                <Поле Имя="Доставка" Тип="Целое" Опции="CtrlC " Описание="Указание кода способа доствки документа"/>
                <Поле Имя="Задолженность-Состояния" Тип="Целое" Описание="Не используется"/>
                <Поле Имя="Идентификатор работы" Тип="Строка" Длина="256" Описание="Код работы из АРМ контролера"/>
                <Поле Имя="МесПостановки" Тип="Дата" Размер="2" Описание="Месяц, который был открыт на момент обновления суммы"/>
                <Поле Имя="Номер" Тип="Строка" Описание="Не используется"/>
                <Поле Имя="НомерДокумента" Тип="Строка" Описание="Номер судебного или иного документа (текстовый)"/>
                <Поле Имя="НомерУведомления" Тип="Длинное целое" Опции="CtrlC " Описание="Числовой номер документа, который генерируется в матрице"/>
                <Поле Имя="ПодФаза-Состояние" Тип="Внешний ключ" Таблица="Состояния фаз" При_удалении="NO ACTION" Описание="Ссылка на подфазу"/>
                <Поле Имя="ПредРеестр-Состояние" Тип="Целое" Описание="Не используется"/>
                <Поле Имя="ПредФаза" Тип="Целое" Описание="Ссылка на предыдущую фазу (не обяательна)"/>
                <Поле Имя="Прим2" Тип="Строка" Описание="Не используется"/>
                <Поле Имя="Примечание" Тип="Строка" Описание="Дополнительные данные по фазе"/>
                <Поле Имя="Причина" Тип="Целое" Опции="CtrlC " Описание="Указание кода причины недоставки документы"/>
                <Поле Имя="Реестр-Состояние" Тип="Целое" Описание="Не используется"/>
                <Поле Имя="Соглашение-Состояние" Тип="Внешний ключ" Таблица="Соглашение рассрочки" При_удалении="SET NULL" Описание="Ссылка на соглашение (появляется на деле, когда в процессе работы было создано соглашение)"/>
                <Поле Имя="Сост2" Тип="Целое" Опции="CtrlC " Описание="Не используется"/>
                <Поле Имя="Состояние" Тип="Целое" Описание="Не используется"/>
                <Поле Имя="Состояние-Дополнение" Тип="Внешний ключ" Таблица="Состояние документа дополнение" При_удалении="SET NULL" Описание="Ссылка на запись с дополнительными данными дела"/>
                <Поле Имя="Состояние-Организации" Тип="Внешний ключ" Таблица="Организации" При_удалении="NO ACTION" Описание="Исполнитель ограничений (сетевая, УК и т.д.)"/>
                <Поле Имя="Сумма" Тип="Деньги" Опции="CtrlC " Описание="Сумма долга"/>
                <Поле Имя="Сумма2" Тип="Деньги" Опции="CtrlC " Описание="Сумма пени"/>
                <Поле Имя="Сумма2Доля" Тип="Деньги" Опции="CtrlC " Описание="Сумма доли пени по делу при долевом взыскании"/>
                <Поле Имя="СуммаАванса" Тип="Деньги" Опции="CtrlC " Описание="Для юрлиц: сумма аванса в отделе ограничений"/>
                <Поле Имя="СуммаДоля" Тип="Деньги" Опции="CtrlC " Описание="Сумма доли основного долга по делу при долевом взыскании"/>
                <Поле Имя="СуммаПениОплата" Тип="Деньги" Опции="CtrlC " Описание="Не используется"/>
                <Поле Имя="СуммаПрочее" Тип="Деньги" Опции="CtrlC " Описание="Сумма прочих расходов"/>
                <Поле Имя="СУчетомАванса" Тип="Целое" Опции="CtrlC " Описание="Признак, был ли на деле расчитан аванс"/>
                <Поле Имя="Счет-Состояние" Тип="Целое" Описание="Не используется"/>
                <Поле Имя="Фаза-Состояние" Тип="Внешний ключ" Таблица="Виды фаз" При_удалении="NO ACTION" Описание="Ссылка на фазу"/>
                <Поле Имя="ФиксПени" Тип="Целое" Опции="CtrlC " Описание="Признак того, что пени на фазе не должны рассчитываться для дела (не влияет на спиание пени в момент вступления в силу)"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="ДатНач" Поля="ДатНач asc"/>
                <Индекс Имя="ДокументСостояниеНомПП" Поля="Документ-Состояние,N п/п" Выражение='&quot;N п/п&quot; = 0'/>
                <Индекс Имя="Документ-Состояние" Поля="Документ-Состояние asc"/>
                <Индекс Имя="Идентификатор работы" Поля="Идентификатор работы"/>
                <Индекс Имя="ОтслеживаниеЦИ" Поля="Фаза-Состояние" Выражение='&quot;ДанныеПоРассылке&quot; is not null and (&quot;ДанныеПоРассылке&quot;::json -> &apos;Направлено&apos;::text)::text is null and  (&quot;ДанныеПоРассылке&quot;::json -> &apos;ВнешниеИД&apos;::text)::text is not null'/>
                <Индекс Имя="ПодФаза" Поля="ПодФаза-Состояние,ДатКнц" ДопПоля="row_id" Выражение="&quot;ПодФаза-Состояние&quot; is not null"/>
                <Индекс Имя="ПредФаза" Поля="ПредФаза" ДопПоля=""/>
                <Индекс Имя="Соглашение-Состояние" Поля="Соглашение-Состояние" ДопПоля="" Выражение="&quot;Соглашение-Состояние&quot; is not null"/>
                <Индекс Имя="Состояние-Дополнение" Поля="Состояние-Дополнение" Выражение="&quot;Состояние-Дополнение&quot; is not null"/>
                <Индекс Имя="Состояние-Организации" Поля="Состояние-Организации" Выражение="&quot;Состояние-Организации&quot; is not null"/>
                <Индекс Имя="Фаза_ПодФаза" Поля="Фаза-Состояние,ПодФаза-Состояние,ДатКнц" ДопПоля="row_id,НомерУведомления"/>
            </Индексы_базы>
            <Триггеры>
                <Триггер Имя="Состояние_документа" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql" Сущность1="Документ-Состояние"/>
            </Триггеры>
        </Table>
