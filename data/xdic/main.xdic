        <Table Имя="Список объектов" Описание="Приборы учета - конкретные устройства (ИПУ, ОКПУ, ОДПУ)">
            <Поля>
                <Поле Имя="N п/п" Тип="Целое" Описание="Порядковый номер. Используется для упорядочивания ПУ при выводе в платежный документ, для интеграции с платежными агентами в части импорта показаний ПУ как уникальный код в пределах лицевого"/>
                <Поле Имя="Вариант" Тип="Целое" Размер="1" Длина="3" Описание="Тип канала прибора учета ( прямое обратное направление )"/>
                <Поле Имя="ВнесеноКонПоказание" Тип="Целое" Опции="CtrlC " Описание="не используется"/>
                <Поле Имя="ГодВыпуска" Тип="Дата" Размер="2" Описание="Год выпуска устройства"/>
                <Поле Имя="ДатКнц" Тип="Дата" Размер="2" Описание="Дата снятия ПУ"/>
                <Поле Имя="ДатНач" Тип="Дата" Размер="2" Описание="Дата установки ПУ"/>
                <Поле Имя="ДатаПломбы" Тип="Дата" Размер="2" Описание="Дата опломбировки ПУ"/>
                <Поле Имя="ДатаПоверки" Тип="Дата" Размер="2" Описание="Дата последней поверки"/>
                <Поле Имя="ДатаСледующейПоверки" Тип="Дата" Размер="2" Описание="Дата следующей поверки"/>
                <Поле Имя="Доступ" Тип="Целое" Опции="CtrlC " Описание="Возможность/не возможность доступа к ПУ (используется для формирование ведомостей обхода)"/>
                <Поле Имя="ДробнаяРазрядность" Тип="Целое" Размер="1" Длина="3" Описание="Количество разрядов в дробной части значения показания"/>
                <Поле Имя="ЗаводскойНомер" Тип="Строка" Описание="Заводской номер устройства"/>
                <Поле Имя="ИсторияПоверки" Тип="Строка" Описание="не используется"/>
                <Поле Имя="КонПоказание" Тип="Вещественное" Точность="9" Описание="Копия конечного показания из таблицы с показаниями счетчиков. С учетом возможной многотарифности ПУ работает только для однотарифных"/>
                <Поле Имя="Коэффициент трансформации" Тип="Вещественное" Точность="9" Опции="CtrlC " Описание="Характеристика ПУ, измеряющих количество потребленной электроэнергии. На него умножается объем, определенный по разности показаний, для получения объема к начислению по ПУ"/>
                <Поле Имя="КоэффициентВычитания" Тип="Вещественное" Точность="9" Описание="не используется"/>
                <Поле Имя="Место установки" Тип="Внешний ключ" Таблица="Места установки ПУ" Описание="Перечисляемое поле с местом установки ПУ (вспомогательная информация для контролеров)"/>
                <Поле Имя="НачПоказание" Тип="Вещественное" Точность="9" Описание="Копия начального показания из таблицы с показаниями счетчиков. С учетом возможной многотарифности ПУ работает только для однотарифных"/>
                <Поле Имя="Номенклатура-Объекты" Тип="Внешний ключ" Таблица="Номенклатура" При_удалении="NO ACTION" Описание="Связь устройства со справочником моделей ПУ"/>
                <Поле Имя="НомерПломбы" Тип="Строка" Описание="Номер пломбы"/>
                <Поле Имя="Объект-Услуга" Тип="Внешний ключ" Таблица="Типы услуг" При_удалении="NO ACTION" Описание="Связь со справочником услуг. Услуга, которая биллингуется от показаний этого ПУ"/>
                <Поле Имя="Объекты-Групповой" Тип="Внешний ключ" Таблица="Документ" При_удалении="CASCADE" Описание="Для ОКПУ и ОДПУ - связь с карточкой коллективного прибора учета. Например, на одной карточке для дома может быть несколько ОДПУ по одной услуге, суммарный объем которых участвует в расчете ОДН"/>
                <Поле Имя="Объекты-Счет" Тип="Внешний ключ" Таблица="Лицевые счета" При_удалении="NO ACTION" Описание="Для ИПУ - связь с лицевым счетом, на котором установлен ПУ"/>
                <Поле Имя="ОбъемВычитания" Тип="Вещественное" Точность="9" Описание="не используется"/>
                <Поле Имя="Примечание" Тип="Строка" Описание="пользовательское примечание"/>
                <Поле Имя="ПричинаСнятия" Тип="Целое" Размер="1" Длина="3" Описание="Причины снятия ПУ"/>
                <Поле Имя="Разрядность" Тип="Целое" Размер="1" Длина="3" Описание="Количество разрядов в целой части значения показания"/>
                <Поле Имя="Тарифность" Тип="Целое" Описание="Количество тарифных зон, по которым ПУ производит измерения (однотарифные, двухтарифные - день/ночь, трехтарифные - ночь/пик/полупик)"/>
                <Поле Имя="Объекты-СетьСоединение" Тип="Внешний ключ" Таблица="Сеть соединения" При_удалении="NO ACTION" Описание="Для приборов на структуре сети - связь с соединением сети, на котором установлен прибор"/>
                <Поле Имя="Владелец" Тип="Целое" Размер="1" Длина="3" Описание="Собственник прибора учета" />
                <Поле Имя="ИдентификаторАСД" Тип="Целое" Описание="Идентификатор прибора (номер записи) в модуле АСД"/>
                <Поле Имя="Внешний код" Тип="Строка" Длина="256" />
                <Поле Имя="БезПоказаний" Тип="Целое" Описание="Флаг снятия без показаний"/>
                <Поле Имя="_ИД" Тип="Строка"/>
                <Поле Имя="Объекты-Узел" Тип="Внешний ключ" Таблица="Узлы учета" При_удалении="NO ACTION" Описание="Ссылка на узел учета"/>
                <Поле Имя="ДатаДемонтажа" Тип="Дата" Описание="Дата демонтажа"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="Счет" Поля="Объекты-Счет, ДатКнц" ДопПоля="ДатНач, Номенклатура-Объекты, Объект-Услуга" Выражение="&quot;Объекты-Счет&quot; is not null"/>
                <Индекс Имя="Документ" Поля="Объекты-Групповой, ДатНач, ДатКнц" Выражение="&quot;Объекты-Групповой&quot; is not null"/>
                <Индекс Имя="Объекты-СетьСоединение" Поля="Объекты-СетьСоединение, ДатНач, ДатКнц" ДопПоля="Номенклатура-Объекты" Выражение="&quot;Объекты-СетьСоединение&quot; is not null"/>
                <Индекс Имя="ЗаводскойНомер" Тип="gin" Поля="&quot;ЗаводскойНомер&quot; gin_trgm_ops"/>
                <Индекс Имя="_ИД" Поля="_ИД"/>
                <Индекс Имя="Объект-Услуга" Поля="Объект-Услуга"/>
            </Индексы_базы>
            <Триггеры>
                <Триггер Имя="Список_объектов" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql" Сущности1="Объекты-Счет,Объекты-СетьСоединение" Сущность2="Объекты-Групповой"/>
                <Триггер Имя="Список_объектов_BF_ALLTRIG" Версия="3" Файл="Список объектов_BF_INSTRIG.sql"/>
            </Триггеры>
            <Политики>
                <Политика Имя="AP_Usl" Файл="Список объектов_Select_AP_Usl.sql"/>
            </Политики>
        </Table>
