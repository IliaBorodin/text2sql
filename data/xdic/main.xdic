                <Поле Имя="ФЛДоговор-Подразделение" Тип="Внешний ключ" Таблица="Организации" При_удалении="SET NULL"/>
                <Поле Имя="ФЛДоговор-Ответственный" Тип="Внешний ключ" Таблица="Сотрудники" При_удалении="SET NULL"/>
