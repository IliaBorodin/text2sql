                <Поле Имя="Аналитика" Тип="Целое" Опции="CtrlC "/>
                <Поле Имя="Дело-Акты" Тип="Внешний ключ" Таблица="Взыскание задолженности" При_удалении="NO ACTION" Описание="Используется при работе с дебиторами"/>
                <Поле Имя="Задача" Тип="Целое" Размер="2" Значение_по_умолчанию="0"/>
                <Поле Имя="Окончания срок" Тип="Дата" Размер="2"/>
                <Поле Имя="Акт-Карточка" Тип="Внешний ключ" Таблица="ДО карточки" При_удалении="NO ACTION"/>
                <Поле Имя="Статус" Тип="Перечисляемое" Поля="\nОбъем включен в объем полезного отпуска\nПодписан на отлагательных условиях\nАннулирован" Описание="Статус акта"/>
                <Поле Имя="Подтвержден" Тип="Перечисляемое" Поля="Не подтверждён\nПодтвержден" Описание="Статус подтверждения акта"/>
                <Поле Имя="ЗаМесяц" Тип="Дата" Размер="2"/>
                <Поле Имя="Акты-Причина недоучета" Таблица="Классификаторы" Тип="Внешний ключ" При_удалении="NO ACTION"/>
                <Поле Имя="Способ" Тип="Перечисляемое" Поля="Своими силами\nС привлечением сетей" />
                <Поле Имя="Вид" Тип="Перечисляемое" Поля="Полное\nЧастичное" />
                <Поле Имя="ДанныеПараметра" Тип="Строка" Поля="Json данные параметра по отключению" />
                <Поле Имя="ВидРасчета" Тип="Перечисляемое" Поля="по мощности\nпо нормативу с коэффициентом 10"/>
