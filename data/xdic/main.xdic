                <Поле Имя="Автор" Тип="Строка" Описание="Последний редактирующий запись пользователь"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="Ix_Частные_лица_Телефон" Поля="Частные лица-Телефон, Тип" Выражение="&quot;Частные лица-Телефон&quot; is not null"/>
                <Индекс Имя="Ix_Частные_лица_Флаг" Поля="Частные лица-Телефон, Флаги" Выражение="&quot;Частные лица-Телефон&quot; is not null"/>
                <Индекс Имя="Ix_Телефоны_Человек" Поля="Человек-Телефон" Выражение="&quot;Человек-Телефон&quot; is not null"/>
                <Индекс Имя="Ix_Телефоны_Счет" Поля="Счет-Телефон, Флаги" Выражение="&quot;Счет-Телефон&quot; is not null"/>
                <Индекс Имя="Организация-Телефон" Поля="Организация-Телефон" Выражение="&quot;Организация-Телефон&quot; is not null"/>
                <Индекс Имя="Сотрудник-Телефон" Поля="Сотрудник-Телефон, Тип" Выражение="&quot;Сотрудник-Телефон&quot; is not null"/>
                <Индекс Имя="Пароли-Телефон" Поля="Пароли-Телефон, Номер" Выражение="&quot;Пароли-Телефон&quot; is not null"/>
                <Индекс Имя="Номер" Тип="gin" Поля="&quot;Номер&quot; gin_trgm_ops"/>
                <Индекс Имя="КонтактПоКонтрагенту" Поля="идКонтрагент,Тип" ДопПоля="row_id" Выражение="&quot;идКонтрагент&quot; is not null" />
            </Индексы_базы>
            <Триггеры>
                <Триггер Имя="Телефоны" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql" Сущности1="Счет-Телефон,Организация-Телефон,Сотрудник-Телефон" Сущности2="Частные лица-Телефон,Пароли-Телефон,Человек-Телефон"/>
                <Триггер Имя="$Телефоны_частные_лица_ALLTRIG" Версия="1" Файл="Телефоны_частные_лица_INSTRIG.sql"/>
            </Триггеры>
        </Table>
