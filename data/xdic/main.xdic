        <Table Имя="ЦентрУведомленийТранспорт" Описание="Транспорт центра уведомлений">
            <Поля>
                <Поле Имя="Папки" Тип="Иерархия" Опции="CascadeDelete " Описание="Указатель на родительскую запись в иерархии"/>
                <Поле Имя="Название" Тип="Строка" Описание="Название транспорта"/>
                <Поле Имя="Комментарий" Тип="Строка" Длина="1000" Описание="Описание транспорта"/>
