                <Индекс Имя="Платеж-Выписка" Поля="Платеж-Выписка, Тип документа" ДопПоля="Дата"/>
                <Индекс Имя="Сторнирование" Поля="Сторнирование" Выражение="&quot;Сторнирование&quot; > 0"/>
                <Индекс Имя="ТипСумма" Поля="row_id,Тип документа, Сумма" Выражение='&quot;Тип документа&quot; = 35 and &quot;Сумма&quot;&lt;0'/>
                <Индекс Имя="ТипПричина" Поля="Тип документа, Причина-Платежи"/>
                <Индекс Имя="ИсточникПлатежи" Поля="Источник-Платежи"/>
                <Индекс Имя="Лицо1" Поля="Лицо1" Выражение="&quot;Лицо1&quot; is not null"/>
                <Индекс Имя="Лицо2" Поля="Лицо2" Выражение="&quot;Лицо2&quot; is not null"/>
                <Индекс Имя="Лицо3" Поля="Лицо3" Выражение="&quot;Лицо3&quot; is not null"/>
                <Индекс Имя="_ИД" Поля="_ИД,FOLDER"/>
                <Индекс Имя="Чек-Ордер" Поля="Чек-Ордер" Выражение="&quot;Чек-Ордер&quot; is not null"/>
                <Индекс Имя="Платеж-Показания" Поля="Платеж-Показания" Выражение="&quot;Платеж-Показания&quot; is not null"/>
            </Индексы_базы>
            <Триггеры>
                <Триггер Имя="Документ" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql" Сущность1="Документы-Договор" Сущность2="Платеж-Выписка"/>
                <Триггер Имя="Документ_BF_ALLTRIG" Версия="2" Файл="Документ_BF_INSTRIG.sql"/>
                <Триггер Имя="Документ_ВП_INSTRIG" Версия="1" Файл="Документ_ВП_ALL_FUNC.sql"/>
                <Триггер Имя="Документ_ВП_DELTRIG" Версия="1"/>
            </Триггеры>
        </Table>
        <Table Имя="Док состояния" Описание="таблица состояний документа, договора, договора с УК">
            <Поля>
                <Поле Имя="Документ-Состояние" Тип="Внешний ключ" Таблица="Документ" При_удалении="CASCADE" Описание="ссылка на документ"/>
                <Поле Имя="Договор-Состояние" Тип="Внешний ключ" Таблица="Договор" При_удалении="CASCADE" Описание="ссылка на договор"/>
                <Поле Имя="ДоговорУК-Состояние" Тип="Внешний ключ" Таблица="УК Договоры" При_удалении="CASCADE" Описание="ссылка на договор с УК"/>
                <Поле Имя="Виды-Состояние" Тип="Внешний ключ" Таблица="Классификаторы" При_удалении="NO ACTION" Описание="ссылка на справочник состояний"/>
                <Поле Имя="Дата" Тип="ДатаВремя" Размер="2" Описание="дата установки состояния"/>
                <Поле Имя="Комментарий" Тип="Строка" Описание="комментарий"/>
                <Поле Имя="Автор" Тип="Строка" Описание="Имя пользователя"/>
                <Поле Имя="УдалившийПользователь" Тип="Строка" Описание="Имя пользователя, выполнившего удаление"/>
                <Поле Имя="ДатаУдаления" Тип="ДатаВремя" Размер="2" Описание="Дата удаления состояния"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="Документ-Состояние" Поля="Документ-Состояние, Виды-Состояние"/>
                <Индекс Имя="Договор-Состояние" Поля="Договор-Состояние, Виды-Состояние"/>
            </Индексы_базы>
            <Триггеры>
                <Триггер Имя="Док_состояния" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql" Сущности1="Договор-Состояние,Документ-Состояние"/>
            </Триггеры>
        </Table>
        <Table Имя="Типы документов" Описание="Используется для комплектов документов а так же содержит служебный перечень типов документов. Таблица Документ поле Тип документа">
