                <Поле Имя="Место работы" Тип="Строка" Описание="Место работы ответчика"/>
                <Поле Имя="Место рождения" Тип="Строка" Описание="Место рождения ответчика"/>
                <Поле Имя="Ответчик-Документ" Тип="Внешний ключ" Таблица="Взыскание задолженности" При_удалении="CASCADE" Описание="Указывает, к какому делу относится ответчик"/>
                <Поле Имя="Ответчик-Организация" Тип="Внешний ключ" Таблица="Организации" При_удалении="SET NULL" Описание="Указывает на орагнизацию, если ответчик - юрлицо"/>
                <Поле Имя="Ответчик-Частные лица" Тип="Внешний ключ" Таблица="Частные лица" При_удалении="NO ACTION" Описание="Указывает на карточку частного лица, если ответчик - физлицо"/>
                <Поле Имя="Ответчик-Человек" Тип="Внешний ключ" Таблица="Карточки регистрации" При_удалении="SET NULL" Описание="Указывает на карточку регистрации ответчика"/>
                <Поле Имя="Паспорт" Тип="Строка" Описание="В данный момент не используется"/>
                <Поле Имя="Пенсионное свидетельство" Тип="Текст" Размер="14" Описание="№ СНИЛС ответчика"/>
                <Поле Имя="Пол" Тип="Целое" Опции="CtrlC " Описание="Пол ответчика (0 - мужской, 1 - женский)"/>
                <Поле Имя="ПризнакБанкротства" Тип="Флаги" Поля="Банкрот" Описание="Признак того, что ответчик был создан в рамках деления дел для банкротного дела"/>
                <Поле Имя="СовместнаяСОтветчик" Тип="Внешний ключ" Таблица="Список ответчиков" При_удалении="SET NULL" Описание="Ссылка на ответчика, с которым совместная собственность"/>
                <Поле Имя="СовместнаяСЧС" Тип="Внешний ключ" Таблица="Частные лица" При_удалении="NO ACTION" Описание="Указывает на карточку частного лица, являющегося главным"/>
                <Поле Имя="СуммаКредитора" Тип="Деньги" Опции="CtrlC " Описание="Сумма, которую заявитель задолжал кредитору"/>
                <Поле Имя="Тип" Тип="Целое" Опции="CtrlC " Описание="Тип ответчика (ответчик, истец, иное лицо, третье лица)"/>
                <Поле Имя="ТипОтветчика" Тип="Целое" Описание="Вид ответчика (собственник, член семьи, опекун и т.п.)"/>
                <Поле Имя="ФИО" Тип="Строка" Описание="ФИО\наименование ответчика"/>
            </Поля>
