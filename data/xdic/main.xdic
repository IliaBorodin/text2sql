        <Table Имя="Сеть элементы" Описание="Элементы структуры сети">
            <Поля>
                <Поле Имя="Папки" Тип="Иерархия" Опции="NoDelete " Описание="Указатель на папку"/>
                <Поле Имя="ТипСети" Тип="Целое" Размер="1" Описание="Тип сети: 1 - тепловая, 2 - электрическая, 3 - водоснабжение, 4 - водоотведение. Может расширяться под требования Заказчика"/>
                <Поле Имя="ТипСети2" Тип="Целое" Размер="1" Описание="Подтип сети, зависит от типа сети, см. sql-функцию ~net_ts2str~"/>
                <Поле Имя="ТипСети3" Тип="Целое" Размер="1" Описание="Подтип сети, зависит от типа сети, см. sql-функцию ~net_ts3str~"/>
                <Поле Имя="ТипЭлемента" Тип="Целое" Размер="1" Описание="Тип элемента сети, зависит от типа сети, см. функции: ТепловаяСеть_ДанныеЭлементаМассив(), ЭлектрическаяСеть_ДанныеЭлементаМассив(), СетьВодоснабжения_ДанныеЭлементаМассив(), СетьВодоотведения_ДанныеЭлементаМассив()"/>
                <Поле Имя="Код" Тип="Текст" Описание="Код элемента. Используется по усмотрению Заказчика (обычно для синхронизации со сторонними системами)"/>
                <Поле Имя="Название" Тип="Текст" Описание="Название элемента"/>
                <Поле Имя="Примечание" Тип="Текст" Описание="Пользовательское примечание"/>
                <Поле Имя="Адрес" Тип="Текст" Описание="Адрес элемента"/>
                <Поле Имя="АдресКладр" Тип="Текст" Описание="Адрес элемента в формате КЛАДР"/>
                <Поле Имя="Подразделение" Тип="Внешний ключ" Таблица="Подразделения" При_удалении="NO ACTION" Описание="Принадлежность к подразделению. Указатель на таблицу ~Подразделения~"/>
                <Поле Имя="Сетевая" Тип="Внешний ключ" Таблица="Организации" При_удалении="NO ACTION" Описание="Сетевая организация, которой принадлежит элемент (владелец). Указатель на таблицу ~Организации~"/>
                <Поле Имя="Объект" Тип="Внешний ключ" Таблица="Сеть объекты" При_удалении="NO ACTION" Описание="Объект сети (комплексный), в который входит элемент. Указатель на таблицу ~Сеть объекты~"/>
                <Поле Имя="Классификатор" Тип="Внешний ключ" Таблица="Классификаторы" При_удалении="NO ACTION" Описание="Пользовательский классификатор элементов. Указатель на таблицу ~Классификаторы~"/>
                <Поле Имя="Номенклатура" Тип="Внешний ключ" Таблица="Номенклатура" При_удалении="NO ACTION" Описание="Принадлежность к типу оборудования. Только для определенных типов элементов (например, силовые транформаторы элетрических сетей). Указатель на таблицу ~Номенклатура~"/>
                <Поле Имя="Отображение" Тип="Целое" Размер="1" Значение_по_умолчанию="0" Описание="Режим отображения в дереве сети и отчетах: 0 - показывать, 1 - скрывать, 2 - сворачивать"/>
                <Поле Имя="ГеоШирота" Тип="Вещественное" MSSQL="decimal(9,6)" PostgreSQL="numeric(9,6)" Размер="5" Длина="9" Точность="6" Значение_по_умолчанию="0" Описание="Не используется"/>
                <Поле Имя="ГеоДолгота" Тип="Вещественное" MSSQL="decimal(9,6)" PostgreSQL="numeric(9,6)" Размер="5" Длина="9" Точность="6" Значение_по_умолчанию="0" Описание="Не используется"/>
                <Поле Имя="ГеоСтатус" Тип="Целое" Значение_по_умолчанию="0" Описание="Не используется"/>
                <Поле Имя="ГеоДата" Тип="Дата" Размер="2" Описание="Не используется"/>
                <Поле Имя="ГеоСотрудник" Тип="Внешний ключ" Таблица="Сотрудники" При_удалении="SET NULL" Описание="Не используется"/>
            </Поля>
            <Индексы/>
            <Индексы_базы>
                <Индекс Имя="Папки" Поля="Папки"/>
                <Индекс Имя="Код" Поля="Код"/>
                <Индекс Имя="Объект" Поля="Объект"/>
            </Индексы_базы>
            <Триггеры>
                <Триггер Имя="Сеть_элементы" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql" />
            </Триггеры>
        </Table>
        <Table Имя="Сеть соединения" Описание="Соединения элементов структуры сети">
            <Поля>
                <Поле Имя="Код" Тип="Текст" Длина="100" Описание="Код элемента. Используется по усмотрению Заказчика (обычно для синхронизации со сторонними системами)"/>
                <Поле Имя="Название" Тип="Текст" Описание="Название соединения"/>
                <Поле Имя="Примечание" Тип="Текст" Описание="Пользовательское примечание"/>
                <Поле Имя="Элемент1" Тип="Внешний ключ" Таблица="Сеть элементы" При_удалении="CASCADE" Описание="Элемент сети, с которого идет соединение (откуда). Указатель на таблицу ~Сеть элементы~"/>
                <Поле Имя="Элемент2" Тип="Внешний ключ" Таблица="Сеть элементы" При_удалении="CASCADE" Описание="Элемент сети, на который идет соединение (куда). Указатель на таблицу ~Сеть элементы~"/>
                <Поле Имя="ВидОбъема" Тип="Целое" Размер="1" Значение_по_умолчанию="0" Описание="Вид объема, проходящего по соединению: 0 - обычный (распределение), 1 - собственные нужды, 2 - технологические потери, 3 - полезный отпуск. Может быть изменен под требования Заказчика"/>
                <Поле Имя="СпособРасчета" Тип="Целое" Размер="1" Значение_по_умолчанию="0" Описание="Способ расчета соединения: 0 - по прибору, 1 - баланс вниз, 2 - баланс вверх, 3 - пользовательский. Может быть изменен под требования Заказчика"/>
                <Поле Имя="Резерв" Тип="Целое" Размер="1" Значение_по_умолчанию="0" Описание="Признак резервного соединения: 0 - не резервное соединение, 1 - резервное соединение"/>
            </Поля>
            <Индексы/>
            <Индексы_базы>
                <Индекс Имя="Элемент1" Поля="Элемент1" ДопПоля="Элемент2, ВидОбъема, СпособРасчета, Резерв"/>
                <Индекс Имя="Элемент2" Поля="Элемент2" ДопПоля="Элемент1, ВидОбъема, СпособРасчета, Резерв"/>
            </Индексы_базы>
            <Триггеры>
                <Триггер Имя="Сеть_соединения" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql" Сущность1="Элемент1" Сущность2="Элемент2" />
            </Триггеры>
        </Table>
        <Table Имя="Сеть состояния" Описание="Состояния соединений элементов структуры сети">
            <Поля>
                <Поле Имя="Соединение" Тип="Внешний ключ" Таблица="Сеть соединения" При_удалении="CASCADE" Описание="Соединение сети. Указатель на таблицу ~Сеть соединения~"/>
                <Поле Имя="Состояние" Тип="Целое" Размер="1" Описание="Состояние соединения: 0 - выключено, 1 - включено"/>
                <Поле Имя="ДатаВремяНач" Тип="ДатаВремя" Описание="Дата-время начала состояния"/>
                <Поле Имя="ДатаВремяКнц" Тип="ДатаВремя" Описание="Дата-время окончания состояния"/>
                <Поле Имя="Примечание" Тип="Строка" Описание="Пользовательское примечание"/>
                <Поле Имя="Процент" Тип="Вещественное" Значение_по_умолчанию="0" Описание="Процент участия при одновременном подключении. Используется в водоотведении"/>
            </Поля>
            <Индексы/>
            <Индексы_базы>
                <Индекс Имя="Соединение" Поля="Соединение, ДатаВремяНач" ДопПоля="Состояние, ДатаВремяКнц"/>
            </Индексы_базы>
            <Триггеры>
                <Триггер Имя="Сеть_состояния" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql" Сущность1="Соединение" />
            </Триггеры>
        </Table>
        <Table Имя="Сеть объемы" Вид="Служебная" Категория="Начислительные" Описание="Объемы расчета сети">
            <Поля>
                <Поле Имя="Элемент" Тип="Целое" Описание="Элемент сети. Равно -1, если это строка расчета соединения. Указатель на таблицу ~Сеть элементы~"/>
                <Поле Имя="Соединение" Тип="Целое" Описание="Соединение сети. Равно -1, если это строка расчета элемента. Указатель на таблицу ~Сеть соединения~"/>
                <Поле Имя="Месяц" Тип="Дата" Описание="Месяц расчета"/>
                <Поле Имя="Объем" Тип="Вещественное" MSSQL="decimal(19,3)" PostgreSQL="numeric(19,3)" Размер="9" Длина="19" Точность="3" Описание="Рассчитанный объем"/>
                <Поле Имя="Статус" Тип="Целое" Размер="2" Описание="Статус расчета, см. функцию РасчетСети_СтатусСтрокой"/>
                <Поле Имя="Аналитика" Тип="Целое" Таблица="Сеть аналитика" Опции="NoDelete " Описание="Аналитика расчета. Указатель на таблицу ~Сеть аналитика~"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="Элемент" Поля="Элемент,Месяц"/>
                <Индекс Имя="Соединение" Поля="Соединение,Месяц"/>
                <Индекс Имя="МесяцЭлемент" Поля="Месяц,Элемент"/>
                <Индекс Имя="МесяцСоединение" Поля="Месяц,Соединение"/>
                <Индекс Имя="Аналитика" Поля="Аналитика"/>
            </Индексы_базы>
            <Триггеры/>
        </Table>
        <Table Имя="Сеть аналитика" Описание="Справочник аналитик расчета сети">
            <Поля>
                <Поле Имя="ТипСети" Тип="Целое" Размер="1" Описание="см. описание аналогичного поля в таблице ~Сеть элементы~"/>
                <Поле Имя="ТипСети2" Тип="Целое" Размер="1" Значение_по_умолчанию="0" Описание="см. описание аналогичного поля в таблице ~Сеть элементы~"/>
                <Поле Имя="ТипСети3" Тип="Целое" Размер="1" Значение_по_умолчанию="0" Описание="см. описание аналогичного поля в таблице ~Сеть элементы~"/>
                <Поле Имя="ВидОбъема" Тип="Целое" Размер="1" Значение_по_умолчанию="0" Описание="см. описание аналогичного поля в таблице ~Сеть соединения~"/>
                <Поле Имя="Флаги" Тип="Целое" Значение_по_умолчанию="0" Описание="см. sql-функцию ~net_fa_list~"/>
                <Поле Имя="Сетевая1" Тип="Внешний ключ" Таблица="Организации" При_удалении="NO ACTION" Описание="Сетевая организация (владелец), которой принадлежит Элемент1 рассчитываемого соединения (в данных расчета элемента - сам рассчитываемый элемент). Указатель на таблицу ~Организации~"/>
                <Поле Имя="Сетевая2" Тип="Внешний ключ" Таблица="Организации" При_удалении="NO ACTION" Описание="Сетевая организация (владелец), которой принадлежит Элемент2 рассчитываемого соединения (только в данных расчета соединения). Указатель на таблицу ~Организации~"/>
            </Поля>
            <Индексы/>
            <Индексы_базы>
                <Индекс Имя="Полный" Поля="ТипСети,ТипСети2,ТипСети3,ВидОбъема,Флаги,Сетевая1,Сетевая2"/>
            </Индексы_базы>
            <Триггеры/>
        </Table>
