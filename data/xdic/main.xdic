        <Table Имя="#kvitFilter" Вид="Временная" Схема="tmp" Описание="Таблица заполняется при подготовке квитанции. Служит для фильтрации данных и чтобы избежать повторного сбора информации">
            <Поля>
                <Поле Имя="row_id" Тип="Целое" Описание="row_id макета квитанции"/>
                <Поле Имя="ПризнакМакета" Тип="Целое" Описание="Поле ПризнакМакета из таблицы Макеты квитанций (не действует/по умолчанию/для договора/дополнительный)"/>
                <Поле Имя="ТипДанных" Тип="Целое" Описание="Поле Детализация из таблицы Макеты квитанций (0-общая, 2-пеневая)"/>
                <Поле Имя="Код услуги" Тип="Целое" Описание="row_id услуги из таблицы Типы услуг"/>
                <Поле Имя="Номер услуги" Тип="Целое" Описание="Номер услуги из таблицы Типы услуг"/>
                <Поле Имя="Название услуги" Тип="Строка" Длина="250" Описание="Название услуги из таблицы Типы услуг"/>
                <Поле Имя="Единица измерения" Тип="Строка" Длина="250" Описание="Единица измерения услуги из таблицы Типы услуг"/>
                <Поле Имя="Группа услуг" Тип="Целое" Описание="Номер группы услуг"/>
                <Поле Имя="Название группы" Тип="Строка" Длина="250" Описание="Название группы услуг"/>
                <Поле Имя="Сокращение группы" Тип="Строка" Длина="5" Описание="Сокращенное название группы услуг (ХВС, ГВС итд)"/>
                <Поле Имя="УслОДН" Тип="Целое" Описание="Признак, что услуга является услугой ОДН (значение 0/1)"/>
                <Поле Имя="УслПК" Тип="Целое" Описание="Признак, что услуга является услугой повышающего коэффициента (значение 0/1)"/>
