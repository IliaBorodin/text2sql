            </Индексы_базы>
        </Table>
        <Table Имя="#tmpImport_IspPr" Описание="Таблица карточек ГП" Вид="ВременнаяДляПользователя" Схема="tmp">
            <Поля>
                <Поле Имя="row_id" Тип="Целое" Опции="Identity"/>
                <Поле Имя="NPP" Тип="Целое" Описание="Служебное: Номер по порядку в файле, если есть Номер по порядку в файле, использовать его"/>
                <Поле Имя="ID_IP" Тип="Строка" Длина="2000" Описание="Идентификатор исполнительного документа (поле ID из файла lawer_ispdoc) *Обязательное"/>
                <Поле Имя="DATE" Тип="Дата" Размер="2" Описание="Дата события в формате дд.мм.гггг *Обязательное"/>
                <Поле Имя="NUMBER" Тип="Строка" Длина="2000" Описание="Номер производства"/>
                <Поле Имя="ID_NEWORG" Тип="Строка" Длина="2000" Описание="Служебное: Идентификатор из поля ID_OSP. Заполняется для новых организаций"/>
                <Поле Имя="ID_OSP" Тип="Строка" Длина="2000" Описание="Идентификатор места хранения (поле ID_SUDUCH из файла tmpImport_Sud_ORG с типом 1)"/>
                <Поле Имя="OSP" Тип="Строка" Длина="2000" Описание="Служебное: xlsx - место хранения текстом, csv - row_id места хранения из справочника"/>
                <Поле Имя="SUM" Тип="Вещественное" Точность="9" Описание="Сумма основного долга (разделитель .)"/>
                <Поле Имя="GP" Тип="Вещественное" Точность="9" Описание="Сумма госпошлины (разделитель .)"/>
                <Поле Имя="PENI" Тип="Вещественное" Точность="9" Описание="Сумма пени (разделитель .)"/>
                <Поле Имя="SUMM_PR" Тип="Вещественное" Точность="9" Описание="Сумма прочих расходов (разделитель .)"/>
                <Поле Имя="ID_ACTIONS" Тип="Строка" Длина="2000" Описание="Стронний код состояния ИД (по умолчанию используем поле Код из справочика состояний ИД. При неоходимости дополнительно готовится список соответствий) *Обязательное"/>
                <Поле Имя="ID_ACTIONS2" Тип="Строка" Длина="2000" Описание="Стронний код состояния ИД (при необходимости)"/>
                <Поле Имя="COMMENT" Тип="Строка" Длина="2000" Описание="Примечание к фазе"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="ID_IP" Поля="ID_IP" ДопПоля=""/>
            </Индексы_базы>
        </Table>
