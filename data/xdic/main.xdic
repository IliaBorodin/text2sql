                <Поле Имя="ИНН" Тип="Строка" Описание="ИНН плательщика"/>
                <Поле Имя="КПП" Тип="Строка" Описание="КПП  плательщика"/>
                <Поле Имя="БИК" Тип="Строка" Описание="БИК  плательщика"/>
                <Поле Имя="РСчет" Тип="Строка" Описание="РС  плательщика"/>
                <Поле Имя="КоррСчет" Тип="Строка" Описание="КС  плательщика"/>
