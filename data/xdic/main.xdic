        <Table Имя="Сообщения в квитанции" Описание="Таблица хранит в себе сообщения в квитанции разных видов">
            <Поля>
                <Поле Имя="Папки" Тип="Иерархия" Опции="BreakDelete "/>
                <Поле Имя="Название" Тип="Строка" Описание="Не используется в текущей версии"/>
                <Поле Имя="Лицевой-Сообщение" Тип="Внешний ключ" Таблица="Лицевые счета" При_удалении="CASCADE" Описание="Группа ЛС по которым задано сообщение"/>
                <Поле Имя="Договор-Сообщение" Тип="Внешний ключ" Таблица="Договор" При_удалении="CASCADE" Описание="Группа ЛС по которым задано сообщение"/>
                <Поле Имя="УК Договор-Сообщение" Тип="Внешний ключ" Таблица="УК Договоры" При_удалении="CASCADE" Описание="Договор УК к которому привязано сообщение"/>
                <Поле Имя="Организация-Сообщение" Тип="Внешний ключ" Таблица="Организации" При_удалении="CASCADE" Описание="Организация, на которую заведено сообщение для таблицы исполнителей и шапки"/>
                <Поле Имя="ДатНач" Тип="Дата" Размер="4" Значение_по_умолчанию_MSSQL="getdate()" Значение_по_умолчанию_PostgreSQL="now()" Описание="Дата начала действия сообщения"/>
                <Поле Имя="ДатКнц" Тип="Дата" Размер="4" Значение_по_умолчанию_MSSQL="&apos;2045-05-09&apos;" Значение_по_умолчанию_PostgreSQL="&apos;2045-05-09 00:00:00&apos;::timestamp without time zone" Описание="Дата конца действия сообщения"/>
                <Поле Имя="Признаки" Тип="Целое" Описание="Заполняется 1 для сообщения ГЖИ"/>
                <Поле Имя="ТипАдресата" Тип="Перечисляемое" Поля="Для всех\nДля адреса\nДля договора с УК\nСообщение ГЖИ\nДля шапки\nДля исполнителя\nДля рассрочки\nДомовой чат в MAX\nИнформационный чат УК/ РСО в MAX" Описание="Вид сообщения"/>
                <Поле Имя="Текст" Тип="Строка" Длина="4000" Описание="Основной текст сообщения"/>
                <Поле Имя="Соглашение-Сообщение" Тип="Внешний ключ" Таблица="Соглашение рассрочки" При_удалении="CASCADE"/>
                <Поле Имя="Перекрытие" Тип="Перечисляемое" Поля="Перекрываем сообщение верхнего уровня\nДобавляем к сообщению верхнего уровня"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="Ix_ЛицевойУК" Поля="Лицевой-Сообщение,УК Договор-Сообщение" ДопПоля="ДатНач,ДатКнц"/>
                <Индекс Имя="ЛицевойДатНачДатКнц" Поля="Лицевой-Сообщение,ТипАдресата,ДатНач,ДатКнц" ДопПоля=""/>
                <Индекс Имя="УкНачДатКнц" Поля="УК Договор-Сообщение,ДатНач,ДатКнц" ДопПоля=""/>
                <Индекс Имя="Соглашение-Сообщение" Поля="Соглашение-Сообщение" Выражение="&quot;Соглашение-Сообщение&quot; is not null"/>
                <Индекс Имя="Организация-Сообщение" Поля="Организация-Сообщение" Выражение="&quot;Организация-Сообщение&quot; is not null"/>
                <Индекс Имя="Текст" Тип="gin" Поля="&quot;Текст&quot; gin_trgm_ops"/>
                <Индекс Имя="Idx_Папки" Поля="Папки,Папки_add" />
            </Индексы_базы>
            <Триггеры>
                <Триггер Имя="Сообщения_в_квитанции" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql" Сущности1="Лицевой-Сообщение,Договор-Сообщение,УК Договор-Сообщение,Организация-Сообщение" Сущности2="Соглашение-Сообщение"/>
            </Триггеры>
        </Table>
