                <Поле Имя="РН документы-Услуга" Тип="Внешний ключ" Таблица="Типы услуг" При_удалении="NO ACTION" Описание="row_id из таблицы [Типы услуг], на которую сохраняем начисления"/>
                <Поле Имя="РН документы-Причина" Тип="Внешний ключ" Таблица="Аналитики" При_удалении="NO ACTION" Описание="Причина создания документа"/>
                <Поле Имя="РН документы-УК Договор" Тип="Внешний ключ" Таблица="УК Договоры" При_удалении="NO ACTION" Описание="row_id из таблицы [УК Договоры], договор на который сохраняем начисления"/>
                <Поле Имя="РН документы-Поставщик" Тип="Внешний ключ" Таблица="Организации" При_удалении="NO ACTION" Описание="row_id из таблицы [Организации], Поставщика на которого сохраняем начисления"/>
                <Поле Имя="Номер" Тип="Строка"/>
                <Поле Имя="Тариф" Тип="Вещественное" Точность="9" Опции="CtrlC " Описание="Тариф, примененный для рассчета общей суммы документа"/>
                <Поле Имя="Объем" Тип="Вещественное" Точность="9" Опции="CtrlC " Описание="Общий объем потребления, который может быть распределен по ЛС данного документа или скопирован на каждый ЛС"/>
                <Поле Имя="Сумма" Тип="Деньги" Опции="CtrlC " Описание="Сумма документа, которая может быть распределена по ЛС данного документа или скопирована на каждый ЛС"/>
                <Поле Имя="Тип" Тип="Целое"/>
                <Поле Имя="Флаги" Тип="Флаги" Поля="Учитывать в ОДПУ" Описание="Применяется при распределении"/>
                <Поле Имя="ВидРасчета" Тип="Целое" Описание="Код вида расчета, который применяется для деления или копирования объема и суммы по ЛС данного документа (деление в обработчике)"/>
