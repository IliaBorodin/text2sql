                <Поле Имя="М11" Тип="Вещественное" Точность="9" Опции="CtrlC " Описание="Ноябрь"/>
                <Поле Имя="М12" Тип="Вещественное" Точность="9" Опции="CtrlC " Описание="Декабрь"/>
                <Поле Имя="Аналитика" Тип="Строка" Описание="Не используется"/>
                <Поле Имя="ТипКалендаря" Опции="CtrlC " Размер="2" Тип="Целое" Описание="Не используется"/>
                <Поле Имя="Флаги" Тип="Флаги" Поля="Не учитывать в расчете" Описание="Учитывать/не учитывать в расчете"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="Договор-Нагрузка" Поля="Договор-Нагрузка"/>
                <Индекс Имя="Лицевой-Нагрузка" Поля="Лицевой-Нагрузка"/>
                <Индекс Имя="Год" Поля="Год, Договор-Нагрузка, Лицевой-Нагрузка"/>
            </Индексы_базы>
            <Триггеры>
                <Триггер Имя="Договорные нагрузки" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql" Сущность1="Лицевой-Нагрузка" Сущность2="Договор-Нагрузка" />
            </Триггеры>
        </Table>
        <Table Имя="Дополнительные начисления" Описание="Начисления по прочим видам деятельности, которые не относятся к основной деятельности, например плата за отключения. По данной таблице формируются комплекты документов.">
            <Поля>
                <Поле Имя="Договор" Тип="Внешний ключ" Таблица="Договор" При_удалении="SET NULL" Описание="Ссылка на договор"/>
                <Поле Имя="Лицевой" Тип="Внешний ключ" Таблица="Лицевые счета" При_удалении="SET NULL" Описание="Ссылка на лицевой"/>
                <Поле Имя="РасчМесяц" Тип="Дата" Описание="Месяц, в котором произведен расчет"/>
                <Поле Имя="Сумма" Тип="Деньги" Опции="CtrlC " Описание="Сумма с НДС"/>
                <Поле Имя="СуммаБезНДС" Тип="Деньги" Опции="CtrlC " Описание="Сумма без НДС"/>
                <Поле Имя="СтавкаНДС" Тип="Целое" Описание="Ставка ндс"/>
                <Поле Имя="Объем" Тип="Вещественное" Точность="9" Опции="CtrlC " Описание="Объем услуги"/>
                <Поле Имя="Тариф" Тип="Вещественное" Точность="9" Опции="CtrlC " Описание="Тариф"/>
                <Поле Имя="Номенклатура" Тип="Внешний ключ" Таблица="Номенклатура" При_удалении="SET NULL" Описание="Вид услуги из справочника Услуги ЮЛ"/>
                <Поле Имя="Наименования счета" Тип="Внешний ключ" Таблица="Наименования счета" При_удалении="SET NULL" Описание="Ссылка на строку документа, в которую вошли данные начисления"/>
                <Поле Имя="Состояние документа" Тип="Внешний ключ" Таблица="Состояние документа" При_удалении="SET NULL" Описание="Статус документа согласно справочнику (отправлен, подписан и т.д.)"/>
                <Поле Имя="Начисления-Акт" Тип="Внешний ключ" Таблица="Акты нарушений" При_удалении="CASCADE" Описание="Внешний ключ на таблицу Акты нарушений"/>
                <Поле Имя="ЗаМесяц" Тип="Дата" Описание="Месяц, за который произведен расчет"/>
                <Поле Имя="Тип" Тип="Целое" Размер="1" Описание="0 - начислено, 1 - сторнировано, 2 - принято к начислению ранее (ДЛЖ)"/>
                <Поле Имя="Аналитика1" Тип="Целое" Описание="Основная услуга"/>
                <Поле Имя="Аналитика2" Тип="Целое" Описание="Вид расчета"/>
                <Поле Имя="идСоглашениеРассрочки" Тип="Внешний ключ" Таблица="Соглашение рассрочки" При_удалении="CASCADE" Описание="Ссылка на соглашение"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="Договор" Поля="Договор" ДопПоля="Номенклатура"/>
                <Индекс Имя="Состояние документа" Поля="Состояние документа"/>
                <Индекс Имя="Начисления-Акт" Поля="Начисления-Акт"/>
                <Индекс Имя="идСоглашениеРассрочки" Поля="идСоглашениеРассрочки" Выражение="&quot;идСоглашениеРассрочки&quot; is not null"/>
            </Индексы_базы>
        </Table>
        <Table Имя="Документ" Описание="Таблица хранит разные бизнес-сущности (счет-фактура, платежная ведомость и т.п.), объединенные понятием документ, а так же служебные записи для реализации внутренней логики системы">
            <Поля>
                <Поле Имя="$Сумма" Тип="Вещественное" Точность="2" Опции="CtrlC " Описание="Начальные остатки по р/сч из выписки"/>
                <Поле Имя="_Автор" Тип="Внешний ключ" Таблица="Сотрудники" При_удалении="NO ACTION"/>
                <Поле Имя="Акцепт" Тип="Целое" Описание="Признак для платежных требований: списание с акцептом или без"/>
                <Поле Имя="Аналитика" Тип="Строка" Описание="Вид деятельности (основная, пени, отключения и т.п.)"/>
                <Поле Имя="Вид платежа" Тип="Перечисляемое" Поля="Электронно\nПочтой\nТелеграфом\nПо клирингу" Описание="Варианты поступления платежа"/>
                <Поле Имя="ВидСчета" Тип="Целое" Описание="Для документа с Типом=21 варианты: платежное поручение, взаимозачет, оплата не деньгами и т.п."/>
                <Поле Имя="Группа нумерации" Тип="Целое" Описание="При создании нового документа ищется документ с максимальным номером из его платежной группы, новому документу дается номер на единицу больше"/>
                <Поле Имя="Дата" Тип="Дата" Размер="2" Описание="Дата документа"/>
                <Поле Имя="Время" Тип="ДатаВремя" Размер="4" Шаблон="дд.мм.гггг чч:мм:cc" Значение_по_умолчанию_PostgreSQL="now()" Описание="Используется для Актов снятия качества"/>
                <Поле Имя="Документы-Договор" Тип="Внешний ключ" Таблица="Договор" При_удалении="NO ACTION" Описание="Связь с договорами юридических лиц"/>
                <Поле Имя="Документы-УКДоговор" Тип="Внешний ключ" Таблица="УК Договоры" При_удалении="NO ACTION" Описание="Связь с договорами договорами с УК"/>
                <Поле Имя="Источник-Платежи" Тип="Внешний ключ" Таблица="Организации" При_удалении="NO ACTION" Описание="Источником платежей для платежных ведомостей"/>
                <Поле Имя="Кол_во" Тип="Целое" Опции="CtrlC " Описание="Для разных документов: - суммарный объем документа (например, для счетов-фактур); - количество записей - деталей документа (например, кол-во платежей в платежной ведомости);"/>
                <Поле Имя="Контрагент ФИО" Тип="Строка" Описание="Для программы Касса - ФИО сотрудника, создавшего документ (ПКО, РКО)"/>
                <Поле Имя="Контрагент документ" Тип="Строка" Описание="Для программы Касса - данные документа, удостоверяющего личность сотрудника, создавшего документ (ПКО, РКО)"/>
                <Поле Имя="Курс" Тип="Вещественное" Точность="4" Описание="не используется"/>
                <Поле Имя="Лицо1" Тип="Внешний ключ" Таблица="Организации" При_удалении="NO ACTION" Описание="Для листа соответствтует полю плательщик из таблицы договор. Для узла - сылка на организацию - продавца"/>
                <Поле Имя="Лицо2" Тип="Внешний ключ" Таблица="Организации" При_удалении="NO ACTION" Описание="Для листа соответствтует полю грузополучатель из таблицы договор. Для узла - сылка на организацию - грузоотправителя"/>
                <Поле Имя="Лицо3" Тип="Внешний ключ" Таблица="Организации" При_удалении="NO ACTION" Описание="Для листа соответствтует полю заказчик из таблицы договор."/>
                <Поле Имя="Документы-Контролер" Тип="Внешний ключ" Таблица="Сотрудники" При_удалении="NO ACTION"/>
                <Поле Имя="Наш р/с-Платежи" Тип="Внешний ключ" Таблица="Расчетные счета" При_удалении="NO ACTION" Описание="Расчетный счет продавца, на который поступили денежные средства"/>
                <Поле Имя="Номер" Тип="Целое" Описание="Номер документа"/>
                <Поле Имя="Полный номер" Тип="Строка" Описание="Полный номер документа"/>
                <Поле Имя="Окончания срок" Тип="Дата" Размер="2" Описание="Признак виртуального документа, который не должен участвовать в отчетности, но служит для некоторых операций"/>
                <Поле Имя="Очередность" Тип="Целое" Описание="Служебное поле. Используется в программе Касса при формировании кассовой книги"/>
                <Поле Имя="Папки" Тип="Иерархия" Опции="BreakDelete " Описание="Иерархическая связь - служит для пользовательских группировок документов в реестрах"/>
