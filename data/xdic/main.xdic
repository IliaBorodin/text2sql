        <Table Имя="ЦентрУведомленийКампании" Описание="Кампании для рассылки уведомлений по СМС, Push, Автообзон, Email">
            <Поля>
                <Поле Имя="Статус" Тип="Перечисляемое" Поля="Новая\nГотова к запуску\nВ работе\nПауза\nЗавершена\nОшибка\nОтменена" Описание="Статус"/>
                <Поле Имя="ПопыткиОтправить" Тип="Целое" Описание="Номер по порядку попытки отправки"/>
                <Поле Имя="История" Тип="xml" Описание="История запусков компании в формате xml"/>
                <Поле Имя="Папки" Тип="Иерархия" Опции="CascadeDelete " Описание="Указатель на родительскую запись в иерархии"/>
                <Поле Имя="ИД_Шаблон" Тип="Внешний ключ" Таблица="ЦентрУведомленийШаблоны" При_удалении="NO ACTION" При_обновлении="NO ACTION" Описание="Идентификатор шаблона сообщений, указатель на запись в таблице ЦентрУведомленийШаблоны"/>
                <Поле Имя="Номер" Тип="Целое" Описание="Номер кампании"/>
                <Поле Имя="Название" Тип="Строка" Описание="Название кампании"/>
                <Поле Имя="Комментарий" Тип="Строка" Описание="Описание кампании"/>
                <Поле Имя="ВремяНач" Тип="ДатаВремя" Размер="2" Шаблон1="чч:мм" Описание="Время начала кампании"/>
                <Поле Имя="ВремяКнц" Тип="ДатаВремя" Размер="2" Шаблон1="чч:мм" Описание="Время окончания кампании"/>
                <Поле Имя="Автор" Тип="Внешний ключ" Таблица="Сотрудники" При_удалении="NO ACTION" Описание="ИД Сотрудника, создавшего кампанию"/>
                <Поле Имя="Отправитель" Тип="Строка" Описание="Отправитель"/>
                <Поле Имя="Попыток" Тип="Целое" Описание="Кол-во попыток отправки уведомлений"/>
                <Поле Имя="ТипПолучателя" Тип="Перечисляемое" Поля="Лицевые счета\nПретензионная работа ФЛ\nДоговоры ЮЛ\nПретензионная работа ЮЛ\nУведомления ограничения первичное\nУведомления ограничения вторичное\nУведомление о возобновлении" Описание="Тип получателя"/>
                <Поле Имя="ВнешнийИД" Тип="Строка" Описание="Идентификатор внешнего сервиса"/>
                <Поле Имя="Задача" Тип="Целое" Описание="Код задачи в которой была создана кампания"/>
                <Поле
                    Имя="ВариантДатыЛК"
                    Тип="Перечисляемое"
                    Поля="Дата последнего статуса\nДата кампании"
                    Описание="Вариант отображения даты сообщения в ЛКК"
                />
                <Поле
                    Имя="НеАктивноЛК"
                    Тип="Целое"
                    Описание="Настройка отображения кампании в ЛК"
                    Значение_по_умолчанию="0"
                />
                <Поле
                    Имя="СрокЖизниЛК"
                    Тип="Целое"
                    Описание="Срок отображения кампании в ЛК в днях, 0 или null -  бессрочная"
                />
                <Поле Имя="ТемаEmail" Тип="Строка" />
                <Поле Имя="ДатаСоздания" Тип="ДатаВремя" Описание="Когда создан реквест" />
            </Поля>
            <Триггеры>
                <Триггер Имя="ЦентрУведомленийКампании" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql" Сущность1="ИД_Шаблон" НелогПоля="История"/>
            </Триггеры>
            <Индексы_базы>
                <Индекс Имя="ИД_Шаблон" Поля="ИД_Шаблон"/>
                <Индекс Имя="Статус" Поля="row_id,Статус"/>
                <Индекс Имя="Задача" Поля="Задача"/>
                <Индекс Имя="Папки" Поля="Папки"/>
            </Индексы_базы>
        </Table>
        <Table Имя="ЦентрУведомленийШаблоны" Описание="Шаблоны центра уведомлений">
            <Поля>
                <Поле Имя="Папки" Тип="Иерархия" Опции="CascadeDelete " Описание="Указатель на родительскую запись в иерархии"/>
                <Поле Имя="Название" Тип="Строка" Описание="Название шаблона"/>
                <Поле Имя="Комментарий" Тип="Строка" Длина="1000" Описание="Описание шаблона"/>
                <Поле Имя="Текст" Тип="Строка" Длина="3000" Описание="Шаблон для уведомлений"/>
                <Поле Имя="Транспорт" Тип="Целое" Описание="Возможные типы транспорта для этого шаблона"/>
                <Поле Имя="Архивный" Тип="Флаги" Поля="Действует\nНе действует" Описание="Флаг действующего шаблона"/>
                <Поле Имя="Шаблон-Транспорт" Тип="Внешний ключ" Таблица="ЦентрУведомленийТранспорт" При_удалении="NO ACTION" При_обновлении="NO ACTION" Описание="Идентификатор транспорта"/>
                <Поле Имя="ТемаEmail" Тип="Строка"/>
            </Поля>
