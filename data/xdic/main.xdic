        <Table Имя="НКЛьгота" Вид="Служебная" Раздел="RANGE (&quot;Месяц расчета&quot;)" Категория="Начислительные" Описание="Перерасчеты компенсаций по актам недопоставки для ЛС биллинга физических лиц">
            <Поля>
                <Поле Имя="Счет" Тип="Целое" Описание="row_id ЛС из таблицы [Лицевые счета]"/>
                <Поле Имя="Месяц расчета" Тип="Дата" Размер="4" Длина="16" MSSQL="smalldatetime" Описание="Месяц расчета"/>
                <Поле Имя="Перерасчет" Тип="Дата" Размер="4" Длина="16" MSSQL="smalldatetime" Описание="Месяц, за который сделан перерасчет"/>
                <Поле Имя="Номер льготы" Тип="Целое" Размер="2" Описание="Номер льготы из справочника [Виды льгот]"/>
                <Поле Имя="Номер услуги" Тип="Целое" Описание="Номер услуги из справочника [Типы услуг]"/>
                <Поле Имя="Объем" Тип="Вещественное" Описание="объем перерасчета"/>
                <Поле Имя="Сумма" Тип="Вещественное" Описание="Сумма перерасчета компенсации"/>
                <Поле Имя="Поставщик" Тип="Целое" Описание="row_id поставщика услуги из таблицы [Организации]"/>
                <Поле Имя="Акт качества" Тип="Целое" Описание="row_id акта недопоставки (качества) из таблицы [Документ] (в таблице [Документ] Тип Документа = 71)"/>
                <Поле Имя="Документ" Тип="Целое" Описание="row_id льготы из таблицы [Льготы]"/>
                <Поле Имя="Пользователи" Тип="Целое" Размер="1" Описание="Кол-во пользователей (членов семьи, которым предоставляется льгота)"/>
                <Поле Имя="ИспользованТариф" Тип="Вещественное" Описание="Тариф, использованный при расчете суммы"/>
                <Поле Имя="ИспользованаНорма" Тип="Вещественное" Описание="Норматив потребления для данного ЛС по этой услуге (заполняется и при расчете по ПУ)"/>
                <Поле Имя="Аналитика1" Тип="Целое" Описание="Доп.данные (инсталляционно: номер услуги с которой производится расчет)"/>
                <Поле Имя="ДоговорУК" Тип="Целое" Описание="row_id договора (с УК или прямого) из таблицы [УК Договоры]"/>
                <Поле Имя="Аналитика2" Тип="Целое" Описание="Вид начисления данной услуги"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="МесяцСчет" Поля="Месяц расчета, Счет"/>
                <Индекс Имя="СчетМесяц" Поля="Счет, Месяц расчета, Перерасчет"/>
            </Индексы_базы>
            <Индексы/>
            <Триггеры>
                <Триггер Имя="НКЛьгота" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql" ИнфоПоля="Счет, Акт качества, Номер льготы, Номер услуги, Месяц расчета, Перерасчет" Сущности1="[{&quot;Поле&quot;:&quot;Счет&quot;,&quot;Таблица&quot;:&quot;Лицевые счета&quot;}]"/>
            </Триггеры>
            <Политики>
                <Политика Имя="AP_Post" Файл="НКЛьгота_Select_AP_Post.sql"/>
            </Политики>
        </Table>
        <Table Имя="НКТариф" Вид="Служебная" Раздел="RANGE (&quot;Месяц расчета&quot;)" Категория="Начислительные" Описание="Перерасчеты начислений по актам недопоставки (качества) для ЛС биллинга физических лиц">
            <Поля>
                <Поле Имя="Счет" Тип="Целое" Описание="row_id ЛС из таблицы [Лицевые счета]"/>
                <Поле Имя="Месяц расчета" Тип="Дата" Размер="4" Длина="16" MSSQL="smalldatetime" Описание="Месяц, в котором сделан перерасчет"/>
                <Поле Имя="Перерасчет" Тип="Дата" Размер="4" Длина="16" MSSQL="smalldatetime" Описание="Месяц, за который сделан перерасчет"/>
                <Поле Имя="Номер услуги" Тип="Целое" Описание="Номер услуги из справочника [Типы услуг]"/>
                <Поле Имя="Объем" Тип="Вещественное" Описание="Объем перерасчета (разница потребленного объема за месяц перерасчета по новым данным и сохранненных ранее)"/>
