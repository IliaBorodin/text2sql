            <Поля>
                <Поле Имя="идБизнесПроцессы" Тип="Внешний ключ" Таблица="Бизнес процессы" При_удалении="CASCADE" Описание="Указатель на бизнес процесс"/>
                <Поле Имя="СсылкаНаИнициатора" Тип="Строка" Описание="Обратный путь к ресурсу инициатора бизнес процесса во внешней системе (полный/частичный)"/>
                <Поле Имя="Адрес" Тип="Строка" Описание="Целевой адрес заявки"/>
