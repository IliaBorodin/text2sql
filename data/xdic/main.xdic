                <Поле Имя="Приватный" Тип="Целое" Описание="(для бп): 0 - доступен всем, 1 - доступен исполнителям, 2 - доступен исполнителям и выбранным сотрудникам"/>
                <Поле Имя="Служебный" Тип="Целое" Размер="1" PostgreSQL="boolean" Значение_по_умолчанию="0" Значение_по_умолчанию_PostgreSQL="false" Описание="0 - обычный трекер, 1 - служебный трекер"/>
                <Поле Имя="Настройки" Тип="Строка" PostgreSQL="jsonb"/>
                <Поле Имя="ВерсияЗафиксирована" Тип="Целое" PostgreSQL="boolean" Значение_по_умолчанию_PostgreSQL="false" Описание= "0 - новая версия, 1 - версия зафиксирована"/>
                <Поле Имя="СледующаяВерсия" Тип="Внешний ключ" Таблица="ДО маршруты" При_удалении="SET NULL" />
                <Поле Имя="ПерваяВерсия" Тип="Внешний ключ" Таблица="ДО маршруты" При_удалении="NO ACTION" Описание="Необходимо для получения списка всех версий" />
                <Поле Имя="ДатаСоздания" Тип="Дата" Значение_по_умолчанию_PostgreSQL="now()" />
                <Поле Имя="Статус" Тип="Целое" Описание="0 - активный, 1 - неактивный"/>
                <Поле Имя="Категория" Тип="Внешний ключ" Таблица="КатегорииБП" Описание="Указатель на категорию БП" />
            </Поля>
            <Индексы_базы>
                <Индекс Имя="ПерваяВерсия" Поля="ПерваяВерсия" />
                <Индекс Имя="СледующаяВерсия" Поля="СледующаяВерсия" />
