                <Поле Имя="Номер" Тип="Целое" Описание="Номер платежа"/>
                <Поле Имя="Полный номер" Тип="Строка" Описание="Полный номер"/>
                <Поле Имя="Дата" Тип="Дата" Размер="2" Описание="Дата платежа"/>
                <Поле Имя="ДатаВозврата" Тип="Дата" Размер="2" Описание="Дата возврата платежа контрагенту"/>
                <Поле Имя="Проблемные документы-Выписка" Тип="Внешний ключ" Таблица="Документ" При_удалении="CASCADE" Описание="Выписка, в которой находится платеж"/>
                <Поле Имя="Проблемные документы-РСчет" Тип="Внешний ключ" Таблица="Расчетные счета" При_удалении="NO ACTION" Описание="Ссылка на расчетный счет"/>
                <Поле Имя="Проблемные документы-Лицо1" Тип="Внешний ключ" Таблица="Организации" При_удалении="NO ACTION" Описание="Ссылка на плательщика"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="Проблемные документы-В" Поля="Проблемные документы-Выписка"/>
                <Индекс Имя="Проблемные документы-Д" Поля="Проблемные документы-Договор"/>
                <Индекс Имя="Проблемные документы-Л" Поля="Проблемные документы-Лицо1"/>
