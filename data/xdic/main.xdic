            <Ограничения>
                <Ограничение Тип="CHECK" Имя="CH_Часы максимальной мощности" Выражение="((&quot;Час&quot; >= 0) AND (&quot;Час&quot; &lt;= 23))" />
            </Ограничения>
        </Table>
