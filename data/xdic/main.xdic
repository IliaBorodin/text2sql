            </Индексы_базы>
            <Триггеры>
                <Триггер Имя="Потр_по_лс" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql" Сущность1="Потребление-Лицевой"/>
                <Триггер Имя="Потребление_по_ЛС_BF_ALLTRIG" Версия="1" Файл="Потребление_по_ЛС_BF_INSTRIG.sql"/>
            </Триггеры>
        </Table>
        <Table Имя="Тепловой расчет" Описание="Плановый расчет по договору для РСО">
            <Поля>
