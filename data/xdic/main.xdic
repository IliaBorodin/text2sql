        <Table Имя="Список ответчиков" Описание="Хранит ответчиков, по которым ведётся дело, а так же иных лиц, причастных к делу (включая иных истцов)">
            <Поля>
                <Поле Имя="Адрес" Тип="Строка" Описание="Адрес ответчика"/>
                <Поле Имя="Группировка" Тип="Целое" Описание="Служебное поле: хранит основание для генерации - или опекаемый или опекун"/>
                <Поле Имя="Дата рождения" Тип="Дата" Размер="2" Описание="Дата рождения ответчика"/>
                <Поле Имя="Доля" Тип="Строка" Описание="Доля ответчика в виде дроби"/>
                <Поле Имя="Доля_знаменатель" Тип="Целое" Описание="Знаменатель дроби доли владения"/>
                <Поле Имя="Доля_числитель" Тип="Целое" Описание="Числитель дроби доли владения"/>
                <Поле Имя="ДопИнформация" Тип="Строка" Описание="Краткое текстовое примечание"/>
                <Поле Имя="ИД_Сторонний" Тип="Строка" Описание="Поле для конвертации"/>
