            <Триггеры>
                <Триггер Имя="ЦентрУведомленийТранспорт" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql"/>
            </Триггеры>
        </Table>
        <Table Имя="ЦентрУведомленийПараметры" Описание="Перечень параметров для шаблона">
