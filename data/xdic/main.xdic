                <Поле Имя="Ответ" Тип="Строка" Длина="7000" Описание="Ответ на запрос"/>
                <Поле Имя="Автор" Тип="Внешний ключ" Таблица="Сотрудники" Описание="Ссылка на сотрудника выполнившего операцию" />
            </Поля>
