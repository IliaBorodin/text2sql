                <Поле Имя="Составной" Тип="Целое" Размер="1" PostgreSQL="boolean" Описание="Признак составного тега"/>
                <Поле Имя="Диалог" Тип="Строка" Описание="Имя диалога на фронте для ввода составной части параметра"/>
            </Поля>
        </Table>
