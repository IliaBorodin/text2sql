                <Поле Имя="Файл-Задание" Тип="Внешний ключ" Таблица="ДО карточки" При_удалении="CASCADE" Описание="Не используется"/>
                <Поле Имя="Файл-Организация" Тип="Внешний ключ" Таблица="Организации" При_удалении="CASCADE" Описание="Не используется"/>
                <Поле Имя="Скачано" Тип="Целое" Описание="Признак, что файл был скачан с SD клиентом"/>
                <Поле Имя="Дата изменения" Тип="Дата" Размер="2"/>
                <Поле Имя="Время изменения" Тип="Время" Размер="4"/>
                <Поле Имя="Признаки" Тип="Флаги" Поля="Временный\nВнутренний\nПодписываемый"/>
                <Поле Имя="Файл-Связка" Тип="Внешний ключ" Таблица="Файлы" При_удалении="CASCADE" Описание="Указатель на файл"/>
                <Поле Имя="ДатНач" Тип="Дата" Размер="2"/>
                <Поле Имя="ДатКнц" Тип="Дата" Размер="2"/>
                <Поле Имя="Комментарий" Тип="Строка"/>
                <Поле Имя="Подпись" Тип="xml" Описание="ЭЦП к файлу"/>
                <Поле Имя="Наименование" Тип="Строка" Длина="500" Описание="Не используется"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="Файл-Карточка" Поля="Файл-Карточка" ДопПоля="Новый файл"/>
                <Индекс Имя="Файл-Задание" Поля="Файл-Задание" ДопПоля=""/>
                <Индекс Имя="Файл-Связка" Поля="Файл-Связка" ДопПоля=""/>
