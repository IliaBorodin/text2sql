                <Поле Имя="Название" Тип="Строка" Описание="Название маршрута"/>
                <Поле Имя="Маршрут-Ящик" Тип="Внешний ключ" Таблица="Сообщения Заголовок" При_удалении="SET NULL" Описание="Указатель на исходящий почтовый ящих для писем по заявке"/>
                <Поле Имя="Признаки" Тип="Флаги" Поля="1-БизнесПроцесс"/>
