        <Table Имя="Бизнес процессы" Описание="Бизнес-процессы">
            <Поля>
                <Поле Имя="Автор" Тип="Внешний ключ" Таблица="Сотрудники" При_удалении="NO ACTION" Описание="Указатель на сотрудника, создавшего процесс/работу"/>
                <Поле Имя="Создан" Тип="ДатаВремя"/>
                <Поле Имя="Обновлен" Тип="ДатаВремя"/>
                <Поле Имя="Завершен" Тип="ДатаВремя" Описание="Дата/время завершения"/>
                <Поле Имя="Маршрут" Тип="Внешний ключ" Таблица="ДО маршруты" При_удалении="NO ACTION" Описание="Указатель на трекер процесса/работы"/>
                <Поле Имя="Номер" Тип="Целое" Опции="CtrlC " Описание="Номер процесса"/>
                <Поле Имя="Папки" Тип="Иерархия" Опции="CascadeDelete " Описание="Папка"/>
                <Поле Имя="Примечание" Тип="Строка" Длина="9000" Описание="Примечание"/>
                <Поле Имя="Тема" Тип="Строка"/>
                <Поле Имя="Владелец" Тип="Внешний ключ" Таблица="Сотрудники" При_удалении="NO ACTION" Описание="Указатель на сотрудника-владельца процесса/работы"/>
                <Поле Имя="Ответственный" Тип="Внешний ключ" Таблица="Сотрудники" При_удалении="NO ACTION" Описание="Указатель на ответственного сотрудника"/>
                <Поле Имя="Статус" Тип="Перечисляемое" Поля="Активен\nВыполнен\nОтменен\nПрерван" Описание="Статус бизнес процесса"/>
                <Поле Имя="Чеклист" Тип="Строка" PostgreSQL="jsonb"/>
                <Поле Имя="Исполнители" Тип="Строка" PostgreSQL="jsonb"/>
                <Поле Имя="Дедлайн" Тип="ДатаВремя"/>
                <Поле Имя="Настройки" Тип="Строка" PostgreSQL="jsonb"/>
                <Поле Имя="ДанныеПерехода" Тип="Строка" PostgreSQL="jsonb" Описание="Хранит привязку работы к определенному статусу маршрута"/>
                <Поле Имя="Группа" Тип="Внешний ключ" Таблица="ДО группы" При_удалении="NO ACTION" Описание="Указатель на ответственную группу" />
                <Поле Имя="Приватный" Тип="Целое" Описание="0 - доступен всем, 1 - доступен исполнителям, 2 - доступен исполнителям и выбранным сотрудникам"/>
                <Поле Имя="ШаблонРаботы" Тип="Целое" Размер="1" Описание="Указатель на шаблон. Перечислены в классе ШаблоныРабот" />
                <Поле Имя="СтатусРаботы" Тип="Целое" />
                <Поле Имя="СозданныйБП" Тип="Внешний ключ" Таблица="Бизнес процессы" При_удалении="NO ACTION" Описание="Бизнес процесс который запустила эта операция" />
                <Поле Имя="Операция" Тип="Внешний ключ" Таблица="ОперацииФаз" При_удалении="NO ACTION" Описание="Указатель на настройки операции" />
                <Поле Имя="Фаза" Тип="Внешний ключ" Таблица="ДО фазы" При_удалении="NO ACTION" Описание="Указатель на текущую операцию" />
                <Поле Имя="РодительскаяРабота" Тип="Внешний ключ" Таблица="Бизнес процессы" При_удалении="NO ACTION" Описание="Указатель какая работа является родителем" />
                <Поле Имя="КомментарийРуководителя" Тип="Строка" Длина="9000" Описание="Комментарий руководителя по работе" />
                <Поле Имя="КомментарийИсполнителя" Тип="Строка" Длина="9000" Описание="Комментарий о проделанной работе" />
                <Поле Имя="Сотрудник" Тип="Внешний ключ" Таблица="Сотрудники" При_удалении="NO ACTION" Описание="Указатель на сотрудника по которому инициировали БП"/>
                <Поле Имя="ЗонаОтветственностиТип" Тип="Строка" Описание="Тип зоны ответственности"/>
                <Поле Имя="ЗонаОтветственностиЗначение" Тип="Целое"/>
                <Поле Имя="идИсточник" Тип="Внешний ключ" Таблица="ИсточникиЗаявок" При_удалении="NO ACTION" Описание="Указатель на источник, из которого инициировали БП"/>
                <Поле Имя="идКонтрагент" Тип="Внешний ключ" Таблица="Контрагенты" При_удалении="SET NULL" Описание="Указатель на организацию, которой пренадлежит заявка"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="Автор" Поля="Автор"/>
                <Индекс Имя="Маршрут" Поля="Маршрут"/>
                <Индекс Имя="Владелец" Поля="Владелец"/>
                <Индекс Имя="Ответственный" Поля="Ответственный"/>
                <Индекс Имя="Группа" Поля="Группа"/>
                <Индекс Имя="Завершен" Поля="Завершен"/>
                <Индекс Имя="Сотрудник" Поля="Сотрудник"/>
                <Индекс Имя="ЗонаОтветственности" Поля="ЗонаОтветственностиТип, ЗонаОтветственностиЗначение"/>
                <Индекс Имя="СозданныйБП" Поля="СозданныйБП"/>
                <Индекс Имя="идИсточник" Поля="идИсточник"/>
                <Индекс Имя="РодительскаяРабота" Поля="РодительскаяРабота"/>
                <Индекс Имя="НомерТекст" Тип="gin" Поля="((&quot;Номер&quot;)::text) gin_trgm_ops"/>
            </Индексы_базы>
            <Триггеры>
                <Триггер Имя="Бизнес_процессы" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql" />
            </Триггеры>
            <Политики>
                <Политика Имя="bp_RLS" Файл="БП_Select_RLS.sql"/>
            </Политики>
        </Table>
        <Table Имя="ОперацииФаз" Описание="Операции на фазе">
