                <Поле Имя="ПокНач" Тип="Вещественное" Описание="предыдущее показание"/>
                <Поле Имя="ПокКнц" Тип="Вещественное" Описание="текущиее показание"/>
                <Поле Имя="Расход" Тип="Вещественное" Описание="разница показания"/>
