        <Table Имя="Связи лицевого" Описание="Связи точек учета (субабоненты)">
            <Поля>
                <Поле Имя="Главный лицевой" Тип="Внешний ключ" Таблица="Лицевые счета" При_удалении="CASCADE" Описание="Головная точка учета"/>
                <Поле Имя="Подчиненный лицевой" Тип="Внешний ключ" Таблица="Лицевые счета" При_удалении="CASCADE" Описание="Подчиненная точка учета (вычитаемая из головной или получающая % от объема"/>
                <Поле Имя="ДатНач" Тип="Дата" Размер="2" Опции=" NotNULL" Описание="Дата начала действия связи"/>
                <Поле Имя="ДатКнц" Тип="Дата" Размер="2" Опции=" NotNULL" Описание="Дата окончания действия связи"/>
                <Поле Имя="_Тип связи счетчиков" Тип="Перечисляемое" Размер="1" Поля="Счетчик подчиненный\nСвязанный счетчик\nВ % подчиненный\nСуммируемый главный счетчик\nРаспределение потребления по площади\nРаспределение потребления по проектной нагрузке\nНачисления ФЛ по дому"/>
                <Поле Имя="Параметры связи" Тип="Флаги" Поля="Вычитается Активная составляющая\nВычитается Реактивная составляющая\nПотери у главного счетчика считаются до вычитания\nРеактивная мощность у главного счетчика считается до вычитания" Описание="Функция ПодчиненнаяТУ_ПолучитьСписокПараметровСвязи( _видПотр ) "/>
                <Поле Имя="Процент отчислений" Тип="Вещественное" Точность="3" Описание="Процент применяемый к объему"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="ACC_LINKS" Поля="Главный лицевой, ДатНач, ДатКнц" ДопПоля="Подчиненный лицевой, _Тип связи счетчиков, Параметры связи, Процент отчислений"/>
                <Индекс Имя="ПодчиненныйЛС" Поля="Подчиненный лицевой, ДатНач, ДатКнц" ДопПоля="Главный лицевой, _Тип связи счетчиков, Параметры связи, Процент отчислений"/>
            </Индексы_базы>
            <Триггеры>
                <Триггер Имя="Связи лицевого" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql" Сущность1="Главный лицевой" Сущность2="Подчиненный лицевой"/>
                <Триггер Имя="Связи_лицевого_BF_ALLTRIG" Версия="2" Файл="Связи лицевого_BF_INSTRIG.sql"/>
            </Триггеры>
        </Table>
