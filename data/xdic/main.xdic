                <Поле Имя="Лимиты-Услуга" Тип="Внешний ключ" Таблица="Типы услуг" При_удалении="SET NULL" Описание="Ссылка на справочник [Типы услуг]"/>
                <Поле Имя="М01" Тип="Вещественное" Точность="9" Опции="CtrlC " Описание="январь"/>
                <Поле Имя="М02" Тип="Вещественное" Точность="9" Опции="CtrlC " Описание="февраль"/>
                <Поле Имя="М03" Тип="Вещественное" Точность="9" Опции="CtrlC " Описание="март"/>
                <Поле Имя="М04" Тип="Вещественное" Точность="9" Опции="CtrlC " Описание="апрель"/>
                <Поле Имя="М05" Тип="Вещественное" Точность="9" Опции="CtrlC " Описание="май"/>
                <Поле Имя="М06" Тип="Вещественное" Точность="9" Опции="CtrlC " Описание="июнь"/>
                <Поле Имя="М07" Тип="Вещественное" Точность="9" Опции="CtrlC " Описание="июль"/>
                <Поле Имя="М08" Тип="Вещественное" Точность="9" Опции="CtrlC " Описание="август"/>
                <Поле Имя="М09" Тип="Вещественное" Точность="9" Опции="CtrlC " Описание="сентябрь"/>
                <Поле Имя="М10" Тип="Вещественное" Точность="9" Опции="CtrlC " Описание="октябрь"/>
                <Поле Имя="М11" Тип="Вещественное" Точность="9" Опции="CtrlC " Описание="ноябрь"/>
                <Поле Имя="М12" Тип="Вещественное" Точность="9" Опции="CtrlC " Описание="декабрь"/>
                <Поле Имя="Примечание" Тип="Строка" Описание="Примечание"/>
                <Поле Имя="Тип" Тип="Целое" Описание="Не используется"/>
                <Поле Имя="ВидЛимита" Тип="Перечисляемое" Поля="план\nфакт\nдоп"/>
                <Поле Имя="ДатНач" Тип="Дата" Размер="2" Описание="Дата начала действия"/>
                <Поле Имя="ДатКнц" Тип="Дата" Размер="2" Описание="Дата окончания действия"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="Год" Поля="Год, Лимиты-Договор"/>
            </Индексы_базы>
            <Триггеры>
                <Триггер Имя="Лимиты" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql" Сущность1="Лимиты-Лицевой" Сущность2="Лимиты-Договор" />
            </Триггеры>
        </Table>
        <Table Имя="Лицевые договора" Описание="Точки учета, входящие в договор. Точка учета может переходить из одного договора в другой.">
            <Поля>
                <Поле Имя="Договор" Тип="Внешний ключ" Таблица="Договор" При_удалении="CASCADE" Описание="Ссылка на договор"/>
                <Поле Имя="Лицевой" Тип="Внешний ключ" Таблица="Лицевые счета" При_удалении="CASCADE" Описание="Ссылка на точку учета"/>
                <Поле Имя="Объект" Тип="Внешний ключ" Таблица="Объекты договора" При_удалении="CASCADE" Описание="Ссылка на на объект договора (группа точек учета)"/>
                <Поле Имя="Сортировка" Тип="Целое" Описание="Поле сортировки для вывода в точек учета в отчеты"/>
                <Поле Имя="ДатНач" Тип="Дата" Размер="2" Описание="Дата вхождения в договор"/>
                <Поле Имя="ДатКнц" Тип="Дата" Размер="2" Описание="Дата выхода из договора"/>
                <Поле Имя="Флаги" Тип="Целое" Описание="Не используется"/>
                <Поле Имя="Комментарий" Тип="Строка" Описание="Комментарий"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="DOG" Поля="Договор, ДатНач, ДатКнц" ДопПоля="Лицевой"/>
                <Индекс Имя="OBJ" Поля="Объект" ДопПоля="ДатНач, ДатКнц"/>
                <Индекс Имя="LS" Поля="Лицевой" ДопПоля="ДатНач, ДатКнц"/>
            </Индексы_базы>
            <Триггеры>
                <Триггер Имя="Лицевые_договора" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql" Сущность1="Лицевой" Сущность2="Договор" />
                <Триггер Имя="Лицевые_договора_BF_ALLTRIG" Версия="2" Файл="Лицевые договора_BF_INSTRIG.sql"/>
            </Триггеры>
        </Table>
        <Table Имя="Объекты договора" Описание="Группировка точек учета внтури договора">
            <Поля>
                <Поле Имя="Договор" Тип="Внешний ключ" Таблица="Договор" При_удалении="CASCADE" Описание="Ссылка на договор"/>
                <Поле Имя="Тип" Тип="Целое" Опции="CtrlC " Описание="Не используется"/>
                <Поле Имя="Название" Тип="Строка" Описание="Название"/>
                <Поле Имя="Комментарий" Тип="Строка" Описание="Комментарий"/>
            </Поля>
            <Триггеры>
                <Триггер Имя="Объекты_договора" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql" Сущность1="Договор" />
            </Триггеры>
        </Table>
        <Table Имя="Лицевые графика" Описание="Лицевые счета привязанные к графику после отбора">
            <Поля>
                <Поле Имя="Лицевые-График" Тип="Внешний ключ" Таблица="График обхода" При_удалении="CASCADE" Описание="Ссылка на график обхода"/>
                <Поле Имя="График-Счет" Тип="Внешний ключ" Таблица="Лицевые счета" При_удалении="SET NULL" Описание="Ссылка на лицевой счет"/>
                <Поле Имя="Лицевые-Реестр" Тип="Внешний ключ" Таблица="Реестры" При_удалении="SET NULL" Описание="Ссылка на реестр лицевых счетов"/>
                <Поле Имя="Флаги" Тип="Целое" Описание="Не используется"/>
                <Поле Имя="Примечание" Тип="Строка"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="Лицевые-График" Поля="Лицевые-График" />
                <Индекс Имя="График-Счет" Поля="График-Счет" />
                <Индекс Имя="Лицевые-Реестр" Поля="Лицевые-Реестр" />
            </Индексы_базы>
        </Table>
        <Table Имя="Лицевые счета" Описание="Информация об объектах учета: домах, лицевых счетах, а так же прочих объектах, которые помогают организовать адресную иерархию (квартиры, улицы, населенные пункты) и иерархию по структурным подразделениям (линейный участок, район), и прочих объектах (офис, помещение, земельный участок)">
            <Поля>
                <Поле Имя="АдресЛС" Тип="Текст" Размер="255" Описание="Адрес лицевого счета, собранный в строку. Используется для быстрой обработки"/>
                <Поле Имя="Архив" Тип="Дата" Размер="4" Описание="Признак архивного лицевого. Запись не отображается во всех функциональных программах комплекса, кроме АРМ Администратора"/>
                <Поле Имя="Блокировка изменений" Тип="Целое" Описание="не используется"/>
                <Поле Имя="Группа потребителей" Тип="Целое" Опции="CtrlC " Описание="не используется"/>
                <Поле Имя="ДопПримечание" Тип="Текст" Размер="255" Описание="Пользовательское примечание"/>
                <Поле Имя="Доступ" Тип="Строка" Описание="не используется"/>
                <Поле Имя="ЖКО" Тип="Строка" Описание="не используется"/>
                <Поле Имя="Кадастровый номер" Тип="Строка" Описание="Кадастровый номер. Используется в программе Подомовой учет"/>
                <Поле Имя="Код строения" Тип="Целое" Описание="Код для интеграции со сторонними системами"/>
                <Поле Имя="Месяц блокировки" Тип="Дата" Размер="2" Описание="Последний заблокированный месяц расчета для данного лицевого счета (используется в процедурах закрытия месяца по частям)"/>
                <Поле Имя="Начисления с" Тип="Дата" Размер="2" Описание="Определяет расчетный период, по который включительно разрешены автоматические перерасчеты. Перерасчеты за более ранние периоды вносятся только вручную. Используется, когда в единую базу данных разные части фонда вносятся в разное время"/>
                <Поле Имя="Напряжение" Тип="Текст" Размер="4" Описание="не используется"/>
                <Поле Имя="Номер" Тип="Длинное целое" Описание="Для лицевого счета - номер лс, для дома - числовая часть номера дома, для квартиры - числовая часть номера квартиры и т.д. Назначение данного поля меняется в зависимости от содержимого поля Тип. В любом случае это поле определяет сортировку записей на экране (записи располагаются по возрастанию значения в данном поле). Для районов, линейных участков, улиц это поле используется только для сортировки на экране."/>
                <Поле Имя="Подразделение" Тип="Целое" Опции="CtrlC " Описание="не используется"/>
                <Поле Имя="Подъезд" Тип="Целое" Опции="CtrlC " Описание="Номер подъезда"/>
                <Поле Имя="Последний этаж" Тип="Целое" Опции="CtrlC " Описание="Признак последнего этажа"/>
                <Поле Имя="Примечание" Тип="Строка" Описание="Пользовательское примечание"/>
                <Поле Имя="Райгаз" Тип="Строка" Описание="не используется"/>
                <Поле Имя="Счет-Аналитика1" Тип="Внешний ключ" Таблица="Лицевых аналитики" При_удалении="NO ACTION" Описание="Поле используется для хранения группы потребителей по классификации в электроэнергетике, для отчетности"/>
                <Поле Имя="Счет-Линейный участок" Тип="Внешний ключ" Таблица="Организации" При_удалении="NO ACTION" Описание="Подразделение организация, к которой территориально относятся лс"/>
                <Поле Имя="Счет-Организация" Тип="Внешний ключ" Таблица="Организации" При_удалении="CASCADE" Описание="не используется"/>
                <Поле Имя="Счет-УПКСЗ" Тип="Внешний ключ" Таблица="Показатели кадастровой стоимости" При_удалении="SET NULL" Описание="Используется в программе Подомовой учет"/>
                <Поле Имя="Счета" Тип="Иерархия" Опции="NoDelete " Описание="Поле для организации адресной иерархии и иерархии в соответствии с подразделениями организации"/>
                <Поле Имя="Телефон" Тип="Строка" Описание="Телефон"/>
                <Поле Имя="e-mail" Тип="Строка" Описание="Адрес электронной почты"/>
                <Поле Имя="Тип" Тип="Перечисляемое" Поля="Район\nЛинейный участок\nУлица\nДом\nКвартира\nЛицевой счет\nПодъезд" Описание="Тип записи"/>
                <Поле Имя="Улица-Лицевой счет" Тип="Внешний ключ" Таблица="Города" При_удалении="NO ACTION" Описание="Для записи с адресным назначением - связь со справочником адресов"/>
                <Поле Имя="Управление" Тип="Целое" Описание="Информация о том, в каких функциональных модулях комплекса данную запись нужно отображать в справочнике"/>
                <Поле Имя="УровеньНапр" Тип="Перечисляемое" Поля="\nВН\nСН-1\nСН-2\nНН" Описание="не используется"/>
                <Поле Имя="Файл" Тип="Текст" Размер="255" Описание="не используется"/>
                <Поле Имя="Фамилия" Тип="Строка" Описание="Для районов – название, для домов и квартир – символьная часть номера, для остальных – не используется"/>
                <Поле Имя="Электросеть" Тип="Строка" Описание="не используется"/>
                <Поле Имя="Этаж" Тип="Целое" Опции="CtrlC " Описание="Номер этажа, на котором расположен лицевой счет"/>
                <Поле Имя="АдресДоставки" Тип="Текст" Размер="255" Описание="Информация об адресе, по которому доставлять платежный документ (когда отличается от основного адреса лицевого счета)"/>
                <Поле Имя="ИндексДоставки" Тип="Целое" Описание="Информация об индексе адреса, по которому доставлять платежный документ (когда отличается от основного адреса лицевого счета)"/>
                <Поле Имя="ОбластьДоставки" Тип="Текст" Размер="50" Описание="Информация о регионе адреса, по которому доставлять платежный документ (когда отличается от основного адреса лицевого счета)"/>
                <Поле Имя="УчастокДоставки" Тип="Строка" Описание="Информация об участке доставки (используется для группировки платежных документов по участкам доставки)"/>
                <Поле Имя="ЗакрытыйМесяц" Тип="Дата" Размер="2" Описание="Последний закрытый месяц расчета для данного лицевого счета (используется в процедурах частичного закрытия фонда)"/>
                <Поле Имя="ДатаОткрытия" Тип="Дата" Размер="2" Описание="Дата открытия лицевого счета"/>
                <Поле Имя="ДатаЗакрытия" Тип="Дата" Размер="2" Описание="Дата закрытия лицевого счета"/>
                <Поле Имя="Цвет" Тип="Целое" Описание="Цвет записи для отображения в интерфейсе"/>
                <Поле Имя="hashguid" Тип="Целое" Описание="Уникальный код. Используется для операции блокировок записей лицевых при закрытии месяца"/>
                <Поле Имя="СтороннийНомер" Тип="Строка" Описание="Вспомогательный номер для интеграции"/>
                <Поле Имя="ГУИД" Тип="Гуид" Описание="guid домов для интеграции с ГИС ЖКХ"/>
                <Поле Имя="ЮЛ_Блокировка фонда" Тип="Целое" Описание="Для программы Расчеты с абонентами - юридическими лицами, используется в процедуре закрытия месяца"/>
                <Поле Имя="ЮЛ_Месяц блокировки" Тип="Дата" Размер="2" Описание="Для программы Расчеты с абонентами - юридическими лицами, используется в процедуре закрытия месяца"/>
                <Поле Имя="ГИС_ИД" Тип="Строка" Описание="не используется"/>
                <Поле Имя="ОКТМО" Тип="Строка" Описание="ОКТМО улиц для интеграции с ГИС ЖКХ"/>
                <Поле Имя="Счет-Доставка" Тип="Внешний ключ" Таблица="Лицевые счета" При_удалении="SET NULL"/>
                <Поле Имя="ГИС_ЕЛС" Тип="Текст"/>
                <Поле Имя="ВидПотребления" Тип="Целое" Размер="1" Длина="3"/>
                <Поле Имя="ТипЗдания" Тип="Целое" Значение_по_умолчанию="2"/>
                <Поле Имя="ТипПомещ" Тип="Целое"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="СчетаROWID" Поля="Счета, Счета_add" ДопПоля="Номер, Управление,Тип, Фамилия, Архив"/>
                <Индекс Имя="НомерЛС" Поля="Тип, Номер"/>
                <Индекс Имя="Тип" Поля="Тип" ДопПоля="Счета, Счет-Линейный участок, Улица-Лицевой счет, Управление, Фамилия"/>
                <Индекс Имя="ЗакрытыйМесяц" Поля="ЗакрытыйМесяц" ДопПоля="Управление"/>
                <Индекс Имя="Месяц блокировки" Поля="Месяц блокировки" ДопПоля="Управление"/>
                <Индекс Имя="СтороннийЛС" Тип="gin" Поля="&quot;СтороннийНомер&quot; gin_trgm_ops"/>
                <Индекс Имя="Улица-Лицевой счет" Поля="Улица-Лицевой счет" ДопПоля="Счета, Счет-Линейный участок, Тип, Управление, Фамилия"/>
                <Индекс Имя="Тип_Код_строения" Поля="Тип, Код строения" ДопПоля=""/>
                <Индекс Имя="Тип_АдресЛС" Поля="Тип, АдресЛС" ДопПоля=""/>
                <Индекс Имя="Телефон" Поля="Тип, Телефон"/>
                <Индекс Имя="Счет-Доставка" Поля="Счет-Доставка" Выражение="&quot;Счет-Доставка&quot; is not null"/>
                <Индекс Имя="Счет-Линейный участок" Поля="Счет-Линейный участок" Выражение="&quot;Счет-Линейный участок&quot; is not null"/>
                <Индекс Имя="Счет-Организация" Поля="Счет-Организация" Выражение="&quot;Счет-Организация&quot; is not null"/>
                <Индекс Имя="НомерФамилия" Тип="gin" Поля="((((&quot;Номер&quot;)::text || &apos; &apos;::text) || &quot;Фамилия&quot;)) gin_trgm_ops"/>
            </Индексы_базы>
            <Триггеры>
                <Триггер Имя="Лицевые_счета" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql"/>
                <Триггер Имя="Лицевые_счета_BF_ALLTRIG" Версия="3" Файл="Лицевые счета_BF_UPDTRIG.sql"/>
                <Триггер Имя="Лицевые_счета_LSHIER_DELTRIG" Версия="2" Файл="Лицевые счета_LSHIER_DELTRIG.sql"/>
                <Триггер Имя="Лицевые_счета_LSHIER_INSTRIG" Версия="2" Файл="Лицевые счета_LSHIER_INSTRIG.sql"/>
                <Триггер Имя="Лицевые_счета_LSHIER_UPDTRIG" Версия="5" Файл="Лицевые счета_LSHIER_UPDTRIG.sql"/>
            </Триггеры>
            <Политики>
                <Политика Имя="AP_Post" Файл="Лицевые счета_Select_AP_Post.sql"/>
