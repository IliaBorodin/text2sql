                <Поле Имя="Папки" Тип="Иерархия" Опции="BreakDelete " Описание="Иерархия для создаия папок"/>
                <Поле Имя="Договор-Акты" Тип="Внешний ключ" Таблица="Договор" При_удалении="CASCADE"/>
                <Поле Имя="Счет-Акты" Тип="Внешний ключ" Таблица="Лицевые счета" При_удалении="CASCADE" Описание="row_id ЛС из таблицы [Лицевые счета]"/>
