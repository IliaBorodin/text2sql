        <Table Имя="Параметры">
            <Поля>
                <Поле Имя="Имя" Тип="Текст" Размер="25"/>
                <Поле Имя="Код" Тип="Целое"/>
                <Поле Имя="Название" Тип="Текст" Размер="40"/>
                <Поле Имя="Параметры_" Тип="Иерархия" Опции="BreakDelete "/>
                <Поле Имя="Описание" Тип="Текст" Размер="255"/>
                <Поле Имя="Тип" Тип="Перечисляемое" Поля="Деньги\nЧисло\nСтрока\nДата\nВремя\nПеречисляемое\nПоле связи\nЧекбокс\nПериод\nСсылка\nПользовательский справочник\nМесяц\nГод\nДата и время" Описание="Тип параметра"/>
                <Поле Имя="Возможные значения" Тип="Строка" Размер="4000" Описание="Возможные значения параметра" />
                <Поле Имя="По умолчанию" Тип="Строка" Размер="4000" Описание="Значение по умолчанию" />
                <Поле Имя="Мультивыбор" Тип="Целое" Размер="1" Длина="1" MSSQL="bit" Описание="Разрешен ли множественный выбор" />
                <Поле Имя="Модель данных" Тип="Строка" Описание="Модель данных - с нее берутся возможные значения параметра для поля связи" />
                <Поле Имя="Поле связи" Тип="Строка" Описание="Название поля модели данных, значение которого принимает параметр" />
                <Поле Имя="ВводНового" Тип="Целое" Размер="1" Длина="1" MSSQL="bit" Описание="Разрешен ли ввод нового значения пользователем" />
                <Поле Имя="Маска" Тип="Строка" Описание="Регулярное выражение для валидации значения параметра" />
                <Поле Имя="ПараметрыЗапроса" Тип="Строка" Размер="4000" Описание="Параметры запроса (то, что полетит в params при получении записей из модели данных)" />
                <Поле Имя="Ссылка" Тип="Строка" Описание="Ссылка для перехода по полю связи" />
                <Поле Имя="Источник" Тип="Целое" Описание="Сущность, которой принадлежит параметр" />
                <Поле Имя="Основной" Тип="Целое" Размер="1" Длина="1" MSSQL="bit" Описание="0 - кастомное, 1 - системное (значение системного поля хранится в соответствующем поле связанной таблицы и берется оттуда, кастомные - в табл. Значения параметров)" />
                <Поле Имя="Видимость" Тип="Целое" Описание="Флаг видимости кастомных полей" />
                <Поле Имя="ИдКлассификатор" Тип="Внешний ключ" Таблица="Классификаторы" При_удалении="NO ACTION" Описание="Указатель на пользовательский справочник" />
                <Поле Имя="ПоляЗначений" Тип="Строка" Описание="Список полей, из которых значение параметра может быть заполнено автоматически" />
            </Поля>
            <Индексы_базы>
                <Индекс Имя="КодИмя" Поля="Код, Имя"/>
            </Индексы_базы>
            <Триггеры>
                <Триггер Имя="Параметры" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql"/>
                <Триггер Имя="Параметры_LOG_ALLTRIG" Версия="1" Файл="Параметры_SPR_TRIG.sql"/>
            </Триггеры>
        </Table>
