            <Триггеры>
                <Триггер Имя="ЦентрУведомленийМедиабиблиотека" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql" Сущность1="Типы документов-Файл" Сущность2="Файл-Связка"/>
            </Триггеры>
        </Table>
        <Table Имя="ЦентрУведомленийСообщения" Описание="Сообщения для отправки">
            <Поля>
                <Поле
                    Имя="ПоследнийСтатус"
                    Тип="Перечисляемое"
                    Поля="Подготовлено\nВ процессе\nОтправлено\nДоставлено\nОшибка\nОтмена"
                    Описание="Последний статус сообщения, обновляется автоматически"
                />
                <Поле
                    Имя="ВремяОбновления"
                    Тип="ДатаВремя"
                    Описание="Дата и время последнего обновления статуса, обновляется автоматически"
                />
                <Поле
                    Имя="ПоследнийПИд"
                    Тип="Целое"
                    Описание="Последний записаный в журнал ПИд, обновляется автоматически"
                />
                <Поле Имя="СтатусДопТекст" Тип="Строка" Описание="Сообщение последней записи в журнале по сообщению" />
                <Поле Имя="Попытка" Тип="Целое" Описание="Номер по порядку попытки отправки"/>
                <Поле Имя="ВнешнийИД" Тип="Строка" Описание="Идентификатор внешнего сервиса"/>
                <Поле Имя="Папки" Тип="Иерархия" Опции="CascadeDelete " Описание="Указатель на родительскую запись в иерархии"/>
                <Поле Имя="ИД_Лицевой" Тип="Внешний ключ" Таблица="Лицевые счета" При_удалении="NO ACTION" При_обновлении="NO ACTION" Описание="Идентификатор лицевого счета, указатель на запись в таблице Лицевые счета"/>
                <Поле Имя="ИД_Кампания" Тип="Внешний ключ" Таблица="ЦентрУведомленийКампании" При_удалении="CASCADE" При_обновлении="NO ACTION" Описание="Идентификатор компании центра уведомлений, указатель на запись в таблице ЦентрУведомленийКампании"/>
                <Поле Имя="ИД_Дело" Тип="Внешний ключ" Таблица="Взыскание задолженности" При_удалении="NO ACTION" При_обновлении="NO ACTION" Описание="Идентификатор дела о задолженности, указатель на запись в таблице Взыскание задолженности"/>
                <Поле Имя="ИД_Договор" Тип="Внешний ключ" Таблица="Договор" При_удалении="NO ACTION" При_обновлении="NO ACTION" Описание="Идентификатор договора, указатель на запись в таблице Договор"/>
                <Поле Имя="ИД_Организация" Тип="Внешний ключ" Таблица="Организации" При_удалении="NO ACTION" При_обновлении="NO ACTION" Описание="Идентификатор организации, указатель на запись в таблице Организации"/>
                <Поле Имя="АдресДоставки" Тип="Строка" Описание="Телефон,E-Mail на который производится рассылка"/>
                <Поле Имя="Отправили" Тип="Целое" Описание="Индикатор отправки в автообзвон"/>
                <Поле Имя="Заголовок" Тип="Строка" Длина="100" Описание="Заголовок сообщения"/>
                <Поле Имя="Текст" Тип="Строка" Длина="7000" Описание="Отправляемое сообщение"/>
                <Поле Имя="Автор" Тип="Внешний ключ" Таблица="Сотрудники" При_удалении="NO ACTION" Описание="Сотрудник"/>
                <Поле Имя="ТемаСообщения" Тип="Строка" />
            </Поля>
            <Триггеры>
                <Триггер Имя="ЦентрУведомленийСообщения" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql" НелогПоля="Текст" Сущность1="ИД_Лицевой" Сущность2="ИД_Кампания"/>
                <Триггер Имя="ЦентрУведомленийСообщения_INSTRIG" Версия="2" Файл="ЦентрУведомленийСообщения_INSTRIG.sql"/>
            </Триггеры>
            <Индексы_базы>
                <Индекс Имя="Папки" Поля="Папки, Папки_add"/>
                <Индекс Имя="ИД_Кампания" Поля="ИД_Кампания,ПоследнийСтатус" />
                <Индекс Имя="ИД" Поля="ИД_Лицевой,ИД_Дело,ИД_Договор"/>
                <Индекс Имя="Организация" Поля="ИД_Организация" Выражение="&quot;ИД_Организация&quot; is not null" />
                <Индекс Имя="ВнешнийИД" Поля="ВнешнийИД"/>
            </Индексы_базы>
        </Table>
        <Table Имя="ЦентрУведомленийЖурнал" Описание="Журнал отправки сообщений">
            <Поля>
                <Поле Имя="ИД_Сообщение" Тип="Внешний ключ" Таблица="ЦентрУведомленийСообщения" При_удалении="CASCADE" При_обновлении="NO ACTION"/>
                <Поле Имя="ДатаВремя" Тип="ДатаВремя" Описание="Дата и время записи в журнал"/>
                <Поле Имя="Сообщение" Тип="Строка" Описание="Описание события журнала для пользователя"/>
                <Поле Имя="СлужебноеСообщение" Тип="Строка" Описание="Информация из сторонних сервисов"/>
                <Поле Имя="Статус" Тип="Перечисляемое" Поля="Подготовлено\nВ процессе\nОтправлено\nДоставлено\nОшибка\nОтмена" Описание="Статус сообщения"/>
                <Поле Имя="ПИд" Тип="Целое" Размер="4" Описание="Идентификатор потока"/>
            </Поля>
            <Триггеры>
                <Триггер Имя="ЦентрУведомленийЖурнал_INSTRIG" Версия="2" Файл="ЦентрУведомленийЖурнал_INSTRIG.sql"/>
            </Триггеры>
            <Индексы_базы>
                <Индекс Имя="ИД_Сообщение" Поля="ИД_Сообщение"/>
                <Индекс Имя="Статус" Поля="Статус" ДопПоля="row_id"/>
                <Индекс Имя="ПИд" Поля="ПИд" ДопПоля="ИД_Сообщение,Статус"/>
            </Индексы_базы>
        </Table>
        <Table Имя="ЦентрУведомленийЖурналЗапросов" Описание="Журнал действий с сообщениями кампаний ЦИ">
            <Поля>
                <Поле Имя="Журнал-Сообщения" PostgreSQL="int~[]~" Тип="Целое" Описание="массив идентификаторов сообщений по которым совершался запрос"/>
                <Поле Имя="Журнал-Кампания" Тип="Внешний ключ" Таблица="ЦентрУведомленийКампании" При_удалении="CASCADE" Описание="Идентификатор компании центра уведомлений, указатель на запись в таблице ЦентрУведомленийКампании" />
