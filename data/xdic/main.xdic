        <Table Имя="#TR_GVS" Вид="Временная" Схема="tmp" Описание="временная таблица с тепловым расчетом ГВС">
            <Поля>
                <Поле Имя="ТР ГВС-ТР" Тип="Целое" Описание="ссылка на таблицу [тепловой расчет]"/>
                <Поле Имя="ТР ГВС-Договор" Тип="Целое" Описание="ссылка на таблицу [договор]"/>
                <Поле Имя="ТР ГВС-Лицевой" Тип="Целое" Описание="ссылка на таблицу [лицевые счета]"/>
                <Поле Имя="Месяц" Тип="Дата" Размер="2" Описание="месяц, в котором произведен расчет"/>
                <Поле Имя="ЗаМесяц" Тип="Дата" Размер="2" Описание="месяц, за который произведен расчет"/>
                <Поле Имя="V" Тип="Вещественное" Описание="объем м3"/>
                <Поле Имя="tc" Тип="Вещественное" Описание="температура водопроводной воды в отопительный период"/>
                <Поле Имя="tcs" Тип="Вещественное" Описание="температура водопроводной воды в неотопительный период"/>
                <Поле Имя="N" Тип="Вещественное" Описание="дней в месяце"/>
                <Поле Имя="ktp" Тип="Вещественное" Описание="тепловые потери в местной системе горячего водоснабжения"/>
                <Поле Имя="B" Тип="Вещественное" Описание="коэффициент бета, учитывающий потери теплоопорами, арматурой, компенсаторами"/>
                <Поле Имя="kdgv" Тип="Вещественное" Описание="продолжительность функционирования систем ГВС, часов в год"/>
                <Поле Имя="ns" Тип="Вещественное" Описание="продолжительность функционирования систем в неотопительном периоде, час"/>
                <Поле Имя="no" Тип="Вещественное" Описание="температура теплоносителя для обратного трубопровода в неотапливаемый период (среднегодовой), °С  "/>
                <Поле Имя="K" Тип="Вещественное" Описание="коэффициент периода"/>
                <Поле Имя="Norm" Тип="Вещественное" Описание="норма на подогрев 1 м3"/>
                <Поле Имя="Объем" Тип="Вещественное" Описание="объем ГКал"/>
                <Поле Имя="Потери" Тип="Вещественное" Описание="объем потерь"/>
                <Поле Имя="ОбъемСуб" Тип="Вещественное" Описание="объем вычитания субабонентов"/>
                <Поле Имя="Коэф" Тип="Вещественное" Описание="расчетный коэффициент"/>
                <Поле Имя="Счетчик" Тип="Целое" Описание="ссылка на таблицу [список объектов]"/>
                <Поле Имя="ТекПок" Тип="Вещественное" Описание="текущее показание"/>
                <Поле Имя="ПредПок" Тип="Вещественное" Описание="предыдущее показание"/>
                <Поле Имя="Расход" Тип="Вещественное" Описание="разница показания"/>
                <Поле Имя="допРасход" Тип="Вещественное" Описание="дополнительный расход"/>
                <Поле Имя="Нагрузка" Тип="Вещественное" Описание="договорный объем (при расчете по нему)"/>
                <Поле Имя="Тип" Тип="Целое"/>
                <Поле Имя="Объект" Тип="Целое" Описание="ссылка на таблицу [объекты договора]"/>
                <Поле Имя="Аналитика1" Тип="Целое" Описание="основная услуга, с нее берется объем (актаульно для услуг с калькуляцией тарифа)"/>
                <Поле Имя="Аналитика2" Тип="Целое" Описание="вид расчета, флаги, подробности в функции ufnULTypeOfService"/>
                <Поле Имя="Сортировка" Тип="Целое" Описание="сортировка для вывода в отчеты"/>
                <Поле Имя="Аналитика" Тип="Целое" Описание="дополнительное поле, в инсталляции не используется"/>
                <Поле Имя="ПотериПр" Тип="Вещественное" Описание="объем процентных потерь"/>
                <Поле Имя="ПотериФикс" Тип="Вещественное" Описание="объем процентных потерь"/>
                <Поле Имя="Пр_Потерь" Тип="Вещественное" Описание="значение параметра процент потерь"/>
                <Поле Имя="Суб" Тип="Строка" Описание="признак субабонента: С - вычитаемый счетчик из другого договора, П - вычитаемый из текущего договора, В% - в процентах подчиненный"/>
                <Поле Имя="ВидНачислений" Тип="Строка" Описание="код вида расчета: по счетчику, замещающий, по норме и т.д."/>
