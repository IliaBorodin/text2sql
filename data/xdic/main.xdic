                <Триггер Имя="Список_оплаты" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql" Сущность1="Счет-Оплата" Сущность2="Платеж-Список"/>
                <Триггер Имя="Список_оплаты_BF_DELTRIG" Версия="2" Файл="Список оплаты_BF_DELTRIG.sql"/>
                <Триггер Имя="Список_оплаты_ВП_DELTRIG" Версия="1" Файл="Список_оплаты_ВП_DELTRIG.sql"/>
