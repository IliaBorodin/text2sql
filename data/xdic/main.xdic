                <Поле Имя="Месяц" Тип="Дата" Размер="2" Описание="Месяц расчета"/>
                <Поле Имя="Поставщик" Тип="Внешний ключ" Таблица="Организации" При_удалении="NO ACTION" Описание="row_id поставщика услуги из таблицы [Организации]"/>
                <Поле Имя="Соглашение-ПениПериоды" Тип="Внешний ключ" Таблица="Соглашение рассрочки" При_удалении="NO ACTION" Описание="row_id из таблицы [Соглашение рассрочки] - ссылка на рассрочку"/>
                <Поле Имя="Соглашение с" Тип="Дата" Размер="2" Описание="Дата начала соглашения"/>
                <Поле Имя="Состояние-ПениПериоды" Тип="Внешний ключ" Таблица="Состояние документа" При_удалении="CASCADE"/>
                <Поле Имя="Счет" Тип="Внешний ключ" Таблица="Лицевые счета" При_удалении="NO ACTION" Описание="row_id ЛС из таблицы [Лицевые счета]"/>
                <Поле Имя="Услуга-ПениПериоды" Тип="Внешний ключ" Таблица="Типы услуг" При_удалении="NO ACTION" Описание="row_id из справочника [Типы услуг]"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="Дело-ПениПериоды" Поля="Дело-ПениПериоды"/>
                <Индекс Имя="Состояние-ПениПериоды" Поля="Состояние-ПениПериоды"/>
                <Индекс Имя="Счет" Поля="Счет, Дело-ПениПериоды"/>
                <Индекс Имя="Услуга-ПениПериоды" Поля="Услуга-ПениПериоды"/>
            </Индексы_базы>
            <Триггеры>
                <Триггер Имя="ПениПериодыНеначисления_PP" Версия="1" Файл="ПениПериодыНеначисления_PP_TRIG.sql"/>
                <Триггер Имя="ПениПериодыНеначисления" Версия="1" Сущность1="Счет" Шаблон="Шаблон_LOG_ALLTRIG.sql"/>
            </Триггеры>
