                <Поле Имя="Площадь" Тип="Вещественное" Точность="9" Описание="справочно для истории на момент начислений"/>
                <Поле Имя="Проживает" Тип="Вещественное" Точность="9" Описание="справочно для истории на момент начислений"/>
                <Поле Имя="Начисления" Тип="Вещественное" Точность="9" Описание="справочно для истории на момент начислений"/>
