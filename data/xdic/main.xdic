        <Table Имя="Категории договоров" Описание="Справочник для формирования отчетности">
            <Поля>
                <Поле Имя="Папки" Тип="Иерархия" Опции="CascadeDelete "/>
                <Поле Имя="Код" Тип="Строка" Описание="Код для группировки в отчетности"/>
                <Поле Имя="Название" Тип="Строка" Описание="Название категории"/>
                <Поле Имя="Тип" Тип="Целое" Размер="1" Длина="3" Опции="CtrlC " Описание="Не используется"/>
                <Поле Имя="Цвет" Тип="Целое" Опции="CtrlC " Описание="Код цвета (задается пользователем) для отображения в интерфейсе"/>
                <Поле Имя="Примечание" Тип="Строка"/>
            </Поля>
            <Индексы_базы/>
            <Триггеры>
                <Триггер Имя="Категории_договоров" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql" />
            </Триггеры>
        </Table>
        <Table Имя="Категории льгот" Описание="Справочник группировки льгот (МСП) для отчетности">
            <Поля>
                <Поле Имя="Категории" Тип="Иерархия" Опции="NoDelete "/>
                <Поле Имя="Льгота-Категории" Тип="Внешний ключ" Таблица="Виды льгот" При_удалении="CASCADE"/>
                <Поле Имя="N п/п" Тип="Целое"/>
                <Поле Имя="Название" Тип="Строка"/>
            </Поля>
            <Индексы_базы/>
            <Триггеры/>
        </Table>
        <Table Имя="Категории организаций" Описание="Справочник группировки организаций для отчетности">
            <Поля>
                <Поле Имя="Категории организаций" Тип="Иерархия" Опции="BreakDelete "/>
                <Поле Имя="Категории-Организация" Тип="Внешний ключ" Таблица="Организации" При_удалении="CASCADE"/>
                <Поле Имя="Номер" Тип="Целое"/>
                <Поле Имя="Наименование" Тип="Строка"/>
                <Поле Имя="Строка" Тип="Текст" Размер="10"/>
                <Поле Имя="ДопКод" Тип="Текст" Размер="10"/>
            </Поля>
            <Индексы_базы/>
            <Триггеры/>
        </Table>
        <Table Имя="Категории работ">
            <Поля>
                <Поле Имя="Категории" Тип="Иерархия" Опции="BreakDelete "/>
                <Поле Имя="Работа-Категории" Тип="Внешний ключ" Таблица="Наименования работ" При_удалении="CASCADE"/>
                <Поле Имя="N п/п" Тип="Целое"/>
                <Поле Имя="Название" Тип="Строка"/>
                <Поле Имя="Номер" Тип="Строка"/>
            </Поля>
            <Индексы_базы/>
            <Триггеры/>
        </Table>
        <Table Имя="Категории услуг" Описание="Справочник группировки услуг для отчетности">
            <Поля>
                <Поле Имя="Категории" Тип="Иерархия" Опции="CascadeDelete "/>
                <Поле Имя="Услуга-Категории" Тип="Внешний ключ" Таблица="Типы услуг" При_удалении="CASCADE"/>
                <Поле Имя="Название" Тип="Строка"/>
                <Поле Имя="Номер категории" Тип="Целое" Опции="CtrlC "/>
                <Поле Имя="Примечание" Тип="Строка"/>
            </Поля>
            <Индексы_базы/>
            <Триггеры/>
        </Table>
        <Table Имя="Квит_Льготы" Категория="Квитанции" Описание="Информация о льготниках в квитанцию">
            <Поля>
                <Поле Имя="КвитЛьготы-Счет" Тип="Внешний ключ" Таблица="Лицевые счета" При_удалении="SET NULL"/>
                <Поле Имя="КвитЛьготы-ОД" Тип="Целое"/>
                <Поле Имя="Месяц" Тип="Дата" Размер="2" Описание="Месяц, за который построена квитанция"/>
                <Поле Имя="Номер льготы" Тип="Строка" Описание="Номер льготы"/>
                <Поле Имя="Число льготников" Тип="Целое" Опции="CtrlC " Описание="Количество льготников"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="КвитЛьготы-ОД" Поля="КвитЛьготы-ОД"/>
                <Индекс Имя="СчетМесяц" Поля="КвитЛьготы-Счет, Месяц"/>
            </Индексы_базы>
            <Триггеры/>
        </Table>
