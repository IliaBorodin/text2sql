                <Поле Имя="Лицевой" Тип="Целое" Таблица="Лицевые счета" Опции="CascadeDelete " Описание="Ссылка на точку учета"/>
                <Поле Имя="Потребитель" Тип="Целое" Таблица="Потребители договора" Опции="CascadeDelete " Описание="Ссылка на потребителя (для формирования отдельным комплектом)"/>
                <Поле Имя="Месяц" Тип="Дата" Описание="Месяц, в котором произведен расчет"/>
                <Поле Имя="ЗаМесяц" Тип="Дата" Описание="Месяц, за который произведен расчет (для перерасчета отличается от поля Месяц)"/>
                <Поле Имя="Номер услуги" Тип="Целое" Описание="Номер услуги из справочика [Типы услуг]"/>
                <Поле Имя="НТариф" Тип="Вещественное" Точность="11" Описание="Тариф использующийся в расчете"/>
                <Поле Имя="Тариф" Тип="Вещественное" Точность="11" Описание="Тариф, который выводится в документе "/>
                <Поле Имя="Кол_во" Тип="Вещественное" Точность="9" Опции="CtrlC " Описание="Объем услуги"/>
                <Поле Имя="НСумма" Тип="Вещественное" Опции="CtrlC " Описание="Сумма из расчета = Объем*НТариф"/>
                <Поле Имя="СуммаБезНДС" Тип="Деньги" Опции="CtrlC " Описание="Сумма без НДС, которая пойдет в документ"/>
                <Поле Имя="Сумма" Тип="Деньги" Опции="CtrlC " Описание="Сумма с НДС, которая пойдет в документ"/>
                <Поле Имя="СтавкаНДС" Тип="Целое" Описание="Ставка НДС использованная в расчете"/>
                <Поле Имя="Группировка" Тип="Строка" Описание="Ключ группировки, используется для вычислеия итоговых сумм в документе"/>
                <Поле Имя="Детализация-Наименование" Тип="Целое" Таблица="Наименования счета" Опции="BreakDelete " Описание="Ссылка на строку документа, в который вошли данные начисления"/>
                <Поле Имя="Детализация-Основание" Тип="Целое" Таблица="Документ" Опции="BreakDelete " Описание="Ссылка на первоначальный документ"/>
                <Поле Имя="Тип" Тип="Целое" Описание="Флаг для переасчета 0 - сумма начисления, 1 - сумма сторнирования"/>
                <Поле Имя="Вид" Тип="Целое" Размер="1" Длина="1" Описание="Вид перерасчета 1 - ручная коррекция, иначе расчет/перерасчет произведен автоматически"/>
                <Поле Имя="Расчет-Аналитика" Тип="Целое" Таблица="Аналитика расчета" Опции="NoDelete " Описание="Ссылка на таблицу с набором характеристик расчета (вид начисления, поставщик, ссылка на сеть и т.д.)"/>
                <Поле Имя="Тип-Договор" Тип="Целое" Таблица="Типы договора" Опции="NoDelete " Описание="Ссылка на справочник типов договора, который был на момент расчета или перерасчета"/>
                <!-- эти поля бы вынести в отд. таблицу типа расширения -->
                <Поле Имя="Детализация-Акт" Тип="Целое" Таблица="Акты нарушений" Опции="BreakDelete " Описание="Ссылка на акт нарушений абонента"/>
                <Поле Имя="Детализация-АктНГВ" Тип="Целое" Таблица="ПДК акт" Опции="BreakDelete " Описание="Ссылка на акты на отбора проб и запрещенного сброса"/>
                <Поле Имя="Детализация-Декларация" Тип="Целое" Таблица="ПДК декларация" Опции="BreakDelete " Описание="Ссылка на декларацию с допустимыми концентрациями веществ"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="МесяцДоговор" Поля="Договор,Месяц,ЗаМесяц"/>
                <Индекс Имя="ДоговорДокумент" Поля="Договор,Детализация-Наименование"/>
                <Индекс Имя="Лицевой" Поля="Лицевой,Месяц"/>
                <Индекс Имя="Детализация-Акт" Поля="Детализация-Акт"/>
                <Индекс Имя="Детализация-АктНГВ" Поля="Детализация-АктНГВ"/>
            </Индексы_базы>
        </Table>
        <Table Имя="ДО внешние документы" Описание="Таблица связи с файлами для ДО и связанных с ним задач">
