            </Индексы_базы>
        </Table>
        <Table Имя="СвязиБП" Описание="Привязки БП к сущностям, быть внимательным с названием связей">
            <Поля>
                <Поле Имя="идБизнесПроцесс" Тип="Внешний ключ" Таблица="Бизнес процессы" При_удалении="CASCADE" />
                <Поле Имя="идСотрудник" Тип="Внешний ключ" Таблица="Сотрудники" При_удалении="NO ACTION" />
                <Поле Имя="идКонтрагент" Тип="Внешний ключ" Таблица="СвязиКонтрагента" При_удалении="SET NULL" />
                <Поле Имя="идАдрес" Тип="Внешний ключ" Таблица="АдресаБП" При_удалении="SET NULL" />
                <Поле Имя="признакРасчета" Тип="Целое" PostgreSQL="boolean" Значение_по_умолчанию_PostgreSQL="false" Описание="Наличие заполненного расчета на работе" />
                <Поле Имя="признакОбращения" Тип="Целое" PostgreSQL="boolean" Значение_по_умолчанию_PostgreSQL="false" Описание="Наличие свзанных обращений на заявке" />
            </Поля>
            <Индексы_базы>
                <Индекс Имя="идБизнесПроцесс" Поля="идБизнесПроцесс" Опции="UNIQUE"/>
                <Индекс Имя="идСотрудник" Поля="идСотрудник"/>
                <Индекс Имя="идКонтрагент" Поля="идКонтрагент"/>
                <Индекс Имя="идАдрес" Поля="идАдрес"/>
            </Индексы_базы>
        </Table>
