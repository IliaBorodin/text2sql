        </Table>
        <Table Имя="Сеть точки" Описание="Привязка точек к структуре сети">
            <Поля>
                <Поле Имя="Лицевой" Тип="Внешний ключ" Таблица="Лицевые счета" При_удалении="CASCADE" Описание="Точка, привязанная к сети. Указатель на таблицу ~Лицевые счета~"/>
                <Поле Имя="Элемент" Тип="Внешний ключ" Таблица="Сеть элементы" При_удалении="CASCADE" Описание="Элемент сети. Указатель на таблицу ~Сеть элементы~"/>
                <Поле Имя="Соединение" Тип="Внешний ключ" Таблица="Сеть соединения" При_удалении="CASCADE" Описание="Соединение сети. Указатель на таблицу ~Сеть соединения~"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="Лицевой" Поля="Лицевой,Элемент" Опции="UNIQUE"/>
                <Индекс Имя="Элемент" Поля="Элемент,Лицевой" Опции="UNIQUE"/>
                <Индекс Имя="Соединение" Поля="Соединение"/>
            </Индексы_базы>
            <Триггеры>
                <Триггер Имя="Сеть_точки" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql" Сущность1="Элемент" Сущность2="Лицевой" />
            </Триггеры>
        </Table>
        <Table Имя="Сеть график" Описание="часы работы системы теплонсабжения (кол-во часов за каждый день месяца, по молчанию 24ч.)">
            <Поля>
                <Поле Имя="Сеть график-Элемент сети" Тип="Внешний ключ" Таблица="Сеть элементы" При_удалении="CASCADE" Описание="ссылка на элемент сети"/>
                <Поле Имя="Сеть график-Лицевой" Тип="Внешний ключ" Таблица="Лицевые счета" При_удалении="CASCADE" Описание="ссылка на лицевой при наличии индивидуального графика"/>
                <Поле Имя="Номер Услуги" Тип="Целое" Описание="вид услуги"/>
                <Поле Имя="Месяц" Тип="Дата" Размер="2" Описание="месяц для графика"/>
                <Поле Имя="КолДней" Тип="Целое" Размер="1" Описание="дней в месяце"/>
                <Поле Имя="КолЧас" Тип="Целое" Размер="2" Описание="количество часов в месяце"/>
                <Поле Имя="Д01" Тип="Целое" Размер="1" Опции="CtrlC " Описание="кол-во часов работы 1 числа месяца"/>
                <Поле Имя="Д02" Тип="Целое" Размер="1" Опции="CtrlC " Описание="кол-во часов работы 2 числа месяца"/>
                <Поле Имя="Д03" Тип="Целое" Размер="1" Опции="CtrlC " Описание="кол-во часов работы 3 числа месяца"/>
