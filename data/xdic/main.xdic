                <Поле Имя="Кол_Дней" Опции="CtrlC " Тип="Вещественное"/>
                <Поле Имя="Кол_Дней_ГВС" Опции="CtrlC " Тип="Вещественное"/>
                <Поле Имя="РасчетДней" Опции="CtrlC " Тип="Целое"/>
