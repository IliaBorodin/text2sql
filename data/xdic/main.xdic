        <Table Имя="#tmpImport_DOSud" Описание="Таблица для конвертации досудебной работы" Вид="ВременнаяДляПользователя" Схема="tmp">
            <Поля>
                <Поле Имя="ABONENT" Тип="Строка" Длина="2000" Описание="Номер лицевого *Обязательное"/>
                <Поле Имя="COMMENT" Тип="Строка" Длина="2000" Описание="Примечание"/>
                <Поле Имя="CREATEDBYUSER" Тип="Целое" Описание="Табельный номер пользователя, создавшего дела (из справочника Сотрудники. При неоходимости дополнительно готовится список соответствий)"/>
                <Поле Имя="DATE" Тип="Дата" Размер="2" Описание="Дата создания дела в формате дд.мм.гггг *Обязательное"/>
                <Поле Имя="ID_ACTIONS" Тип="Строка" Длина="2000" Описание="Стронний код фазы досудебной работы (по умолчанию используем поле Код из справочика фаз. При неоходимости дополнительно готовится список соответствий) *Обязательное"/>
                <Поле Имя="NUMBER" Тип="Длинное целое" Описание="Номер документа на фазе"/>
                <Поле Имя="PENI" Тип="Вещественное" Точность="9" Описание="Сумма пени (разделитель .)"/>
                <Поле Имя="PERIOD_FOR" Тип="Дата" Размер="2" Описание="Дата последнего месяца долга - должно быть первое число месяца (ДатКнцДолга) в формате дд.мм.гггг *Обязательное"/>
                <Поле Имя="PERIOD_FROM" Тип="Дата" Размер="2" Описание="Дата начала образования задолженности (ДатНачДолга) в формате дд.мм.гггг *Обязательное"/>
                <Поле Имя="PLAINTIFF" Тип="Строка" Длина="2000" Описание="Идентификатор кредитора, если требуется (поле Код группы со справочника кредиторов стека. При неоходимости дополнительно готовится список соответствий)"/>
                <Поле Имя="SUM" Тип="Вещественное" Точность="9" Описание="Сумма основного долга (разделитель .)"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="ID_ACTIONS" Поля="ID_ACTIONS" ДопПоля=""/>
            </Индексы_базы>
        </Table>
        <Table Имя="#tmpImport_Sud" Описание="Основная таблица с делами" Вид="ВременнаяДляПользователя" Схема="tmp">
            <Поля>
                <Поле Имя="ABONENT" Тип="Строка" Длина="2000" Описание="Номер лицевого/договора для дальнейшей идентификации *Обязательное"/>
                <Поле Имя="ADRES" Тип="Строка" Длина="2000" Описание="Адрес должника"/>
                <Поле Имя="COMMENT" Тип="Строка" Длина="2000" Описание="Примечание"/>
                <Поле Имя="CREATEDBYUSER" Тип="Целое" Описание="Табельный номер пользователя, создавшего дела (из справочника Сотрудники. При неоходимости дополнительно готовится список соответствий)"/>
                <Поле Имя="DATE_CLAIM" Тип="Дата" Размер="2" Описание="Дата создания дела в формате дд.мм.гггг *Обязательное"/>
                <Поле Имя="ID" Тип="Строка" Длина="2000" Описание="Идентификатор дела (первичный ключ) стороннего ПО, используется для дальнейшей связи между таблицами -  *Обязательное"/>
                <Поле Имя="ID_FOLDER" Тип="Целое" Описание="Служебное: Ссылка на папку, в которой будет лежать дело"/>
                <Поле Имя="ID_SUDUCH" Тип="Строка" Длина="2000" Описание="Идентификатор судебного участка (поле ID_SUDUCH из файла lawer_sud_org с типом 0)"/>
                <Поле Имя="FILE" Тип="Строка" Длина="2000" Описание="Служебное: Имя xls файла"/>
                <Поле Имя="LINE" Тип="Целое" Описание="Служебное: Строчка с xls файлом"/>
                <Поле Имя="LIST" Тип="Строка" Длина="2000" Описание="Служебное: Имя листа в xls файле"/>
                <Поле Имя="NPP" Тип="Целое" Описание="Номер дела по порядку"/>
                <Поле Имя="NUMBER" Тип="Строка" Длина="2000" Описание="Полный номер документа (СудНомер в будущем)"/>
                <Поле Имя="PERIOD_FOR" Тип="Дата" Размер="2" Описание="Дата последнего месяца долга - должно быть первое число месяца (ДатКнцДолга) в формате дд.мм.гггг *Обязательное"/>
                <Поле Имя="PERIOD_FROM" Тип="Дата" Размер="2" Описание="Дата начала образования задолженности (ДатНачДолга) в формате дд.мм.гггг *Обязательное"/>
                <Поле Имя="PLAINTIFF" Тип="Строка" Длина="2000" Описание="Идентификатор кредитора, если требуется (поле Код группы со справочника кредиторов стека. При неоходимости дополнительно готовится список соответствий)"/>
                <Поле Имя="row_id" Тип="Целое" Опции="Identity" Описание="Служебное: запись в стеке"/>
                <Поле Имя="SHARE" Тип="Строка" Длина="2000" Описание="Доля в виде Числитель/знаменатель (например 1/2)"/>
                <Поле Имя="SUBJECT" Тип="Строка" Длина="2000" Описание="Предмет иска: идентификатор предмета иска ОСНОВНОЙ - долг и пени за этот период *Обязательное"/>
                <Поле Имя="TASK" Тип="Целое" Описание="Задача 278 или 284 (ФЛ или ЮЛ соответственно) в зависимости от того, что конвертируется *Обязательное"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="ABONENT" Поля="ABONENT" ДопПоля=""/>
                <Индекс Имя="ID" Поля="ID" ДопПоля=""/>
            </Индексы_базы>
        </Table>
        <Table Имя="#tmpImport_Sud_Phase" Описание="Список фаз" Вид="ВременнаяДляПользователя" Схема="tmp">
            <Поля>
