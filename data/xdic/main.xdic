        <Table Имя="ПДК состав" Описание="перечень веществ входящших в акт">
            <Поля>
                <Поле Имя="ПДК-Акт" Тип="Внешний ключ" Таблица="ПДК акт" При_удалении="CASCADE" Описание="ссылка на акт"/>
                <Поле Имя="ПДК-Декларация" Тип="Внешний ключ" Таблица="ПДК декларация" При_удалении="CASCADE" Описание="ссылка на декларацию"/>
                <Поле Имя="ПДК-Вид" Тип="Внешний ключ" Таблица="Вещества" При_удалении="NO ACTION" Описание="ссылка на справочник веществ"/>
                <Поле Имя="Факт" Тип="Вещественное" Точность="9" Опции="CtrlC " Описание="фактичиское значение содержания вещества из протокола"/>
                <Поле Имя="Отклонение" Тип="Вещественное" Точность="9" Опции="CtrlC " Описание="не используется"/>
                <Поле Имя="Повторность" Тип="Целое" Опции="CtrlC " Описание="повторность нарушения, указывается в протоколе акта в случае невозможности определить автоматически"/>
