                <Поле Имя="Число цепей" Тип="Целое" Размер="1" Описание="Число параллельных цепей"/>
                <Поле Имя="АСопротивление" Тип="Вещественное" Описание="Активное сопротивление"/>
                <Поле Имя="УПотери" Тип="Вещественное" Описание="Удельные потери"/>
                <Поле Имя="РасчетныеПризнаки" Тип="Флаги" Описание="Признаки, влияющие на расчет"/>
