                <Индекс Имя="Ответчик-Документ" Поля="Ответчик-Документ, Ответчик-Человек" ДопПоля="Паспорт"/>
                <Индекс Имя="Ответчик-Частные лица" Поля="Ответчик-Частные лица"/>
                <Индекс Имя="СовместнаяСОтветчик" Поля="СовместнаяСОтветчик,СовместнаяСЧС"/>
            </Индексы_базы>
            <Триггеры>
                <Триггер Имя="Список_ответчиков" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql" Сущность1="Ответчик-Документ"/>
            </Триггеры>
        </Table>
        <Table Имя="Расширение функционала ДЛЖ" Описание="Хранение характеристик функциональных справочников ДЛЖ">
            <Поля>
                <Поле Имя="ДополнительныйТип" Тип="Целое" Описание="Для типа 0 - возможность устанавливать факсимиле. Для типа 1 - определеяется перечисляемым ДополнительныйТип из Фазы документа"/>
                <Поле Имя="Задача" Тип="Целое" Описание="Определяет задачу - АРМ Юриста Фл или ЮЛ"/>
                <Поле Имя="Название" Тип="Строка"/>
                <Поле Имя="Папки" Тип="Иерархия" Опции="BreakDelete " Описание="Поле иерархии"/>
