                <Поле Имя="Сумма2" Тип="Деньги" Опции="CtrlC " Описание="Итоговая сумма без ндс"/>
                <Поле Имя="Примечание" Тип="Строка" Описание="Примечание"/>
                <Поле Имя="идПродавец" Тип="Внешний ключ" Таблица="Организации" При_удалении="NO ACTION" Описание="Ссылка на организацию - продавца"/>
