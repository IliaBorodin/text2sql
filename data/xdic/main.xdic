                <Поле Имя="ВидСвязи" Тип="Перечисляемое" Размер="1" Поля="Автоматический\nРучной"/>
                <Поле Имя="Договор" Тип="Целое" Описание="Идентификатор договора юр. лица"/>
                <Поле Имя="Лицевой" Тип="Целое" Описание="Идентификатор точки учета юр. лица"/>
