                <Поле Имя="Флаги" Тип="Целое" Описание="Маршрут ТО"/>
                <Поле Имя="Иконка" Тип="Строка" Описание="Иконка маршрута"/>
                <Поле Имя="Описание" Тип="Строка" Описание="Описание маршрута"/>
                <Поле Имя="КатегорииРабот" Тип="Строка" PostgreSQL="jsonb"/>
                <Поле Имя="Владелец" Тип="Внешний ключ" Таблица="Сотрудники" При_удалении="NO ACTION" />
