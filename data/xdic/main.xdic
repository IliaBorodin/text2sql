         </Поля>
         <Триггеры>
            <Триггер Имя="ПП_расположение_наименование" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql" />
         </Триггеры>
      </Table>
      <Table Имя="ПП права по статусам">
         <Поля>
            <Поле Имя="ПользовательскоеПоле" Тип="Внешний ключ" Таблица="ДО наборы параметров" При_удалении="CASCADE" Описание="Указатель на набор параметров" />
            <Поле Имя="Права" Тип="Целое" Описание="0 - по умолчанию, 1 - обязательное поле, 2 - нельзя редактировать" />
            <Поле Имя="Статус" Тип="Внешний ключ" Таблица="ДО категории фаз" При_удалении="CASCADE" Описание="Указатель на категорию фазы"/>
            <Поле Имя="Роль" Тип="Целое" Описание="Указатель на роль" />
