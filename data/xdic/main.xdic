            <Триггеры>
                <Триггер Имя="ПДК_состав" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql" Сущности1="ПДК-Акт,ПДК-Декларация" />
            </Триггеры>
        </Table>
        <Table Имя="ПДК расчет" Вид="Служебная" Категория="Начислительные">
            <Поля>
                <Поле Имя="ПДК-Акт" Тип="Внешний ключ" Таблица="ПДК акт" При_удалении="CASCADE" Описание="ссылка на акт"/>
                <Поле Имя="ПДК-Декларация" Тип="Внешний ключ" Таблица="ПДК декларация" При_удалении="CASCADE" Описание="ссылка на декларацию"/>
                <Поле Имя="ПДК-Вид" Тип="Внешний ключ" Таблица="Вещества" При_удалении="NO ACTION" Описание="ссылка на справочник веществ"/>
                <Поле Имя="ПДК-Сеть" Тип="Внешний ключ" Таблица="Сеть элементы" При_удалении="NO ACTION"/>
                <Поле Имя="Норма" Тип="Вещественное" Точность="9"/>
                <Поле Имя="Факт" Тип="Вещественное" Точность="9"/>
                <Поле Имя="Кратность" Тип="Вещественное" Точность="9"/>
                <Поле Имя="Сумма" Тип="Деньги"/>
                <Поле Имя="Месяц" Тип="Дата" Размер="2"/>
                <Поле Имя="ЗаМесяц" Тип="Дата" Размер="2"/>
                <Поле Имя="Коэф" Тип="Целое"/>
                <Поле Имя="Тип" Тип="Целое" Описание="0 - Приложение 4, 1 - Приложение 4(1), 2 - Приложение 5, 3 - НССВ (ПДК)"/>
                <Поле Имя="Аналитика" Тип="Целое" Описание="Флагавое поле расшифровывающее как прошел расчет по веществу"/>
                <Поле Имя="Коэф1" Тип="Вещественное" Описание="Коэффициент компенсации за негативное воздействие на окружающую среду; поле Коэффициент k1 в справочнике нормативов для расчета НССВ" />
                <Поле Имя="Коэф2" Тип="Вещественное" Описание="Коэффициент, равный 0,5. Если не применяется, равен 1; поле Коэффициент k2 в справочнике нормативов для расчета НССВ" />
                <Поле Имя="Коэф3" Тип="Вещественное" Описание="Коэффициент, устанавливаемый Правительством РФ; константа КОЭФИНДЕКСАЦИИ" />
                <Поле Имя="Коэф4" Тип="Вещественное" Описание="Коэффициент, учитывающий расходы организации, осуществляющей водоотведение, на выполнение функций по исчислению платы за сброс; Константа КОЭФРАСХОДНССВ" />
                <Поле Имя="Ставка" Тип="Вещественное" Описание="Ставка платы за негативное воздействие на окружающую среду (руб./т); поле Ставка в справочнике нормативов для расчета НССВ" />
            </Поля>
            <Индексы_базы>
                <Индекс Имя="ПДК-Акт" Поля="ПДК-Акт" />
                <Индекс Имя="ПДК-Декларация" Поля="ПДК-Декларация" />
            </Индексы_базы>
        </Table>
        <Table Имя="Нормативы водоотведения" Описание="Нормативы для расчета негативного воздействия воотведения">
