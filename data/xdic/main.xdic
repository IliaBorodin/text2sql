                <Поле Имя="ДатКнц" Тип="Дата" Размер="4" Описание="Окончание периода рассрочки"/>
                <Поле Имя="МесНачДолга" Тип="Дата" Размер="4" Описание="Начало периода образования задолженности"/>
                <Поле Имя="МесКнцДолга" Тип="Дата" Размер="4" Описание="Окончание периода образования задолженности"/>
                <Поле Имя="МесНачПени" Тип="Дата" Размер="4" Описание="Начало периода образования задолженности по пени"/>
                <Поле Имя="МесКнцПени" Тип="Дата" Размер="4" Описание="Окончание периода образования задолженности по пени"/>
                <Поле Имя="ОстатокСуммы" Тип="Деньги" Опции="CtrlC " Описание="Неоплаченный остаток основного долга (пока только ЮЛ)"/>
                <Поле Имя="ОстатокПроцентов" Тип="Деньги" Опции="CtrlC " Описание="Неоплаченный остаток процентов, начисленных по соглашению (пока только ЮЛ)"/>
                <Поле Имя="Процент" Тип="Вещественное" Точность="9" Описание="Процент рассрочки"/>
                <Поле Имя="СоглашениеСтатус" Тип="Целое" Описание="Код последнего статуса, с пометкой Служебный (из таблицы классификаторы)"/>
                <Поле Имя="Сумма" Тип="Деньги" Опции="CtrlC " Описание="Сумма долга по услугам рассрочки"/>
                <Поле Имя="СуммаПени" Тип="Деньги" Опции="CtrlC " Описание="Сумма долга по пени рассрочки"/>
                <Поле Имя="Признаки" Тип="Целое" Описание="Текущий статус соглашения: 0 - в Работе, 2 - Расторгнуто, 6 - Погашено, 7 - Погашено принудительно (*) - для ЮЛ дублируется в справочнике Статусов соглашений"/>
                <Поле Имя="Примечание" Тип="Строка" Длина="250"/>
                <Поле Имя="Тип" Тип="Целое" Описание="Перечисляемое поле - значения определяются ф-цией (реструктуризация долга,Рассрочка суммы,72-75 354, распределение тек.начисления)"/>
                <Поле Имя="Задача" Тип="Целое"/>
                <Поле Имя="Автор" Тип="Внешний ключ" Таблица="Сотрудники" Описание="Ответственный сотрудник"/>
                <Поле Имя="МесяцРазрываСоглашения" Тип="Дата" Размер="4"/>
                <Поле Имя="Соглашение-РН документ" Тип="Внешний ключ" Таблица="РН документ" При_удалении="CASCADE"/>
                <Поле Имя="ТипПроцента" Тип="Перечисляемое" Поля="по ставке рефинансирования\nаннуитетный платеж"/>
                <Поле Имя="ВидПроцента" Тип="Перечисляемое" Поля="из графика\nна лету" Описание="Вид расчета процента"/>
                <Поле Имя="СрокОплаты" Тип="Целое"/>
                <Поле Имя="Потребитель" Тип="Внешний ключ" Таблица="Частные лица" Описание="Ссылка на частное лицо"/>
                <Поле Имя="ДатаСменыСтатуса" Тип="Дата" Размер="4"/>
                <Поле Имя="УчитыватьПени" Тип="Целое" Описание="Учитывать ли сальдо по пени"/>
                <Поле Имя="ФильтрПени" Тип="Строка" Длина="250" Описание="строка с фильтром по пени"/>
                <Поле Имя="ФильтрСоглашений" Тип="Строка" PostgreSQL="jsonb" Описание="Пока реализовано только для ЮЛ: хранит информацию о выбранном наборе фильтров при создании соглашений"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="Лицевой" Поля="Лицевой" ДопПоля="ДатНач,ДатКнц"/>
                <Индекс Имя="Договор" Поля="Договор" ДопПоля="ДатНач,ДатКнц"/>
                <Индекс Имя="Задача" Поля="Задача"/>
            </Индексы_базы>
