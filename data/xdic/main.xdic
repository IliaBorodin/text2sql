        <Table Имя="#Показания_для_контроля" Вид="Временная" Схема="tmp">
            <Поля>
                <Поле Имя="row_id" Тип="Целое" Опции="Identity"/>
                <Поле Имя="N п/п" Тип="Целое"/>
                <Поле Имя="Акт" Тип="Целое" Размер="1" Длина="3"/>
                <Поле Имя="Дата" Тип="Дата" Размер="2"/>
                <Поле Имя="Дополнительный расход" Тип="Вещественное" Точность="9" Опции="CtrlC "/>
                <Поле Имя="Итоговый расход" Тип="Вещественное" Точность="9" Опции="CtrlC "/>
                <Поле Имя="Контроль-Документ" Тип="Целое" />
                <Поле Имя="Контроль-Счет" Тип="Целое"/>
                <Поле Имя="Контроль-Услуга" Тип="Целое"/>
                <Поле Имя="Объект-Контроль" Тип="Целое"/>
                <Поле Имя="Показание" Тип="Вещественное" Точность="9" Опции="CtrlC "/>
                <Поле Имя="Расход" Тип="Вещественное" Точность="9" Опции="CtrlC "/>
                <Поле Имя="Расчетный месяц" Тип="Дата" Размер="2"/>
                <Поле Имя="Сумма" Тип="Вещественное" Точность="9" Опции="CtrlC "/>
                <Поле Имя="СчМесяцев" Тип="Целое" Размер="1" Опции="CtrlC "/>
                <Поле Имя="Тариф" Тип="Целое" Размер="1" Опции="CtrlC "/>
                <Поле Имя="Тип" Тип="Целое" Размер="1"/>
                <Поле Имя="ТипВвода" Тип="Целое" Размер="2" Опции="CtrlC "/>
                <Поле Имя="Показания-Источник" Тип="Целое" Размер="2"/>
                <Поле Имя="Контроль-Показание" Тип="Целое" />
                <Поле Имя="ФлагОшибок" Тип="Флаги" Размер="4" Поля="Нет счетчика\nРасход превышает предельное значение\nОтрицательный расход/Перекрутка\nСчетчик не работает\nПоказание больше разрядности\nДата/месяц меньше или равна предыдущей\nНеверная тарифность\nНе найден лицевой счет\nЛицевой счет закрыт\nРасчетный месяц на лицевом закрыт\nПоказания не по всем тарифам/Не принято показание по одному из тарифов\nПредыдущее показание было изменено\nДвукратный недопуск\nКП меньше предыдущего показания\nНет даты/месяца показаний\nАкт ограничения\nОднократный недопуск"/>
                <Поле Имя="НомерЛС файл" Тип="Текст" Размер="255"/>
                <Поле Имя="СтороннийЛС файл" Тип="Текст" Размер="255"/>
                <Поле Имя="АдресЛС файл" Тип="Текст" Размер="255"/>
                <Поле Имя="ФИО файл" Тип="Текст" Размер="255"/>
                <Поле Имя="Услуга файл" Тип="Текст" Размер="255"/>
                <Поле Имя="ЗаводскойНомер файл" Тип="Текст" Размер="255"/>
                <Поле Имя="ТипСчетчика файл" Тип="Текст" Размер="255"/>
                <Поле Имя="Тарифность файл" Тип="Целое" Размер="1" Опции="CtrlC "/>
                <Поле Имя="Контроль-Платеж" Тип="Целое"/>
                <Поле Имя="Контроль-ПрПлатеж" Тип="Целое"/>
                <Поле Имя="ДокументГрупповой-Контроль" Тип="Целое"/>
                <Поле Имя="ТипПоказаний" Тип="Перечисляемое" Поля="Ипу\Окпу\nОДПУ" Значение_по_умолчанию="0"/>
                <Поле Имя="УникГуид" Тип="Гуид" Описание="guid уникальный из Стек-коннекта который приходит"/>
                <Поле Имя="УникГуидОперации" Тип="Гуид" Описание="Уникальный guid операции для Стек-Коннекта"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="Счет" Поля="Контроль-Счет, Тариф, Дата" ДопПоля="Показание, Объект-Контроль"/>
                <Индекс Имя="Контроль-Документ" Поля="Контроль-Документ"/>
                <Индекс Имя="Контроль-Показание" Поля="Контроль-Показание" ДопПоля="Итоговый расход"/>
                <Индекс Имя="Объект-Контроль" Поля="Объект-Контроль, Тип, Тариф, ТипВвода" ДопПоля=""/>
                <Индекс Имя="Платеж_Документ" Поля="Контроль-Платеж, Контроль-Документ" ДопПоля=""/>
                <Индекс Имя="Ix_ДокументГрупповой_Контроль" Поля="ДокументГрупповой-Контроль, Объект-Контроль, Тип, Тариф, ТипВвода" ДопПоля=""/>
                <Индекс Имя="УникГуидОперации" Поля="Контроль-Документ, УникГуидОперации"/>
            </Индексы_базы>
            <Триггеры/>
        </Table>
        <Table Имя="Показания счетчиков" Категория="Показания" Описание="Информация о показаниях приборов учета (ИПУ, ОДПУ, ОКПУ), распределенных объемах коллективных приборов учета, связей лицевых счетов и коллективных приборов учета">
            <Поля>
                <Поле Имя="N п/п" Тип="Целое" Описание="Порядковый номер в ведомости"/>
                <Поле Имя="Акт" Тип="Целое" Размер="1" Длина="3"/>
                <Поле Имя="Дата" Тип="Дата" Размер="2" Описание="Дата показания (по месяцу этого поля определяется месяц, в котором показание будет принято к расчету при методике расчета от даты показания)"/>
                <Поле Имя="Дополнительный расход" Тип="Вещественное" Точность="9" Опции="CtrlC " Описание="Пользовательская добавка к расходу, определенному по показанию"/>
                <Поле Имя="Итоговый расход" Тип="Вещественное" Точность="9" Опции="CtrlC " Описание="Расход*[Коэффициент трансформации] + Дополнительный расход"/>
                <Поле Имя="Объект-Показания" Тип="Внешний ключ" Таблица="Список объектов" При_удалении="CASCADE" Описание="Прибор учета, к которому относится показание"/>
                <Поле Имя="Платеж-Счетчики" Тип="Внешний ключ" Таблица="Список оплаты" При_удалении="CASCADE" Описание="Платеж. с которым было передано показание в момент оплаты абонентом. Поступает по информации от платежных агентов"/>
                <Поле Имя="Показание" Тип="Вещественное" Точность="9" Опции="CtrlC " Описание="Значение показания"/>
                <Поле Имя="Показания-Документ" Тип="Внешний ключ" Таблица="Документ" При_удалении="CASCADE" Описание="Ведомость из которой показание"/>
                <Поле Имя="Показания-Счет" Тип="Внешний ключ" Таблица="Лицевые счета" При_удалении="CASCADE" Описание="Лицевой, на котором прибор учета, которого показание"/>
                <Поле Имя="Показания-Услуга" Тип="Внешний ключ" Таблица="Типы услуг" При_удалении="CASCADE"/>
                <Поле Имя="Показания-Акт" Тип="Внешний ключ" Таблица="ПУ Акты" При_удалении="CASCADE"/>
                <Поле Имя="ПрПлатеж-Счетчики" Тип="Внешний ключ" Таблица="Проблемные платежи" При_удалении="CASCADE" Описание="При подкачке платежей, если платеж не прошел проверки корректности, он хранится во вспомогательных таблицах, до обработки пользователем и переноса в основные. И показания тоже привязаны к нему"/>
                <Поле Имя="Примечание" Тип="Строка" Длина="1000"/>
                <Поле Имя="Расход" Тип="Вещественное" Точность="9" Опции="CtrlC " Описание="Разница показания и предыдущего показания. Вычисляется автоматически"/>
                <Поле Имя="Расчетный месяц" Тип="Дата" Размер="2" Описание="Месяц, в котором показание будет принято к расчету (при методике расчета по показаниям от месяца)"/>
                <Поле Имя="Сумма" Тип="Вещественное" Точность="9" Опции="CtrlC " Описание="Поле используется для неинсталляционных методик, когда через псевдопоказание передается сумма к начислению или распределению"/>
                <Поле Имя="СчМесяцев" Тип="Целое" Размер="1" Длина="3" Описание="Количество месяцев от последнего расчетного показания. Используется для перерасчета объемов по среднему при отсутствии показаний"/>
                <Поле Имя="Тариф" Тип="Целое" Размер="1" Длина="3" Опции="CtrlC " Описание="Для многотарифных счетчиков - номер тарифа данного показания. Для однотарифных - 0"/>
                <Поле Имя="Тип" Тип="Целое" Размер="1" Длина="3" Описание="1 - показание ИПУ, 4 - распределенный объем от ОДПУ, ОКПУ; 5 - показание ОДПУ/ОКПУ, 6 - привязка лицевых к ОДПУ/ОКПУ (выполнена через фиктивные записи с типом 6 в таблице [Показания счетчиков])"/>
                 <Поле Имя="ТипВвода" Тип="Целое" Опции="CtrlC " Описание="Тип ввода показания. Соответствие числовых кодов и смысла в функции"/>
                <Поле Имя="ФлагОшибок" Тип="Флаги" Поля="нет счетчика\nрасход превышает предельное значение\nотрицательный расход\nсчетчик не работает\nпоказание превышает разрядность\nпоказание с меньшей датой\nневерная тарифность" Описание="Хранит результаты проверки показания на корректность при автоматической загрузке из внешних источников"/>
                <Поле Имя="ФотографияПоказания" Тип="Строка" Длина="256" />
                <Поле Имя="Акт-Показания" Тип="Внешний ключ" Таблица="Акты нарушений" При_удалении="CASCADE" Описание="Акт нарушений, к которому относится показание"/>
                <Поле Имя="Показания-Источник" Тип="Внешний ключ" Таблица="Источники показаний" При_удалении="NO ACTION" Описание="Источник показаний"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="Ix_Объект_Показания_ПредПок" Поля="Объект-Показания, Тип, ТипВвода, Расчетный месяц DESC, Дата DESC" ДопПоля="Тариф, Показание" Выражение="((&quot;Тип&quot; = ANY (ARRAY~[1, 5]~)) AND (&quot;ТипВвода&quot; &lt;> 7))" Коэффициент_заполнения="90"/>
                <Индекс Имя="Ix_Показания_Счет_Месяц" Поля="Показания-Счет, Расчетный месяц" ДопПоля="Показания-Услуга, Дата, Тариф" Коэффициент_заполнения="80"/>
                <Индекс Имя="Ix_Объект_Показания_Дата" Поля="Объект-Показания, Дата DESC" ДопПоля="Расчетный месяц, Тип, Тариф, Показание" Коэффициент_заполнения="90"/>
                <Индекс Имя="Ix_Показания_Документ" Поля="Показания-Документ, Тип, ТипВвода" ДопПоля="Показания-Счет, Дата" />
                <Индекс Имя="Ix_Показания_Док_РМ" Поля="Показания-Документ, Расчетный месяц, Тип" ДопПоля="Расход, Сумма, Показания-Услуга, Дополнительный расход" />
                <Индекс Имя="Ix_Тип_Счет_Документ" Поля="Тип, Показания-Счет, Показания-Документ" Выражение='&quot;Тип&quot; = 6'/>
                <Индекс Имя="Ix_Платеж_Счетчики" Поля="Платеж-Счетчики" Выражение="&quot;Платеж-Счетчики&quot; is not null"/>
                <Индекс Имя="Ix_Платеж_Счетчики_2" Поля="Платеж-Счетчики, Расчетный месяц" Выражение='&quot;Платеж-Счетчики&quot; is not null and &quot;Расчетный месяц&quot; IS NOT NULL'/>
                <Индекс Имя="Ix_ПрПлатеж_Счетчики" Поля="ПрПлатеж-Счетчики" ДопПоля="ФлагОшибок" Выражение="&quot;ПрПлатеж-Счетчики&quot; is not null"/>
                <Индекс Имя="Ix_Дата_Счет" Поля="Дата, Показания-Счет"/>
                <Индекс Имя="Ix_Месяц_Счет" Поля="Расчетный месяц, Показания-Счет, Тип" ДопПоля="Дата, Сумма, Объект-Показания, Тариф, Показания-Услуга, СчМесяцев, Показания-Документ, Платеж-Счетчики, Показание, Итоговый расход, Расход, Дополнительный расход, ТипВвода" Коэффициент_заполнения="80"/>
                <Индекс Имя="Показания-Услуга" Поля="Показания-Услуга"/>
                <Индекс Имя="Показания-Акт" Поля="Показания-Акт" Выражение="&quot;Показания-Акт&quot; is not null"/>
                <Индекс Имя="Акт-Показания" Поля="Акт-Показания" Выражение="&quot;Акт-Показания&quot; is not null"/>
                <Индекс Имя="Ix_Показания_Документ_Дата" Поля="Показания-Документ, Дата" ДопПоля="Показания-Счет, Расчетный месяц" />
            </Индексы_базы>
            <Триггеры>
                <Триггер Имя="Показ_счетчиков" Версия="2" Шаблон="Шаблон_LOG_ALLTRIG.sql" Сущности1="Показания-Счет,Показания-Документ,Платеж-Счетчики" Сущность2="Объект-Показания"/>
                <Триггер Имя="Показания счетчиков_BF_ALLTRIG" Версия="2" Файл="Показания счетчиков_BF_INSTRIG.sql"/>
            </Триггеры>
            <Политики>
                <Политика Имя="AP_Usl" Файл="Показания счетчиков_Select_AP_Usl.sql"/>
            </Политики>
        </Table>
        <Table Имя="Показатели кадастровой стоимости">
            <Поля>
