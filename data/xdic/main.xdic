                <Поле Имя="ID_ACTIONS" Тип="Строка" Длина="2000" Описание="Стронний код фазы (по умолчанию используем поле Код из справочика фаз. При неоходимости дополнительно готовится список соответствий) *Обязательное"/>
                <Поле Имя="ID_ACTIONS2" Тип="Строка" Длина="2000" Описание="Сторонний код подфазы (по умолчанию используем поле Код из справочника Состояния фаз. Является обязательным в случае, если на на фазе, указанной в ID_ACTIONS есть состояния. При неоходимости дополнительно готовится список соответствий.)"/>
                <Поле Имя="NPP" Тип="Целое" Описание="Служебное: номер по порядку - генерируется в постобработке"/>
                <Поле Имя="NUMBER" Тип="Строка" Длина="2000" Описание="Номер фазы"/>
                <Поле Имя="PENI" Тип="Вещественное" Точность="9" Описание="Сумма пени (разделитель .)"/>
                <Поле Имя="PERIOD_FOR" Тип="Дата" Размер="2" Описание="Служебное: Дата последнего месяца долга (актуально для досудебной работы)"/>
                <Поле Имя="PERIOD_FROM" Тип="Дата" Размер="2" Описание="Служебное: Дата начала образования задолженности (актуально для досудебной работы)"/>
                <Поле Имя="PRIM" Тип="Строка" Длина="2000" Описание="Примечание к фазе"/>
                <Поле Имя="SUM" Тип="Вещественное" Точность="9" Описание="Сумма основного долга (разделитель .)"/>
                <Поле Имя="SUMM_PR" Тип="Вещественное" Точность="9" Описание="Сумма прочих расходов (разделитель .)"/>
            </Поля>
            <Индексы_базы>
