        <Table Имя="Сеть сверка заголовок" Описание="Реестр документов - сверок полезного отпуска">
            <Поля>
                <Поле Имя="Папки" Тип="Иерархия" Опции="NoDelete " Описание="Указатель на папку"/>
                <Поле Имя="Дата" Тип="Дата" Размер="2" Описание="Дата документа сверки"/>
                <Поле Имя="Месяц" Тип="Дата" Размер="2" Описание="Месяц сверки"/>
                <Поле Имя="Номер" Тип="Целое" Описание="Номер документа сверки"/>
                <Поле Имя="Название" Тип="Текст" Описание="Название сверки"/>
                <Поле Имя="Примечание" Тип="Текст" Описание="Пользовательское примечание"/>
                <Поле Имя="Сверка-Источник" Тип="Внешний ключ" Таблица="Организации" При_удалении="NO ACTION" Описание="Организация, с данными которой производится сверка. Указатель на таблицу ~Организации~"/>
                <Поле Имя="Автор" Тип="Внешний ключ" Таблица="Сотрудники" При_удалении="SET NULL" Описание="Сотрудник, создавший документ сверки. Указатель на таблицу ~Сотрудники~"/>
                <Поле Имя="Колво" Тип="Вещественное" MSSQL="decimal(9,1)" PostgreSQL="numeric(9,1)" Размер="5" Длина="9" Точность="1" Опции="CtrlC " Описание="Количество строк в документе сверки"/>
                <Поле Имя="Колво_Блок" Тип="Вещественное" MSSQL="decimal(9,1)" PostgreSQL="numeric(9,1)" Размер="5" Длина="9" Точность="1" Опции="CtrlC " Описание="Количество строк в документе сверки, имеющих признак блокировки"/>
                <Поле Имя="Колво_Пред" Тип="Вещественное" MSSQL="decimal(9,1)" PostgreSQL="numeric(9,1)" Размер="5" Длина="9" Точность="1" Опции="CtrlC " Описание="Количество строк в документе сверки, имеющих статус предупреждения"/>
                <Поле Имя="Колво_Ошиб" Тип="Вещественное" MSSQL="decimal(9,1)" PostgreSQL="numeric(9,1)" Размер="5" Длина="9" Точность="1" Опции="CtrlC " Описание="Количество строк в документе сверки, имеющих статус ошибки"/>
                <Поле Имя="Файл_Объем" Тип="Вещественное" MSSQL="decimal(19,3)" PostgreSQL="numeric(19,3)" Размер="9" Длина="19" Точность="3" Опции="CtrlC " Описание="Объем в документе сверки, предоставленный сторонней организацией"/>
                <Поле Имя="Расч_Объем" Тип="Вещественное" MSSQL="decimal(19,3)" PostgreSQL="numeric(19,3)" Размер="9" Длина="19" Точность="3" Опции="CtrlC " Описание="Объем в документе сверки, рассчитанный нами"/>
                <Поле Имя="Блок_Объем" Тип="Вещественное" MSSQL="decimal(19,3)" PostgreSQL="numeric(19,3)" Размер="9" Длина="19" Точность="3" Опции="CtrlC " Описание="Объем в документе сверки, рассчитанный нами, имеющий признак блокировки"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="Папки" Поля="Папки"/>
                <Индекс Имя="Номер" Поля="Номер"/>
            </Индексы_базы>
            <Триггеры>
                <Триггер Имя="Сеть_сверка_заголовок" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql"/>
            </Триггеры>
        </Table>
        <Table Имя="Сеть сверка" Описание="Состав документов - сверок полезного отпуска">
            <Поля>
                <Поле Имя="Заголовок" Тип="Внешний ключ" Таблица="Сеть сверка заголовок" При_удалении="CASCADE" Описание="Документ сверки. Указатель на таблицу ~Сеть сверка заголовок~"/>
                <Поле Имя="Лицевой" Тип="Внешний ключ" Таблица="Лицевые счета" При_удалении="CASCADE" Описание="Точка, по которой выполняется сверка. Указатель на таблицу ~Лицевые счета~"/>
                <Поле Имя="Флаги" Тип="Целое" Значение_по_умолчанию="0" Описание="Флаги сверки (текущее значение), см. sql-функцию ~net_fpo_list~"/>
                <Поле Имя="Расч_Объем" Тип="Вещественное" MSSQL="decimal(19,3)" PostgreSQL="numeric(19,3)" Размер="9" Длина="19" Точность="3" Опции="CtrlC " Описание="Объем (текущее значение)"/>
                <Поле Имя="Расч_УрНапр" Тип="Текст" Описание="Уровень напряжения (текущее значение, справочно)"/>
                <Поле Имя="Расч_Коэфф" Тип="Вещественное" MSSQL="decimal(19,9)" PostgreSQL="numeric(19,9)" Размер="9" Длина="19" Точность="9" Описание="Коэффициент расчета (текущее значение, справочно)"/>
                <Поле Имя="Блок" Тип="Целое" Размер="1" Значение_по_умолчанию="0" Описание="Признак блокировки (фиксация сверки строки)"/>
                <Поле Имя="Блок_Флаги" Тип="Целое" Значение_по_умолчанию="0" Описание="Флаги сверки (заблокированное значение), см. sql-функцию ~net_fpo_list~"/>
                <Поле Имя="Блок_Объем" Тип="Вещественное" MSSQL="decimal(19,3)" PostgreSQL="numeric(19,3)" Размер="9" Длина="19" Точность="3" Опции="CtrlC " Описание="Объем (заблокированное значение)"/>
                <Поле Имя="Блок_Примечание" Тип="Текст" Описание="Пользовательское примечание к блокировке"/>
                <Поле Имя="Файл_НомерСтр" Тип="Целое" Значение_по_умолчанию="0" Описание="Номер строки в файле"/>
                <Поле Имя="Файл_НомерДог" Тип="Текст" Описание="Номер договора (стороннее значение)"/>
                <Поле Имя="Файл_Потребитель" Тип="Текст" Описание="Название организации/потребителя (стороннее значение)"/>
                <Поле Имя="Файл_ЭтоЮрЛ" Тип="Целое" Размер="1" Описание="Признак юр. лица (стороннее значение)"/>
                <Поле Имя="Файл_ЭтоСуб" Тип="Целое" Размер="1" Описание="Признак субабонента (стороннее значение)"/>
                <Поле Имя="Файл_Номер" Тип="Текст" Описание="Номер точки (стороннее значение)"/>
                <Поле Имя="Файл_Название" Тип="Текст" Описание="Описание точки (стороннее значение)"/>
                <Поле Имя="Файл_Адрес" Тип="Текст" Описание="Адрес точки (стороннее значение)"/>
                <Поле Имя="Файл_Марка" Тип="Текст" Описание="Марка прибора учета (стороннее значение)"/>
                <Поле Имя="Файл_ЗавНомер" Тип="Текст" Описание="Заводской номер прибора учета (стороннее значение)"/>
                <Поле Имя="Файл_Тарифность" Тип="Целое" Размер="1" Описание="Тарифность (стороннее значение)"/>
                <Поле Имя="Файл_Тариф" Тип="Целое" Размер="1" Описание="Тариф (стороннее значение)"/>
                <Поле Имя="Файл_Дата" Тип="Дата" Размер="2" Описание="Дата (стороннее значение)"/>
                <Поле Имя="Файл_Показание" Тип="Вещественное" MSSQL="decimal(19,3)" PostgreSQL="numeric(19,3)" Размер="9" Длина="19" Точность="3" Описание="Показание (стороннее значение)"/>
                <Поле Имя="Файл_Объем" Тип="Вещественное" MSSQL="decimal(19,3)" PostgreSQL="numeric(19,3)" Размер="9" Длина="19" Точность="3" Опции="CtrlC " Описание="Объем (стороннее значение)"/>
                <Поле Имя="Файл_ДопДанные" Тип="Текст" Описание="Дополнительные данные (json) по строке (стороннее значение)"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="Заголовок" Поля="Заголовок"/>
                <Индекс Имя="Лицевой" Поля="Лицевой"/>
            </Индексы_базы>
        </Table>
        <Table Имя="Профили счетчиков" Описание="Профили (часовые) приборов учета">
            <Поля>
                <Поле Имя="Счетчик-Профиль" Тип="Внешний ключ" Таблица="Список объектов" При_удалении="CASCADE" Описание="Прибор учета. Указатель на таблицу ~Список объектов~"/>
                <Поле Имя="Дата" Тип="Дата" Размер="2" Описание="Дата профиля"/>
                <Поле Имя="Интервал" Тип="Целое" Описание="Номер интервала (часа) внутри суток (поле Дата), начиная с 0"/>
                <Поле Имя="Значение" Тип="Вещественное" MSSQL="decimal(19,3)" PostgreSQL="numeric(19,3)" Размер="9" Длина="19" Точность="3" Опции="CtrlC " Описание="Значение на интервале (объем"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="Счетчик-Профиль" Поля="Счетчик-Профиль, Дата"/>
            </Индексы_базы>
        </Table>
        <Table Имя="Ведомости обхода реестр" Описание="Реестр документов - ведомостей обхода">
            <Поля>
                <Поле Имя="Папки" Тип="Иерархия" Опции="BreakDelete " Описание="Указатель на папку"/>
                <Поле Имя="Номер" Тип="Длинное целое" Описание="Номер ведомости обхода"/>
                <Поле Имя="Дата" Тип="Дата" Размер="2" Описание="Дата ведомости обхода"/>
                <Поле Имя="Тип" Тип="Целое" Размер="1" Длина="3" Описание="Не используется"/>
                <Поле Имя="Примечание" Тип="Строка" Описание="Пользовательское примечание"/>
                <Поле Имя="Флаги" Тип="Целое" Размер="1" Длина="3" Описание="Состояние ведомости: 0 - открыта, 1 - закрыта"/>
                <Поле Имя="Ведомость-Автор" Тип="Внешний ключ" Таблица="Сотрудники" При_удалении="NO ACTION" Описание="Сотрудник, создавший ведомость обхода. Указатель на таблицу ~Сотрудники~"/>
            </Поля>
            <Индексы_базы/>
            <Триггеры>
               <Триггер Имя="Ведомости_обхода_реестр" Версия="1" Шаблон="Шаблон_LOG_ALLTRIG.sql"/>
            </Триггеры>
        </Table>
        <Table Имя="Ведомости обхода" Описание="Состав документов - ведомостей обхода">
            <Поля>
                <Поле Имя="НПП" Тип="Целое" Описание="Порядковый номер прибора в ведомости обхода (порядок сортировки)"/>
                <Поле Имя="Ведомость-Реестр" Тип="Внешний ключ" Таблица="Ведомости обхода реестр" При_удалении="CASCADE" Описание="Документ ведомости обхода. Указатель на таблицу ~Ведомости обхода реестр~"/>
                <Поле Имя="Ведомость-Объект" Тип="Внешний ключ" Таблица="Список объектов" При_удалении="CASCADE" Описание="Прибор учета. Указатель на таблицу ~Список объектов~"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="Ведомость-Реестр" Поля="Ведомость-Реестр"/>
                <Индекс Имя="Ведомость-Объект" Поля="Ведомость-Объект"/>
