        </Table>
        <Table Имя="ДО фазы" Описание="Фазы маршрута">
            <Поля>
                <Поле Имя="Маршрут-Фазы" Тип="Внешний ключ" Таблица="ДО маршруты" При_удалении="CASCADE" Описание="Указатель на маршрут"/>
                <Поле Имя="Исполнитель по умолчанию" Тип="Внешний ключ" Таблица="Сотрудники" При_удалении="SET NULL" Описание="Указатель на сортудника-исполнителя по умолчанию"/>
                <Поле Имя="Группа по умолчанию" Тип="Внешний ключ" Таблица="Группы сотрудников" При_удалении="SET NULL" Описание="Поле для ДО"/>
                <Поле Имя="Фаза-Категория" Тип="Внешний ключ" Таблица="ДО категории фаз" При_удалении="NO ACTION" Описание="Указатель на справорчник фаз"/>
                <Поле Имя="Фаза-Шаблон журнала" Тип="Внешний ключ" Таблица="ДО категории журналов" При_удалении="SET NULL" Описание="Поле для ДО"/>
                <Поле Имя="Папки" Тип="Иерархия" Опции="BreakDelete " Описание="Папки"/>
                <Поле Имя="Автовыполнение" Тип="Целое" Размер="1" Длина="3" Описание="Возможность автовыполнения"/>
                <Поле Имя="Номер" Тип="Целое" Опции="CtrlC " Описание="Номер фазы в маршруте"/>
                <Поле Имя="СледующийНомер" Тип="Целое" Опции="CtrlC " Описание="Номер следующей фазы в маршруте"/>
                <Поле Имя="Флаги" Тип="Целое"/>
                <Поле Имя="Предыдущий исполнитель" Тип="Целое" Размер="1" Длина="3" Опции="CtrlC " Описание="Подставлять по умолчанию исполнителя с предыдущей фазы заявки"/>
                <Поле Имя="УказатьПредФазу" Тип="Целое" Размер="1" Длина="3" Опции="CtrlC " Описание="Необходимо указать предыдущую фазу в переходе"/>
                <Поле Имя="Автоматическое завершение" Тип="Целое" Размер="1" Длина="3" Опции="CtrlC " Описание="Автоматическое завершение работы по фазе"/>
                <Поле Имя="Авт_зав_дней" Тип="Целое" Размер="2" Длина="5" Опции="CtrlC " Описание="Поле дял ДО"/>
                <Поле Имя="Авт_пред_дней" Тип="Целое" Размер="2" Длина="5" Опции="CtrlC " Описание="Поле дял ДО"/>
                <Поле Имя="Авт_переход" Тип="Внешний ключ" Таблица="ДО фазы" При_удалении="SET NULL" Описание="Поле дял ДО"/>
                <Поле Имя="Авт_коммент" Тип="Строка" Описание="Поле дял ДО"/>
                <Поле Имя="Авт_предупр_ф_ия" Тип="Строка" Описание="Поле дял ДО"/>
                <Поле Имя="Авт_завершение_ф_ия" Тип="Строка" Описание="Поле дял ДО"/>
                <Поле Имя="План в часах" Тип="Вещественное" Точность="9" Опции="CtrlC " Описание="Поле дял ДО"/>
                <Поле Имя="Последний шаг" Тип="Целое" Описание="Завершающая фаза маршрута"/>
                <Поле Имя="Обязателен комментарий" Тип="Целое" Описание="Комментарий к работе с фазой обязателен"/>
                <Поле Имя="ПланВремя" Тип="Время" Размер="4" Описание="Поле дял ДО"/>
                <Поле Имя="СрокДней" Тип="Целое" Размер="2" Длина="5" Опции="CtrlC " Описание="Срок исполнения в днях"/>
                <Поле Имя="СрокРабДни" Тип="Целое" Значение_по_умолчанию="0" Описание="Признак, что дни в сроке рабочие, а не календарные"/>
                <Поле Имя="Подсказка" Тип="Строка" Длина="7000" Описание="Полсказка по выполнению работы на фазе для исполнителя"/>
                <Поле Имя="ТипИсполнителя" Тип="Строка" />
