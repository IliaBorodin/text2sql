                <Поле Имя="ПоУмолчанию" Тип="Целое" Описание="Признак использования источника по умолчанию"/>
                <Поле Имя="ВнешнийКод" Тип="Строка" Описание="Внешний код источника заявок"/>
            </Поля>
            <Индексы_базы>
                <Индекс Имя="ВнешнийКод" Поля="ВнешнийКод" Опции="UNIQUE"/>
