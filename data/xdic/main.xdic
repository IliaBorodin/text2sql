                <Поле Имя="Итоговый расход" Тип="Вещественное" Описание="Итоговый расход = расход*коэфтр"/>
                <Поле Имя="Дополнительный расход" Тип="Вещественное" Описание="Дополнительный расход"/>
                <Поле Имя="ОДН" Тип="Вещественное" Описание="объем СОИ"/>
                <Поле Имя="ПотериЛин" Тип="Вещественное" Описание="объем потерь в линии"/>
                <Поле Имя="Пот_л_квт" Тип="Вещественное" Описание="фиксированные потери в линии"/>
                <Поле Имя="Пот_л_пр" Тип="Вещественное" Описание="процент потерь в линии"/>
                <Поле Имя="ПотериТР" Тип="Вещественное" Описание="объем потерь в трансформаторе"/>
                <Поле Имя="Пот_тр_квт" Тип="Вещественное" Описание="фиксированные потери в трансформаторе"/>
                <Поле Имя="Пот_тр_пр" Тип="Вещественное" Описание="процент потерь в трансформаторе"/>
                <Поле Имя="ОбъемВыч" Тип="Вещественное" Описание="объем вычитания субабонетов"/>
                <Поле Имя="Аналитика" Тип="Целое" Описание="дополнительное поле в инсталляции не используется"/>
                <Поле Имя="Сортировка" Тип="Целое" Описание="сортировка при выводе в отчет"/>
                <Поле Имя="Ттар" Тип="Целое" Описание="тарифная зона для прибора учета (день, ночь, пик, полупик)"/>
                <Поле Имя="Кол_во" Тип="Вещественное" Опции="CtrlC " Описание="объем услуги"/>
                <Поле Имя="Счетчик" Тип="Целое" Значение_по_умолчанию_MSSQL="-1" Значение_по_умолчанию_PostgreSQL="&apos;-1&apos;::integer" Описание="row_id счетчика из таблицы [список объектов]"/>
                <Поле Имя="Поставщик" Тип="Целое" Значение_по_умолчанию_MSSQL="-1" Значение_по_умолчанию_PostgreSQL="&apos;-1&apos;::integer" Описание="row_id поставщика из таблицы [организации]"/>
