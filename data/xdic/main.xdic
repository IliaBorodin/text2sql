                <Поле Имя="Принял" Тип="Строка" Описание="Используется в программе Касса"/>
                <Поле Имя="Р/с-Платежи" Тип="Внешний ключ" Таблица="Расчетные счета" При_удалении="NO ACTION" Описание="Расчетный счет покупателя, с которого пришли денежные средства"/>
                <Поле Имя="РасчМесяц" Тип="Дата" Размер="2" Опции=" CheckClosed " Описание="Расчетный месяц, в котором учтен документ"/>
                <Поле Имя="Состояние" Тип="Флаги" Поля="С +\nС -\nЗакрыт\nоплачен\nОплачен\nне расчитан\nрегистрация\nРегистрация\nИзменены проводки\nБлокирована\nВыставлены документы ДЛЖ" Описание="4 - закрыт на редактирование"/>
                <Поле Имя="Срок" Тип="Дата" Размер="2" Описание="Срок оплаты по документу"/>
                <Поле Имя="Сторнирование" Тип="Иерархия" Опции="BreakDelete " Описание="Иерархическая связь на документ коррекции"/>
                <Поле Имя="Сумма" Тип="Вещественное" MSSQL="numeric(29,2)" PostgreSQL="numeric(29,2)" Размер="17" Длина="29" Точность="2" Опции="CtrlC " Описание="Сумма с НДС"/>
                <Поле Имя="Сумма1" Тип="Деньги" Опции="CtrlC " Описание="Служебное поле"/>
                <Поле Имя="Сумма2" Тип="Деньги" Опции="CtrlC " Описание="Сумма без НДС"/>
