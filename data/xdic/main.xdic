                <Поле Имя="LIST" Тип="Строка" Длина="2000" Описание="Служебное: Имя листа в xls файле"/>
                <Поле Имя="FILE" Тип="Строка" Длина="2000" Описание="Служебное: Имя xls файла"/>
            </Поля>
            <Индексы_базы>
