                <Поле Имя="Потери" Тип="Вещественное" Описание="объем потерь"/>
                <Поле Имя="Пот_фикс" Тип="Вещественное" Описание="фиксированные потери"/>
                <Поле Имя="Пот_пр" Тип="Вещественное" Описание="процент потерь"/>
                <Поле Имя="ОбъемВыч" Тип="Вещественное" Описание="объем вычитания субабонетов"/>
                <Поле Имя="Ттар" Тип="Целое" Описание="тарифная зона для прибора учета (день, ночь, пик, полупик)"/>
                <Поле Имя="Счетчик" Тип="Целое" Значение_по_умолчанию_MSSQL="-1" Значение_по_умолчанию_PostgreSQL="&apos;-1&apos;::integer" Описание="row_id счетчика из таблицы [список объектов]"/>
                <Поле Имя="ОтрОбъем_вх" Тип="Вещественное" Описание="объем отрицательной дельты входящий - принят к расчету"/>
                <Поле Имя="ОтрОбъем_исх" Тип="Вещественное" Описание="объем отрицательной дельты исходящий"/>
                <Поле Имя="Недопоставка" Тип="Вещественное" Описание="объем недопоставки"/>
                <Поле Имя="Расчет" Тип="Вещественное" Описание="объем полученный расчетным способом"/>
                <Поле Имя="Кол_во" Тип="Вещественное" Описание="начисленный объем услуги"/>
