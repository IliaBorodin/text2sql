                <Индекс Имя="Контроль_документ" Поля="Контроль-Документ, ФлагОшибок" ДопПоля="Объект-Контроль, Контроль-Счет, Дата, Контроль-Показание" Коэффициент_заполнения="90"/>
                <Индекс Имя="ФлагОшибок" Поля="ФлагОшибок" ДопПоля=""/>
